<% content_for(:title, "Documentation - Wokku") %>

<div class="min-h-screen bg-surface text-on-surface">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <div class="mb-12">
      <a href="/" class="text-sm text-primary hover:underline mb-4 inline-block">← Back to Wokku</a>
      <h1 class="font-headline text-4xl font-bold text-on-surface mb-3">Documentation</h1>
      <p class="text-outline">Everything you need to deploy and manage applications on Wokku.</p>
    </div>

    <div class="grid grid-cols-12 gap-8">
      <%# Sidebar Nav %>
      <nav class="col-span-3 sticky top-8">
        <p class="text-[10px] text-outline uppercase tracking-widest font-bold mb-3">On This Page</p>
        <div class="space-y-1">
          <a href="#getting-started" class="block text-sm text-on-surface-variant hover:text-primary transition py-1">Getting Started</a>
          <a href="#deploy-methods" class="block text-sm text-on-surface-variant hover:text-primary transition py-1">Deploy Methods</a>
          <a href="#cli" class="block text-sm text-on-surface-variant hover:text-primary transition py-1">CLI Reference</a>
          <a href="#api" class="block text-sm text-on-surface-variant hover:text-primary transition py-1">API</a>
          <a href="#addons" class="block text-sm text-on-surface-variant hover:text-primary transition py-1">Add-ons</a>
          <a href="#pricing" class="block text-sm text-on-surface-variant hover:text-primary transition py-1">Pricing</a>
        </div>
      </nav>

      <%# Content %>
      <div class="col-span-9 space-y-12">

        <%# Getting Started %>
        <section id="getting-started">
          <h2 class="font-headline text-2xl font-bold text-on-surface mb-4">Getting Started</h2>
          <p class="text-sm text-on-surface-variant mb-6">Wokku makes it easy to deploy and manage your applications. Follow these steps to get started.</p>

          <div class="space-y-6">
            <div>
              <h3 class="text-sm font-bold text-on-surface mb-2">1. Connect via GitHub</h3>
              <p class="text-xs text-outline mb-3">Sign in with GitHub OAuth and connect your repository for automatic deployments.</p>
            </div>

            <div>
              <h3 class="text-sm font-bold text-on-surface mb-2">2. Create an app</h3>
              <p class="text-xs text-outline mb-2">Create a new app from the dashboard or use the API.</p>
              <div class="bg-surface-container-lowest rounded-md p-4 font-mono text-sm text-primary">
                <span class="text-outline">$</span> curl -X POST https://wokku.dev/api/v1/apps \<br>
                <span class="text-outline pl-4">-H</span> "Authorization: Bearer YOUR_TOKEN" \<br>
                <span class="text-outline pl-4">-d</span> '{"name": "my-app", "server_id": 1}'
              </div>
            </div>

            <div>
              <h3 class="text-sm font-bold text-on-surface mb-2">3. Deploy</h3>
              <p class="text-xs text-outline mb-2">Push to your connected GitHub repo or use git push to deploy.</p>
              <div class="bg-surface-container-lowest rounded-md p-4 font-mono text-sm text-primary">
                <span class="text-outline">$</span> git push dokku main
              </div>
            </div>

            <div>
              <h3 class="text-sm font-bold text-on-surface mb-2">4. Configure</h3>
              <p class="text-xs text-outline mb-2">Set environment variables, add domains, and attach add-ons from the dashboard.</p>
            </div>
          </div>
        </section>

        <%# Deploy Methods %>
        <section id="deploy-methods">
          <h2 class="font-headline text-2xl font-bold text-on-surface mb-4">Deploy Methods</h2>
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-surface-container-low rounded-md p-5">
              <span class="material-symbols-outlined text-primary text-[24px] mb-3">code</span>
              <h3 class="text-sm font-bold text-on-surface mb-1">GitHub Auto-Deploy</h3>
              <p class="text-xs text-outline">Connect a repo and deploy automatically on push. Supports PR preview deployments.</p>
            </div>
            <div class="bg-surface-container-low rounded-md p-5">
              <span class="material-symbols-outlined text-secondary text-[24px] mb-3">terminal</span>
              <h3 class="text-sm font-bold text-on-surface mb-1">Git Push</h3>
              <p class="text-xs text-outline">Add the Dokku remote and push directly. Supports Buildpacks and Dockerfiles.</p>
            </div>
            <div class="bg-surface-container-low rounded-md p-5">
              <span class="material-symbols-outlined text-tertiary text-[24px] mb-3">rocket_launch</span>
              <h3 class="text-sm font-bold text-on-surface mb-1">1 Click Deploy</h3>
              <p class="text-xs text-outline">Deploy from 50+ pre-built templates — databases, CMS, monitoring, and more.</p>
            </div>
            <div class="bg-surface-container-low rounded-md p-5">
              <span class="material-symbols-outlined text-primary text-[24px] mb-3">deployed_code</span>
              <h3 class="text-sm font-bold text-on-surface mb-1">Docker Image</h3>
              <p class="text-xs text-outline">Deploy any Docker image directly using <code class="text-primary">git:from-image</code>.</p>
            </div>
          </div>
        </section>

        <%# CLI %>
        <section id="cli">
          <h2 class="font-headline text-2xl font-bold text-on-surface mb-4">CLI</h2>
          <p class="text-sm text-on-surface-variant mb-4">Manage apps from the terminal.</p>

          <div class="bg-surface-container-lowest rounded-md p-4 font-mono text-sm text-primary mb-4">
            <span class="text-outline">$</span> curl -sL https://wokku.dev/cli/install.sh | bash
          </div>

          <div class="space-y-3 mb-6">
            <% [
              ["wokku auth:login", "Log in to your account"],
              ["wokku apps", "List all apps"],
              ["wokku apps:create NAME --server ID", "Create a new app"],
              ["wokku apps:destroy APP_ID", "Delete an app"],
              ["wokku ps:restart APP_ID", "Restart an app"],
              ["wokku ps:scale APP_ID web=2", "Scale processes"],
              ["wokku config APP_ID", "Show config vars"],
              ["wokku config:set APP_ID KEY=VAL", "Set config vars"],
              ["wokku domains APP_ID", "List domains"],
              ["wokku domains:add APP_ID example.com", "Add a domain"],
              ["wokku logs APP_ID", "View logs"],
              ["wokku addons APP_ID", "List add-ons"],
              ["wokku addons:add APP_ID postgres", "Add a database"],
              ["wokku deploy ghost --server 1", "Deploy a template"],
              ["wokku releases APP_ID", "List releases"],
              ["wokku rollback APP_ID RELEASE_ID", "Rollback to release"],
              ["wokku activity", "Recent activity"],
            ].each do |cmd, desc| %>
              <div class="bg-surface-container-lowest rounded-md px-4 py-2.5 flex items-center justify-between">
                <code class="text-xs font-mono text-primary"><%= cmd %></code>
                <span class="text-xs text-outline"><%= desc %></span>
              </div>
            <% end %>
          </div>
        </section>

        <%# API %>
        <section id="api">
          <h2 class="font-headline text-2xl font-bold text-on-surface mb-4">API</h2>
          <p class="text-sm text-on-surface-variant mb-4">
            The Wokku API is available at <code class="bg-surface-container-highest px-2 py-0.5 rounded text-xs font-mono text-primary">https://wokku.dev/api/v1</code>.
            Authenticate with a Bearer token.
          </p>

          <div class="space-y-3">
            <% [
              ["POST /api/v1/auth/login", "Get API token"],
              ["GET /api/v1/auth/whoami", "Current user info"],
              ["GET /api/v1/apps", "List all apps"],
              ["POST /api/v1/apps", "Create app"],
              ["GET /api/v1/apps/:id", "Get app details"],
              ["PATCH /api/v1/apps/:id", "Update app"],
              ["DELETE /api/v1/apps/:id", "Delete app"],
              ["POST /api/v1/apps/:id/restart", "Restart app"],
              ["POST /api/v1/apps/:id/stop", "Stop app"],
              ["POST /api/v1/apps/:id/start", "Start app"],
              ["GET /api/v1/apps/:id/config", "Get config vars"],
              ["PUT /api/v1/apps/:id/config", "Set config vars"],
              ["GET /api/v1/apps/:id/domains", "List domains"],
              ["POST /api/v1/apps/:id/domains", "Add domain"],
              ["DELETE /api/v1/apps/:id/domains/:id", "Remove domain"],
              ["POST /api/v1/apps/:id/domains/:id/ssl", "Enable SSL"],
              ["GET /api/v1/apps/:id/releases", "List releases"],
              ["POST /api/v1/apps/:id/releases/:id/rollback", "Rollback"],
              ["GET /api/v1/apps/:id/logs", "View logs"],
              ["GET /api/v1/apps/:id/deploys", "List deploys"],
              ["GET /api/v1/apps/:id/ps", "Get process info"],
              ["PATCH /api/v1/apps/:id/ps", "Scale processes"],
              ["GET /api/v1/apps/:id/addons", "List add-ons"],
              ["POST /api/v1/apps/:id/addons", "Add add-on"],
              ["DELETE /api/v1/apps/:id/addons/:id", "Remove add-on"],
              ["GET /api/v1/templates", "List templates"],
              ["POST /api/v1/templates/deploy", "Deploy template"],
              ["GET /api/v1/databases", "List databases"],
              ["POST /api/v1/databases", "Create database"],
              ["DELETE /api/v1/databases/:id", "Delete database"],
              ["GET /api/v1/databases/:id/backups", "List backups"],
              ["POST /api/v1/databases/:id/backups", "Create backup"],
              ["GET /api/v1/servers", "List servers"],
              ["GET /api/v1/activities", "Activity log"],
              ["GET /api/v1/teams", "List teams"],
              ["GET /api/v1/notifications", "List notifications"],
            ].each do |endpoint, desc| %>
              <div class="bg-surface-container-lowest rounded-md px-4 py-3 flex items-center justify-between">
                <code class="text-xs font-mono text-primary"><%= endpoint %></code>
                <span class="text-xs text-outline"><%= desc %></span>
              </div>
            <% end %>
          </div>
        </section>

        <%# Add-ons %>
        <section id="addons">
          <h2 class="font-headline text-2xl font-bold text-on-surface mb-4">Add-ons</h2>
          <p class="text-sm text-on-surface-variant mb-4">Provision managed databases, caches, and services from the Resources tab on any app.</p>

          <div class="grid grid-cols-3 gap-3">
            <% [
              ["PostgreSQL", "database", "Relational DB"],
              ["MySQL", "database", "Relational DB"],
              ["Redis", "bolt", "Cache"],
              ["MongoDB", "database", "Document DB"],
              ["Elasticsearch", "search", "Search"],
              ["Meilisearch", "search", "Search"],
              ["RabbitMQ", "forum", "Messaging"],
              ["NATS", "forum", "Messaging"],
              ["ClickHouse", "database", "Analytics"],
            ].each do |name, icon, type| %>
              <div class="bg-surface-container-low rounded-md p-3 flex items-center gap-3">
                <span class="material-symbols-outlined text-secondary text-[16px]"><%= icon %></span>
                <div>
                  <span class="text-xs font-bold text-on-surface"><%= name %></span>
                  <span class="text-[10px] text-outline ml-1"><%= type %></span>
                </div>
              </div>
            <% end %>
          </div>
        </section>

        <%# Pricing %>
        <section id="pricing">
          <h2 class="font-headline text-2xl font-bold text-on-surface mb-4">Pricing</h2>
          <div class="bg-surface-container-low rounded-md overflow-hidden">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-surface-container-highest">
                  <th class="px-4 py-3 text-left text-[10px] text-outline uppercase tracking-wider font-bold">Plan</th>
                  <th class="px-4 py-3 text-left text-[10px] text-outline uppercase tracking-wider font-bold">RAM</th>
                  <th class="px-4 py-3 text-left text-[10px] text-outline uppercase tracking-wider font-bold">vCPU</th>
                  <th class="px-4 py-3 text-left text-[10px] text-outline uppercase tracking-wider font-bold">Storage</th>
                  <th class="px-4 py-3 text-right text-[10px] text-outline uppercase tracking-wider font-bold">Price</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-outline-variant/10">
                <% [
                  ["Free", "256 MB", "0.15", "—", "Free"],
                  ["Basic", "512 MB", "0.3", "512 MB", "$1.50/mo"],
                  ["Standard", "1 GB", "0.5", "1 GB", "$4/mo"],
                  ["Performance", "2 GB", "1.0", "2 GB", "$8/mo"],
                  ["Performance 2x", "4 GB", "2.0", "5 GB", "$15/mo"],
                ].each do |name, ram, cpu, storage, price| %>
                  <tr class="hover:bg-surface-container-high/30 transition">
                    <td class="px-4 py-3 font-bold text-on-surface font-headline"><%= name %></td>
                    <td class="px-4 py-3 font-mono text-on-surface-variant"><%= ram %></td>
                    <td class="px-4 py-3 font-mono text-on-surface-variant"><%= cpu %></td>
                    <td class="px-4 py-3 font-mono text-on-surface-variant"><%= storage %></td>
                    <td class="px-4 py-3 text-right font-bold text-primary"><%= price %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </section>
      </div>
    </div>
  </div>
</div>
