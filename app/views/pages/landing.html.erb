<% content_for(:title, t('landing.title')) %>

<style>
  @keyframes terminal-type { from { width: 0 } to { width: 100% } }
  @keyframes blink { 50% { border-color: transparent } }
  @keyframes float-up { from { opacity: 0; transform: translateY(20px) } to { opacity: 1; transform: translateY(0) } }
  @keyframes pulse-glow { 0%, 100% { box-shadow: 0 0 20px rgba(192, 193, 255, 0.1) } 50% { box-shadow: 0 0 40px rgba(192, 193, 255, 0.2) } }
  @keyframes grid-fade { from { opacity: 0 } to { opacity: 0.03 } }
  @keyframes count-up { from { opacity: 0; transform: translateY(10px) } to { opacity: 1; transform: translateY(0) } }
  .animate-float { animation: float-up 0.6s ease-out both; }
  .animate-float-1 { animation-delay: 0.1s; }
  .animate-float-2 { animation-delay: 0.2s; }
  .animate-float-3 { animation-delay: 0.3s; }
  .animate-float-4 { animation-delay: 0.4s; }
  .animate-float-5 { animation-delay: 0.5s; }
  .terminal-line { overflow: hidden; white-space: nowrap; animation: terminal-type 0.8s steps(40) both; }
  .terminal-line-2 { animation-delay: 1s; }
  .terminal-line-3 { animation-delay: 1.8s; }
  .terminal-line-4 { animation-delay: 2.6s; }
  .terminal-line-5 { animation-delay: 3.2s; }
  .terminal-cursor { border-right: 2px solid #c0c1ff; animation: blink 0.8s step-end infinite; padding-right: 2px; }
  .hero-grid { background-image: linear-gradient(rgba(192, 193, 255, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(192, 193, 255, 0.05) 1px, transparent 1px); background-size: 60px 60px; animation: grid-fade 1s ease-out both; }
  .app-card:hover { transform: translateY(-2px); box-shadow: 0 0 30px rgba(192, 193, 255, 0.08); }
  .glow-border { position: relative; }
  .glow-border::before { content: ''; position: absolute; inset: -1px; border-radius: inherit; background: linear-gradient(135deg, rgba(192, 193, 255, 0.3), transparent 50%, rgba(192, 193, 255, 0.1)); z-index: -1; opacity: 0; transition: opacity 0.3s; }
  .glow-border:hover::before { opacity: 1; }
  .feature-card { transition: all 0.2s ease; }
  .feature-card:hover { transform: translateY(-2px); background: rgba(30, 41, 59, 0.7); }
  .pricing-card { transition: all 0.2s ease; }
  .pricing-card:hover { transform: translateY(-3px); }
  .comparison-strike { text-decoration: line-through; color: #958e9e; }

  /* Meteor shower */
  .meteors { position: absolute; inset: 0; overflow: hidden; pointer-events: none; z-index: 0; }
  .meteor {
    position: absolute;
    width: 2px;
    height: 80px;
    background: linear-gradient(to top, rgba(192, 193, 255, 0.8), rgba(192, 193, 255, 0.2), transparent);
    border-radius: 2px;
    animation: meteor-streak linear infinite;
    transform: rotate(-35deg);
    filter: blur(0.5px);
  }
  .meteor::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: -1px;
    width: 4px;
    height: 4px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 8px rgba(192, 193, 255, 0.9), 0 0 20px rgba(192, 193, 255, 0.4);
  }
  @keyframes meteor-streak {
    0% { transform: rotate(-35deg) translateY(-200px); opacity: 0; }
    5% { opacity: 1; }
    60% { opacity: 0.6; }
    100% { transform: rotate(-35deg) translateY(120vh); opacity: 0; }
  }

  /* Dino follows mouse along terminal bottom */
  .terminal-dino-wrap {
    position: absolute;
    bottom: -16px;
    left: 0;
    right: 0;
    height: 40px;
    pointer-events: none;
    overflow: visible;
    z-index: 10;
  }
  .terminal-dino {
    position: absolute;
    bottom: 0;
    font-size: 28px;
    cursor: default;
    pointer-events: auto;
    opacity: 0.5;
    transition: left 0.15s ease-out, opacity 0.2s;
    left: 85%;
  }
  .terminal-dino:hover { opacity: 1; }
  .terminal-dino.dead {
    opacity: 0.6;
    animation: none;
    cursor: pointer;
  }
  @keyframes dino-shake {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-5deg); }
    75% { transform: rotate(5deg); }
  }
</style>

<!-- Hero -->
<div class="relative overflow-hidden">
  <div class="hero-grid absolute inset-0"></div>
  <div class="absolute top-20 left-1/4 w-96 h-96 bg-[#c0c1ff]/5 rounded-full blur-[120px]"></div>
  <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-[#c0c1ff]/3 rounded-full blur-[100px]"></div>

  <%# Meteor shower %>
  <div class="meteors">
    <% 12.times do |i| %>
      <div class="meteor" style="left: <%= rand(10..90) %>%; animation-duration: <%= rand(20..40) / 10.0 %>s; animation-delay: <%= rand(0..80) / 10.0 %>s; height: <%= rand(60..120) %>px; opacity: <%= rand(3..7) / 10.0 %>;"></div>
    <% end %>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-28">
    <div class="text-center max-w-4xl mx-auto">
      <div class="animate-float inline-flex items-center px-3 py-1 rounded-full bg-[#c0c1ff]/10 border border-[#c0c1ff]/20 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-[#c0c1ff] mr-2"></span>
        <span class="text-xs text-[#c0c1ff] font-medium tracking-wide"><%= t('landing.hero_badge') %></span>
      </div>

      <h1 class="animate-float animate-float-1 text-5xl sm:text-6xl lg:text-7xl font-bold text-white tracking-tight leading-[1.1]" style="font-family: 'Space Grotesk', sans-serif;">
        <%= t('landing.hero_heading_1') %><br>
        <span class="bg-gradient-to-r from-[#c0c1ff] to-[#a78bfa] bg-clip-text text-transparent"><%= t('landing.hero_heading_2') %></span>
      </h1>

      <p class="animate-float animate-float-2 mt-6 text-lg sm:text-xl text-[#958e9e] max-w-2xl mx-auto leading-relaxed">
        <%= t('landing.hero_subtitle_html', price: format_price(1.50) + price_period).html_safe %>
      </p>

      <div class="animate-float animate-float-3 mt-10 flex flex-col sm:flex-row justify-center gap-4">
        <%= link_to new_user_session_path, class: "inline-flex items-center justify-center px-8 py-3.5 text-sm font-semibold rounded-lg hover:opacity-90 transition shadow-lg shadow-[#c0c1ff]/20 text-[#282a64]", style: "background: linear-gradient(135deg, #c0c1ff 0%, #5625ab 100%);" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          <%= t('landing.start_building') %>
        <% end %>
        <%= link_to dashboard_templates_path, class: "inline-flex items-center justify-center px-8 py-3.5 border border-[#c0c1ff]/30 text-[#c0c1ff] text-sm font-semibold rounded-lg hover:bg-[#c0c1ff]/10 transition" do %>
          <%= t('landing.view_all_templates') %>
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        <% end %>
      </div>

      <p class="animate-float animate-float-4 mt-6 text-xs text-[#4a4453]"><%= t('landing.free_tier') %> &middot; <%= t('landing.deploy_in_5_min') %></p>
    </div>

    <!-- Terminal Preview -->
    <div class="animate-float animate-float-4 mt-16 max-w-2xl mx-auto relative" data-controller="dino-game">
      <div class="terminal-dino-wrap"><span class="terminal-dino" data-dino-game-target="dino" data-action="click->dino-game#revive" title="rawr!">🦕</span></div>
      <div class="rounded-xl border border-[#28283d]/30 bg-[#0D1424]/80 backdrop-blur-sm overflow-hidden shadow-2xl shadow-black/40">
        <div class="flex items-center px-4 py-2.5 border-b border-[#28283d]/30 bg-[#111125]/80">
          <div class="flex space-x-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-[#334155]"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-[#334155]"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-[#334155]"></div>
          </div>
          <span class="ml-3 text-[10px] text-[#4a4453] font-mono">terminal</span>
        </div>
        <div class="p-5 font-mono text-sm space-y-1">
          <div class="terminal-line"><span class="text-[#958e9e]">$</span> <span class="text-gray-300">wokku apps:create my-app</span></div>
          <div class="terminal-line terminal-line-2"><span class="text-[#c0c1ff]">Creating my-app... done</span></div>
          <div class="terminal-line terminal-line-3 mt-1"><span class="text-[#958e9e]">$</span> <span class="text-gray-300">git push wokku main</span></div>
          <div class="terminal-line terminal-line-4"><span class="text-[#c0c1ff]">Deploying...</span> <span class="text-[#958e9e]">build succeeded</span></div>
          <div class="terminal-line terminal-line-5"><span class="text-[#c0c1ff]">Live at</span> <span class="text-[#c0c1ff] underline">https://my-app.wokku.cloud</span><span class="terminal-cursor"></span></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Why Wokku — Comparison -->
<div class="border-t border-[#28283d]/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white" style="font-family: 'Space Grotesk', sans-serif;"><%= t('landing.why_wokku') %></h2>
      <p class="mt-3 text-[#958e9e] text-lg"><%= t('landing.why_wokku_subtitle') %></p>
    </div>

    <div class="max-w-3xl mx-auto">
      <div class="bg-[#1e1e32] rounded-2xl overflow-hidden">
        <div class="p-8">
          <p class="text-sm text-[#958e9e] font-mono mb-6">PostgreSQL + Redis + Your App</p>

          <div class="space-y-4">
            <!-- Heroku -->
            <div class="flex items-center justify-between p-4 rounded-xl bg-[#111125] border border-[#28283d]/50">
              <div class="flex items-center space-x-3">
                <div class="w-8 h-8 rounded-lg bg-[#6762A6]/20 flex items-center justify-center">
                  <span class="text-xs font-bold text-[#958e9e]">H</span>
                </div>
                <div>
                  <span class="text-sm font-medium text-[#958e9e]">Heroku</span>
                  <p class="text-xs text-[#4a4453]"><%= t('landing.heroku_stack_desc') %></p>
                </div>
              </div>
              <span class="text-lg font-mono font-bold text-[#958e9e] comparison-strike">$32/mo</span>
            </div>

            <!-- Wokku -->
            <div class="flex items-center justify-between p-4 rounded-xl bg-[#c0c1ff]/5 border border-[#c0c1ff]/20">
              <div class="flex items-center space-x-3">
                <div class="w-8 h-8 rounded-lg bg-[#c0c1ff]/20 flex items-center justify-center">
                  <span class="text-xs font-bold text-[#c0c1ff]">W</span>
                </div>
                <div>
                  <span class="text-sm font-medium text-white">Wokku</span>
                  <p class="text-xs text-[#958e9e]"><%= t('landing.wokku_stack_desc') %></p>
                </div>
              </div>
              <span class="text-lg font-mono font-bold text-[#c0c1ff]"><%= format_price(1.50) %><%= price_period %></span>
            </div>
          </div>

          <div class="mt-6 text-center">
            <span class="inline-flex items-center px-4 py-2 rounded-full bg-[#c0c1ff]/10 border border-[#c0c1ff]/20">
              <span class="text-sm font-semibold text-[#c0c1ff]"><%= t('landing.save_infrastructure') %></span>
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

