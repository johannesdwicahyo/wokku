    <div class="text-center mt-10">
      <%= link_to dashboard_templates_path, class: "inline-flex items-center px-6 py-3 border border-[#c0c1ff]/30 text-[#c0c1ff] text-sm font-medium rounded-lg hover:bg-[#c0c1ff]/10 transition" do %>
        <%= t('landing.view_all_templates') %>
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      <% end %>
    </div>
  </div>
</div>

<!-- Developer Experience — 4 Ways to Interact -->
<div class="border-t border-[#28283d]/30 bg-[#0D1424]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="text-center mb-16">
