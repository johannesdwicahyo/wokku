        <span class="text-[10px] text-[#c0c1ff] font-mono font-medium tracking-wider uppercase"><%= t('landing.for_developers') %></span>
      </div>
      <h2 class="text-3xl sm:text-4xl font-bold text-white" style="font-family: 'Space Grotesk', sans-serif;"><%= t('landing.four_ways_heading') %></h2>
      <p class="mt-3 text-[#958e9e] text-lg"><%= t('landing.four_ways_subtitle') %></p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Web Dashboard -->
      <div class="bg-[#1e1e32] rounded-xl p-6">
        <div class="flex items-center space-x-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-[#c0c1ff]/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-[#c0c1ff]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"/></svg>
          </div>
          <h3 class="text-base font-semibold text-white"><%= t('landing.deploy_web_title') %></h3>
        </div>
        <p class="text-sm text-[#958e9e] leading-relaxed mb-4"><%= t('landing.deploy_web_desc') %></p>
        <div class="rounded-lg bg-[#111125] border border-[#28283d]/50 p-4">
          <div class="flex items-center space-x-2 text-xs text-[#958e9e]">
            <span class="w-2 h-2 rounded-full bg-[#c0c1ff]"></span>
            <span>my-app</span>
            <span class="text-[#4a4453]">&middot;</span>
            <span class="text-[#c0c1ff]">Running</span>
            <span class="text-[#4a4453]">&middot;</span>
            <span>512 MB</span>
            <span class="text-[#4a4453]">&middot;</span>
            <span>my-app.wokku.cloud</span>
          </div>
        </div>
      </div>

      <!-- CLI -->
      <div class="bg-[#1e1e32] rounded-xl p-6">
        <div class="flex items-center space-x-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-[#c0c1ff]/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-[#c0c1ff]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"/></svg>
          </div>
          <h3 class="text-base font-semibold text-white"><%= t('landing.deploy_cli_title') %></h3>
        </div>
        <p class="text-sm text-[#958e9e] leading-relaxed mb-4"><%= t('landing.deploy_cli_desc_html').html_safe %></p>
        <div class="rounded-lg bg-[#111125] border border-[#28283d]/50 p-4 font-mono text-xs text-[#958e9e]">
          <div><span class="text-[#4a4453]">$</span> wokku apps:create my-app --server prod</div>
          <div class="text-[#c0c1ff]">Creating my-app on prod... done</div>
        </div>
      </div>

      <!-- API -->
      <div class="bg-[#1e1e32] rounded-xl p-6">
        <div class="flex items-center space-x-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-[#c0c1ff]/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-[#c0c1ff]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z"/></svg>
          </div>
          <h3 class="text-base font-semibold text-white"><%= t('landing.deploy_api_title') %></h3>
        </div>
        <p class="text-sm text-[#958e9e] leading-relaxed mb-4"><%= t('landing.deploy_api_desc') %></p>
        <div class="rounded-lg bg-[#111125] border border-[#28283d]/50 p-4 font-mono text-xs text-[#958e9e] overflow-x-auto">
          <div>curl -X POST https://wokku.cloud/api/v1/apps \</div>
          <div class="pl-4">-H "Authorization: Bearer $TOKEN" \</div>
          <div class="pl-4">-d '{"name": "my-app"}'</div>
        </div>
      </div>

      <!-- MCP -->
      <div class="bg-[#1e1e32] rounded-xl p-6">
        <div class="flex items-center space-x-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-[#c0c1ff]/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-[#c0c1ff]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/></svg>
          </div>
          <h3 class="text-base font-semibold text-white"><%= t('landing.deploy_mcp_title') %></h3>
        </div>
        <p class="text-sm text-[#958e9e] leading-relaxed mb-4"><%= t('landing.deploy_mcp_desc') %></p>
        <div class="rounded-lg bg-[#111125] border border-[#28283d]/50 p-4 text-xs text-[#958e9e]">
          <div class="flex items-start space-x-2">
            <span class="text-[#c0c1ff]"><%= t('landing.deploy_mcp_user') %></span>
            <span><%= t('landing.deploy_mcp_prompt') %></span>
          </div>
          <div class="flex items-start space-x-2 mt-1">
            <span class="text-[#c0c1ff]"><%= t('landing.deploy_mcp_ai') %></span>
            <span><%= t('landing.deploy_mcp_response') %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Pricing -->
<div class="border-t border-[#28283d]/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white" style="font-family: 'Space Grotesk', sans-serif;"><%= t('landing.pricing_heading') %></h2>
      <p class="mt-3 text-[#958e9e] text-lg"><%= t('landing.pricing_subtitle') %></p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 max-w-6xl mx-auto">
      <%
        tiers = [
          { name: "Free",           usd: 0,    ram: "256 MB", vcpu: "0.15", storage: "1 GB",  badge: t('landing.tier_free_badge'),    badge_color: "bg-[#c0c1ff]/10 text-[#c0c1ff]", highlight: false },
          { name: "Basic",          usd: 1.50, ram: "512 MB", vcpu: "0.3",  storage: "5 GB",  badge: nil, badge_color: nil, highlight: false },
          { name: "Standard",       usd: 4,    ram: "1 GB",   vcpu: "0.5",  storage: "10 GB", badge: nil, badge_color: nil, highlight: false },
          { name: "Performance",    usd: 8,    ram: "2 GB",   vcpu: "1.0",  storage: "25 GB", badge: t('landing.tier_popular_badge'), badge_color: "bg-[#c0c1ff]/20 text-[#c0c1ff]", highlight: true },
          { name: "Performance 2x", usd: 15,   ram: "4 GB",   vcpu: "2.0",  storage: "50 GB", badge: nil, badge_color: nil, highlight: false }
        ]
      %>
      <% tiers.each do |tier| %>
        <div class="pricing-card rounded-xl p-6 <%= tier[:highlight] ? 'bg-[#c0c1ff]/5 border-2 border-[#c0c1ff]/30 ring-1 ring-[#c0c1ff]/10' : 'bg-[#1e1e32] border border-[#28283d]/50' %>">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-sm font-semibold text-white uppercase tracking-wider"><%= tier[:name] %></h3>
            <% if tier[:badge] %>
              <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full <%= tier[:badge_color] %>"><%= tier[:badge] %></span>
            <% end %>
          </div>

          <div class="mb-6">
            <span class="text-xl font-bold text-white font-mono"><%= format_price(tier[:usd]) %></span>
            <span class="text-xs text-[#958e9e]"><%= price_period %></span>
          </div>

          <ul class="space-y-2 mb-6 text-sm text-[#958e9e]">
            <li class="flex items-center">
              <svg class="w-3.5 h-3.5 text-[#c0c1ff] mr-2 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <%= tier[:ram] %> RAM
            </li>
            <li class="flex items-center">
              <svg class="w-3.5 h-3.5 text-[#c0c1ff] mr-2 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <%= vcpu_display(tier[:vcpu]) %> vCPU
            </li>
            <li class="flex items-center">
              <svg class="w-3.5 h-3.5 text-[#c0c1ff] mr-2 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <%= tier[:storage] %> disk
            </li>
            <% if tier[:usd] == 0 %>
              <li class="flex items-center text-[#4a4453]">
                <svg class="w-3.5 h-3.5 text-[#4a4453] mr-2 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <%= t('pricing.sleeps_idle') %>
              </li>
            <% end %>
          </ul>

          <%= link_to new_user_session_path, class: "block w-full text-center py-2.5 text-sm font-medium rounded-lg transition #{tier[:highlight] ? 'text-[#282a64] hover:opacity-90' : 'text-[#c0c1ff] border border-[#c0c1ff]/30 hover:bg-[#c0c1ff]/10'}", style: tier[:highlight] ? "background: linear-gradient(135deg, #c0c1ff 0%, #5625ab 100%);" : "" do %>
            <%= t('landing.pricing_get_started') %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="text-center mt-8">
      <p class="text-sm text-[#958e9e]"><%= t('landing.pricing_all_tiers_note') %> <span class="text-[#4a4453]"><%= t('landing.pricing_db_note') %></span></p>
      <%= link_to pricing_path, class: "inline-flex items-center text-sm text-[#c0c1ff] hover:text-white transition font-medium mt-2" do %>
        <%= t('landing.compare_pricing') %>
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      <% end %>
    </div>
  </div>
</div>

<!-- Open Source -->
<div class="border-t border-[#28283d]/30 bg-[#0D1424]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center px-3 py-1 rounded-full bg-[#1e1e32] border border-[#28283d]/50 mb-6">
        <svg class="w-3.5 h-3.5 text-[#958e9e] mr-1.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <span class="text-xs text-[#958e9e] font-medium"><%= t('landing.open_source_github') %></span>
      </div>

      <h2 class="text-3xl sm:text-4xl font-bold text-white" style="font-family: 'Space Grotesk', sans-serif;"><%= t('landing.open_source') %><br><%= t('landing.run_anywhere') %></h2>
      <p class="mt-4 text-[#958e9e] leading-relaxed text-lg">
        <%= t('landing.open_source_desc') %>
      </p>

      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4">
        <a href="https://github.com/johannesdwicahyo/wokku" target="_blank" rel="noopener" class="inline-flex items-center justify-center px-6 py-3 bg-[#1e1e32] border border-[#28283d]/50 text-white text-sm font-medium rounded-lg hover:bg-[#28283d] transition">
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <%= t('landing.star_on_github') %>
        </a>
        <%= link_to docs_path, class: "inline-flex items-center justify-center px-6 py-3 text-sm text-[#958e9e] font-medium hover:text-white transition" do %>
          <%= t('landing.read_the_docs') %>
          <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Final CTA -->
<div class="border-t border-[#28283d]/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white" style="font-family: 'Space Grotesk', sans-serif;"><%= t('landing.ready_to_deploy') %></h2>
      <p class="mt-3 text-[#958e9e] text-lg"><%= t('landing.start_free') %></p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4">
        <%= link_to new_user_session_path, class: "inline-flex items-center justify-center px-8 py-3.5 text-sm font-semibold rounded-lg hover:opacity-90 transition shadow-lg shadow-[#c0c1ff]/20 text-[#282a64]", style: "background: linear-gradient(135deg, #c0c1ff 0%, #5625ab 100%);" do %>
          <%= t('landing.start_building') %>
        <% end %>
        <%= link_to dashboard_templates_path, class: "inline-flex items-center justify-center px-8 py-3.5 border border-[#c0c1ff]/30 text-[#c0c1ff] text-sm font-semibold rounded-lg hover:bg-[#c0c1ff]/10 transition" do %>
          <%= t('landing.view_all_templates') %>
        <% end %>
      </div>
    </div>
  </div>
</div>

