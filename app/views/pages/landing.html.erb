      <p class="mt-3 text-[#958e9e] text-lg"><%= t('landing.popular_apps_desc') %></p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <%
        templates = [
          { name: "n8n",          emoji: "🔄", desc: t('landing.template_n8n_desc'),       category: t('landing.template_automation') },
          { name: "Uptime Kuma",  emoji: "📈", desc: t('landing.template_uptime_desc'),    category: t('landing.template_monitoring') },
          { name: "Ghost",        emoji: "📝", desc: t('landing.template_ghost_desc'),     category: t('landing.template_cms') },
