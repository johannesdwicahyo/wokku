            <span class="text-[10px] font-mono text-[#958e9e] bg-[#111125] px-2 py-0.5 rounded"><%= template[:category] %></span>
          </div>
          <h3 class="text-base font-semibold text-white mb-2"><%= template[:name] %></h3>
          <p class="text-sm text-[#958e9e] leading-relaxed mb-4"><%= template[:desc] %></p>
          <%= link_to dashboard_templates_path, class: "inline-flex items-center text-xs font-medium text-[#c0c1ff] hover:text-white transition" do %>
            <%= t('landing.start_building') %>
