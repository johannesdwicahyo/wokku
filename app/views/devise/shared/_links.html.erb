<div class="mt-6 space-y-3 text-center text-sm">
  <%- if controller_name != 'sessions' %>
    <div>
      <%= link_to t("auth.have_account") + " " + t("auth.sign_in"), new_session_path(resource_name), class: "text-[#c0c1ff] hover:text-[#c0c1ff]" %>
    </div>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <div>
      <%= link_to t("auth.no_account") + " " + t("auth.sign_up"), new_registration_path(resource_name), class: "text-[#c0c1ff] hover:text-[#c0c1ff]" %>
    </div>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <div>
      <%= link_to t("auth.forgot_password"), new_password_path(resource_name), class: "text-[#c0c1ff] hover:text-[#c0c1ff]" %>
    </div>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <div>
      <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "text-[#c0c1ff] hover:text-[#c0c1ff]" %>
    </div>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <div>
      <%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "text-[#c0c1ff] hover:text-[#c0c1ff]" %>
    </div>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <div>
        <%= button_to t("auth.sign_in_with", provider: OmniAuth::Utils.camelize(provider)), omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "text-[#c0c1ff] hover:text-[#c0c1ff]" %>
      </div>
    <% end %>
  <% end %>
</div>
