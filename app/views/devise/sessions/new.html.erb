<div class="min-h-screen flex items-center justify-center px-4">
  <div class="max-w-sm w-full">
    <div class="text-center mb-8">
      <h1 class="text-xl font-semibold text-[#e2e0fc]" style="font-family: 'Space Grotesk', sans-serif;">Sign in to Wokku.dev</h1>
      <p class="mt-1 text-sm text-[#958e9e]">Deploy, manage, and scale your apps</p>
    </div>

    <div class="bg-[#1e1e32]/60 rounded-lg border border-[#4a4453]/30 p-6">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-xs font-medium text-[#958e9e] mb-1.5 uppercase tracking-wider" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "w-full rounded-md bg-[#111125] border border-[#4a4453]/30 px-3 py-2 text-sm text-[#e2e0fc] placeholder-[#4a4453] focus:outline-none focus:ring-1 focus:ring-[#c0c1ff] focus:border-[#c0c1ff] font-mono" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-xs font-medium text-[#958e9e] mb-1.5 uppercase tracking-wider" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-md bg-[#111125] border border-[#4a4453]/30 px-3 py-2 text-sm text-[#e2e0fc] placeholder-[#4a4453] focus:outline-none focus:ring-1 focus:ring-[#c0c1ff] focus:border-[#c0c1ff]" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center justify-between">
            <label class="flex items-center cursor-pointer">
              <%= f.check_box :remember_me, class: "h-3.5 w-3.5 rounded border-[#4a4453]/30 bg-[#111125] text-[#c0c1ff] focus:ring-[#c0c1ff] cursor-pointer" %>
              <span class="ml-2 text-xs text-[#958e9e]">Remember me</span>
            </label>
            <% if devise_mapping.recoverable? %>
              <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-xs text-[#958e9e] hover:text-[#c0c1ff] transition cursor-pointer" %>
            <% end %>
          </div>
        <% end %>

        <div>
          <%= f.submit "Sign in", class: "w-full py-2 px-4 text-[#282a64] text-sm font-semibold rounded-md hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-[#c0c1ff] focus:ring-offset-2 focus:ring-offset-[#111125] cursor-pointer transition", style: "background: linear-gradient(135deg, #c0c1ff 0%, #5625ab 100%);" %>
        </div>
      <% end %>

      <% if flash[:alert] %>
        <div class="mt-3 rounded-md bg-red-500/10 border border-red-500/20 p-2.5">
          <p class="text-xs text-red-400"><%= flash[:alert] %></p>
        </div>
      <% end %>

      <% if flash[:notice] %>
        <div class="mt-3 rounded-md bg-[#c0c1ff]/10 border border-[#c0c1ff]/20 p-2.5">
          <p class="text-xs text-[#c0c1ff]"><%= flash[:notice] %></p>
        </div>
      <% end %>

      <%= render "devise/shared/oauth_buttons" %>
    </div>

    <p class="mt-6 text-center text-xs text-[#4a4453]">
      Don't have an account?
      <%= link_to "Sign up", new_registration_path(resource_name), class: "text-[#c0c1ff] hover:text-[#c0c1ff] font-medium ml-1 cursor-pointer transition" %>
    </p>
  </div>
</div>
