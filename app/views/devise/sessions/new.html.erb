<div class="min-h-screen flex items-center justify-center px-4">
  <div class="max-w-sm w-full">
    <div class="text-center mb-8">
      <h1 class="text-xl font-semibold text-[#e2e0fc]" style="font-family: 'Space Grotesk', sans-serif;">Sign in to Wokku</h1>
      <p class="mt-1 text-sm text-[#958e9e]">Deploy, manage, and scale your apps</p>
    </div>

    <div class="bg-[#1e1e32]/60 rounded-lg border border-[#4a4453]/30 p-6">
      <% if flash[:alert] %>
        <div class="mb-4 rounded-md bg-red-500/10 border border-red-500/20 p-2.5">
          <p class="text-xs text-red-400"><%= flash[:alert] %></p>
        </div>
      <% end %>

      <% if flash[:notice] %>
        <div class="mb-4 rounded-md bg-[#c0c1ff]/10 border border-[#c0c1ff]/20 p-2.5">
          <p class="text-xs text-[#c0c1ff]"><%= flash[:notice] %></p>
        </div>
      <% end %>

      <div class="space-y-3">
        <%= button_to user_google_oauth2_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "w-full flex items-center justify-center px-4 py-3 bg-[#1e1e32] border border-[#4a4453]/30 rounded-lg hover:bg-[#333348] transition cursor-pointer" do %>
          <svg class="w-5 h-5 mr-3" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          <span class="text-sm text-[#e2e0fc] font-medium">Continue with Google</span>
        <% end %>

        <%= button_to user_github_omniauth_authorize_path, method: :post, data: { turbo: false }, class: "w-full flex items-center justify-center px-4 py-3 bg-[#1e1e32] border border-[#4a4453]/30 rounded-lg hover:bg-[#333348] transition cursor-pointer" do %>
          <svg class="w-5 h-5 text-[#e2e0fc] mr-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span class="text-sm text-[#e2e0fc] font-medium">Continue with GitHub</span>
        <% end %>
      </div>

      <p class="mt-5 text-center text-[10px] text-[#4a4453]">
        By signing in, you agree to our
        <%= link_to "Terms", terms_path, class: "text-[#958e9e] hover:text-[#c0c1ff] transition" %> and
        <%= link_to "Privacy Policy", privacy_path, class: "text-[#958e9e] hover:text-[#c0c1ff] transition" %>.
      </p>
    </div>
  </div>
</div>
