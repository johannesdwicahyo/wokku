<div class="min-h-screen flex items-center justify-center px-4">
  <div class="max-w-sm w-full">
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-10 h-10 bg-green-500 rounded-lg mb-4">
        <svg class="w-5 h-5 text-[#0B1120]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
      <h1 class="text-xl font-semibold text-white">Sign in to Wokku</h1>
      <p class="mt-1 text-sm text-gray-500">Deploy, manage, and scale your apps</p>
    </div>

    <div class="bg-[#1E293B]/60 rounded-lg border border-[#334155]/50 p-6">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "w-full rounded-md bg-[#0B1120] border border-[#334155] px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-green-500 font-mono" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-md bg-[#0B1120] border border-[#334155] px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-green-500" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center justify-between">
            <label class="flex items-center cursor-pointer">
              <%= f.check_box :remember_me, class: "h-3.5 w-3.5 rounded border-[#334155] bg-[#0B1120] text-green-500 focus:ring-green-500 cursor-pointer" %>
              <span class="ml-2 text-xs text-gray-400">Remember me</span>
            </label>
            <% if devise_mapping.recoverable? %>
              <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-xs text-gray-500 hover:text-green-400 transition cursor-pointer" %>
            <% end %>
          </div>
        <% end %>

        <div>
          <%= f.submit "Sign in", class: "w-full py-2 px-4 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 focus:ring-offset-[#0B1120] cursor-pointer transition" %>
        </div>
      <% end %>

      <% if flash[:alert] %>
        <div class="mt-3 rounded-md bg-red-500/10 border border-red-500/20 p-2.5">
          <p class="text-xs text-red-400"><%= flash[:alert] %></p>
        </div>
      <% end %>

      <% if flash[:notice] %>
        <div class="mt-3 rounded-md bg-green-500/10 border border-green-500/20 p-2.5">
          <p class="text-xs text-green-400"><%= flash[:notice] %></p>
        </div>
      <% end %>

      <%= render "devise/shared/oauth_buttons" %>
    </div>

    <p class="mt-6 text-center text-xs text-gray-600">
      Don't have an account?
      <%= link_to "Sign up", new_registration_path(resource_name), class: "text-green-400 hover:text-green-300 font-medium ml-1 cursor-pointer transition" %>
    </p>
  </div>
</div>
