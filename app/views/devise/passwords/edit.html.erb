<div class="min-h-screen flex items-center justify-center px-4">
  <div class="max-w-sm w-full">
    <div class="text-center mb-8">
      <h1 class="text-xl font-semibold text-white">Set new password</h1>
    </div>

    <div class="bg-[#1E293B]/60 rounded-lg border border-[#334155]/50 p-6">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-4" }) do |f| %>
        <%= f.hidden_field :reset_password_token %>

        <% if resource.errors.any? %>
          <div class="rounded-md bg-red-500/10 border border-red-500/20 p-3">
            <ul class="text-xs text-red-400 space-y-1">
              <% resource.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :password, "New password", class: "block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider" %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "w-full rounded-md bg-[#0B1120] border border-[#334155] px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-green-500" %>
          <p class="mt-1 text-xs text-gray-600"><%= @minimum_password_length %> characters minimum</p>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm password", class: "block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-md bg-[#0B1120] border border-[#334155] px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-green-500" %>
        </div>

        <div>
          <%= f.submit "Change my password", class: "w-full py-2 px-4 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 cursor-pointer transition" %>
        </div>
      <% end %>
    </div>

    <p class="mt-6 text-center text-xs text-gray-600">
      <%= link_to "Back to sign in", new_session_path(resource_name), class: "text-green-400 hover:text-green-300 font-medium cursor-pointer transition" %>
    </p>
  </div>
</div>
