<div class="min-h-screen flex items-center justify-center px-4">
  <div class="max-w-sm w-full">
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-10 h-10 bg-green-500 rounded-lg mb-4">
        <svg class="w-5 h-5 text-[#0B1120]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
      <h1 class="text-xl font-semibold text-white">Create your account</h1>
      <p class="mt-1 text-sm text-gray-500">Start deploying in seconds</p>
    </div>

    <div class="bg-[#1E293B]/60 rounded-lg border border-[#334155]/50 p-6">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <% if resource.errors.any? %>
          <div class="rounded-md bg-red-500/10 border border-red-500/20 p-3">
            <ul class="text-xs text-red-400 space-y-1">
              <% resource.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= f.label :email, class: "block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "w-full rounded-md bg-[#0B1120] border border-[#334155] px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-green-500 font-mono" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider" %>
          <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-md bg-[#0B1120] border border-[#334155] px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-green-500" %>
          <p class="mt-1 text-xs text-gray-600"><%= @minimum_password_length %> characters minimum</p>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm password", class: "block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-md bg-[#0B1120] border border-[#334155] px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-green-500" %>
        </div>

        <div>
          <%= f.submit "Create account", class: "w-full py-2 px-4 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 focus:ring-offset-[#0B1120] cursor-pointer transition" %>
        </div>
      <% end %>

      <%= render "devise/shared/oauth_buttons" %>
    </div>

    <p class="mt-6 text-center text-xs text-gray-600">
      Already have an account?
      <%= link_to "Sign in", new_session_path(resource_name), class: "text-green-400 hover:text-green-300 font-medium ml-1 cursor-pointer transition" %>
    </p>
  </div>
</div>
