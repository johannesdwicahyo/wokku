<!DOCTYPE html>
<html class="dark h-full" lang="en">
  <head>
    <title><%= content_for(:title) || "Wokku" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Wokku">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/css/xterm.min.css">
    <%= javascript_importmap_tags %>

    <script>
      // Custom Turbo confirm dialog — replaces ugly browser native confirm()
      // Wait for Turbo to be available before overriding
      document.addEventListener("turbo:load", function initConfirm() {
        if (typeof Turbo === "undefined") return;
        document.removeEventListener("turbo:load", initConfirm);
        Turbo.setConfirmMethod((message, element) => {
        const dialog = document.createElement('div');
        dialog.innerHTML = `
          <div class="fixed inset-0 z-[100] flex items-center justify-center bg-black/60 backdrop-blur-sm">
            <div class="bg-surface-container-high border border-outline-variant/20 rounded-lg shadow-2xl max-w-sm w-full mx-4 p-6">
              <h3 class="text-sm font-semibold text-on-surface font-headline mb-2">Confirm</h3>
              <p class="text-sm text-on-surface-variant mb-6">${message}</p>
              <div class="flex items-center justify-end gap-3">
                <button data-action="cancel" class="px-4 py-2 text-sm text-on-surface-variant hover:text-on-surface border border-outline-variant/20 rounded-md transition cursor-pointer">Cancel</button>
                <button data-action="confirm" class="px-4 py-2 text-sm font-semibold technical-gradient text-on-primary rounded-md hover:opacity-90 transition cursor-pointer">Confirm</button>
              </div>
            </div>
          </div>
        `;
        document.body.appendChild(dialog);
        return new Promise((resolve) => {
          dialog.querySelector('[data-action="confirm"]').addEventListener('click', () => { dialog.remove(); resolve(true); });
          dialog.querySelector('[data-action="cancel"]').addEventListener('click', () => { dialog.remove(); resolve(false); });
          dialog.querySelector('.fixed').addEventListener('click', (e) => { if (e.target === e.currentTarget) { dialog.remove(); resolve(false); } });
        });
      });
      }, { once: true });
    </script>
  </head>
  <body class="h-full bg-surface text-on-surface font-body selection:bg-primary-container selection:text-primary">
    <%# Beta Banner %>
    <div class="fixed top-0 left-0 right-0 z-[60] bg-gradient-to-r from-tertiary/15 via-primary/15 to-tertiary/15 border-b border-tertiary/20">
      <div class="px-4 py-1.5">
        <div class="flex items-center justify-center gap-2 text-xs">
          <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-tertiary/20 text-tertiary rounded font-bold uppercase tracking-wider text-[10px]">
            <span class="w-1.5 h-1.5 rounded-full bg-tertiary animate-pulse"></span>
            Public Beta
          </span>
          <span class="text-on-surface-variant hidden md:inline">
            Wokku.dev is in public beta — not recommended for production workloads yet. See the <%= link_to "beta notice", "/docs/beta", class: "text-primary hover:underline" %>.
          </span>
          <span class="text-on-surface-variant md:hidden">Beta — not for production yet</span>
        </div>
      </div>
    </div>

    <div class="pt-7" data-controller="mobile-nav">
      <%= render "dashboard/shared/sidebar" %>
      <%= render "dashboard/shared/navbar" %>

      <%# Mobile overlay — appears when sidebar is open %>
      <div class="lg:hidden fixed inset-0 bg-black/50 z-20 hidden"
           data-mobile-nav-target="overlay"
           data-action="click->mobile-nav#close"></div>

      <main class="lg:ml-64 pt-16 min-h-screen">
        <div class="px-4 sm:px-6 lg:px-8 py-6 lg:py-8">
          <%= render "dashboard/shared/flash" %>
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
