<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Wokku - Deploy Anything in One Click" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Open-source cloud platform for developers and creators. Deploy popular apps in one click or push your own code. 60% cheaper than Heroku.">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Wokku">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      body { font-family: 'Inter', system-ui, sans-serif; }
      .font-mono, code, pre { font-family: 'JetBrains Mono', ui-monospace, monospace; }
      .technical-gradient { background: linear-gradient(135deg, #c0c1ff 0%, #5625ab 100%); }
    </style>
  </head>

  <body class="h-full bg-[#111125]">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 border-b border-[#28283d]/30 bg-[#111125]/80 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-14 items-center">
          <div class="flex items-center space-x-8">
            <%= link_to root_path, class: "text-base font-semibold text-white tracking-tight", style: "font-family: 'Space Grotesk', sans-serif;" do %>
              Wokku.dev
            <% end %>
            <div class="hidden sm:flex items-center space-x-6">
              <%= link_to "Templates", dashboard_templates_path, class: "text-sm text-[#958e9e] hover:text-white transition" %>
              <%= link_to "Deploy", "/deploy", class: "text-sm text-[#958e9e] hover:text-white transition" %>
              <%= link_to "Pricing", pricing_path, class: "text-sm text-[#958e9e] hover:text-white transition" %>
              <%= link_to "Docs", docs_path, class: "text-sm text-[#958e9e] hover:text-white transition" %>
              <a href="https://github.com/johannesdwicahyo/wokku" target="_blank" rel="noopener" class="text-sm text-[#958e9e] hover:text-white transition">GitHub</a>
            </div>
          </div>
          <div class="flex items-center space-x-4">
            <%= link_to "Log in", new_user_session_path, class: "text-sm text-[#958e9e] hover:text-white transition" %>
            <%= link_to "Sign up free", new_user_registration_path, class: "inline-flex items-center px-3.5 py-1.5 technical-gradient text-[#282a64] text-sm font-semibold rounded-md hover:opacity-90 transition" %>
          </div>
        </div>
      </div>
    </nav>

    <main>
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="border-t border-[#28283d]/30">
      <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div>
            <div class="mb-4">
              <span class="text-sm font-semibold text-white" style="font-family: 'Space Grotesk', sans-serif;">Wokku.dev</span>
            </div>
            <p class="text-xs text-[#4a4453] leading-relaxed">Web UI for Dokku.<br>Open-source cloud platform.</p>
          </div>

          <div>
            <h4 class="text-xs font-semibold text-[#958e9e] uppercase tracking-wider mb-3">Product</h4>
            <ul class="space-y-2">
              <li><%= link_to "Templates", dashboard_templates_path, class: "text-xs text-[#4a4453] hover:text-[#ccc3d5] transition" %></li>
              <li><%= link_to "Pricing", pricing_path, class: "text-xs text-[#4a4453] hover:text-[#ccc3d5] transition" %></li>
              <li><%= link_to "Docs", docs_path, class: "text-xs text-[#4a4453] hover:text-[#ccc3d5] transition" %></li>
              <li><%= link_to "Dashboard", dashboard_apps_path, class: "text-xs text-[#4a4453] hover:text-[#ccc3d5] transition" %></li>
            </ul>
          </div>

          <div>
            <h4 class="text-xs font-semibold text-[#958e9e] uppercase tracking-wider mb-3">Developers</h4>
            <ul class="space-y-2">
              <li><a href="https://github.com/johannesdwicahyo/wokku" target="_blank" rel="noopener" class="text-xs text-[#4a4453] hover:text-[#ccc3d5] transition">GitHub</a></li>
              <li><%= link_to "REST API", docs_path, class: "text-xs text-[#4a4453] hover:text-[#ccc3d5] transition" %></li>
              <li><span class="text-xs text-[#4a4453]">CLI: <code class="text-[#958e9e] font-mono">gem install wokku</code></span></li>
            </ul>
          </div>

          <div>
            <h4 class="text-xs font-semibold text-[#958e9e] uppercase tracking-wider mb-3">Popular Apps</h4>
            <ul class="space-y-2">
              <li><span class="text-xs text-[#4a4453]">n8n</span></li>
              <li><span class="text-xs text-[#4a4453]">Waha</span></li>
              <li><span class="text-xs text-[#4a4453]">Uptime Kuma</span></li>
              <li><span class="text-xs text-[#4a4453]">Ghost</span></li>
            </ul>
          </div>
        </div>

        <div class="mt-10 pt-6 border-t border-[#28283d]/30 flex flex-col sm:flex-row justify-between items-center gap-4">
          <p class="text-[#4a4453] text-xs">&copy; <%= Date.current.year %> Wokku. Built on Dokku. AGPL-3.0 License.</p>
          <div class="flex items-center space-x-4">
            <a href="https://github.com/johannesdwicahyo/wokku" target="_blank" rel="noopener" class="text-[#4a4453] hover:text-[#ccc3d5] transition">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
