<% content_for(:title, "Marketplace - Wokku") %>

<div class="space-y-8">
  <div class="mb-8">
    <h1 class="font-headline text-3xl font-bold text-on-surface mb-2">Marketplace</h1>
    <p class="text-sm text-outline">Deploy production-ready stacks in seconds. Each template is optimized for high-performance orchestration and auto-scaling.</p>
  </div>

  <div class="flex items-center space-x-3">
    <%= form_with url: dashboard_templates_path, method: :get, class: "flex-1", data: { turbo_frame: "_top" } do |f| %>
      <div class="relative">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-lg">search</span>
        <%= f.search_field :q, value: params[:q], placeholder: "Search templates...", class: "w-full pl-10 pr-4 py-2 rounded-md bg-surface-container-low border-none text-sm text-on-surface placeholder-outline/50 focus:ring-1 focus:ring-primary", autofocus: params[:q].present? %>
      </div>
    <% end %>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= link_to "All", dashboard_templates_path, class: "px-3 py-1 rounded-full text-xs font-medium transition #{params[:category].blank? ? 'technical-gradient text-on-primary' : 'bg-surface-container-low text-outline hover:text-on-surface'}" %>
    <% @categories.each do |cat| %>
      <%= link_to cat["name"], dashboard_templates_path(category: cat["slug"]), class: "px-3 py-1 rounded-full text-xs font-medium transition #{params[:category] == cat['slug'] ? 'technical-gradient text-on-primary' : 'bg-surface-container-low text-outline hover:text-on-surface'}" %>
    <% end %>
  </div>

  <% if @templates.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      <% @templates.each do |template| %>
        <%= render "dashboard/templates/card", template: template %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-surface-container-low/40 rounded-lg border border-outline-variant/15">
      <p class="text-outline">No templates found<%= " for '#{params[:q]}'" if params[:q].present? %>.</p>
    </div>
  <% end %>
</div>
