<% content_for(:title, "#{@template[:name]} - Wokku") %>

<div class="max-w-2xl mx-auto space-y-6">
  <%= link_to dashboard_templates_path, class: "inline-flex items-center text-sm text-outline hover:text-on-surface transition" do %>
    <span class="material-symbols-outlined text-base mr-1">arrow_back</span>
    Back to Marketplace
  <% end %>

  <div class="bg-surface-container-low rounded-xl border border-outline-variant/15 p-6">
    <div class="flex items-start space-x-4">
      <div class="w-14 h-14 rounded-xl bg-surface border border-outline-variant/15 flex items-center justify-center flex-shrink-0">
        <span class="text-2xl"><%= template_icon(@template[:icon]) %></span>
      </div>
      <div>
        <h1 class="font-headline text-xl font-bold text-on-surface"><%= @template[:name] %></h1>
        <p class="text-sm text-on-surface-variant mt-1"><%= @template[:description] %></p>
        <div class="mt-3 flex flex-wrap gap-1.5">
          <% (@template[:tags] || []).each do |tag| %>
            <span class="px-2 py-0.5 rounded text-xs font-medium bg-primary-container text-on-primary-container"><%= tag %></span>
          <% end %>
        </div>
      </div>
    </div>

    <% if @template[:addons]&.any? %>
      <div class="mt-4 pt-4 border-t border-outline-variant/15">
        <h3 class="text-[10px] font-bold text-outline uppercase tracking-widest mb-2">Included Add-ons</h3>
        <div class="flex flex-wrap gap-2">
          <% @template[:addons].each do |addon| %>
            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-primary/10 text-primary border border-primary/20">
              <%= addon["type"].capitalize %> (<%= addon["tier"] || "mini" %>)
            </span>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="mt-4 pt-4 border-t border-outline-variant/15">
      <a href="<%= @template[:repo] %>" target="_blank" rel="noopener" class="inline-flex items-center text-xs text-outline hover:text-on-surface transition font-mono">
        <svg class="w-3.5 h-3.5 mr-1.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <%= @template[:repo].sub("https://github.com/", "") %>
      </a>
    </div>
  </div>

  <div class="bg-surface-container-low rounded-xl border border-outline-variant/15 p-6">
    <h2 class="text-[10px] font-bold text-outline uppercase tracking-widest mb-4">Deploy this template</h2>

    <%= form_with url: dashboard_templates_path, method: :post, class: "space-y-4" do |f| %>
      <%= f.hidden_field :template_slug, value: @template[:slug] %>

      <div>
        <label class="block text-xs text-outline uppercase tracking-wider mb-1">App Name</label>
        <input type="text" name="app_name" required placeholder="my-app" class="w-full rounded-md bg-surface border border-outline-variant/15 text-on-surface font-mono text-sm focus:ring-1 focus:ring-primary focus:border-primary" pattern="[a-z][a-z0-9\-]*" title="Lowercase letters, numbers, and hyphens">
        <p class="mt-1 text-xs text-outline/60">Lowercase letters, numbers, and hyphens only</p>
      </div>

      <div>
        <label class="block text-xs text-outline uppercase tracking-wider mb-1">Server</label>
        <select name="server_id" required class="w-full rounded-md bg-surface border border-outline-variant/15 text-on-surface text-sm focus:ring-1 focus:ring-primary focus:border-primary">
          <option value="">Select a server</option>
          <% @servers.each do |server| %>
            <option value="<%= server.id %>"><%= server.name %></option>
          <% end %>
        </select>
      </div>

      <div class="pt-2">
        <button type="submit" class="w-full py-2.5 px-4 technical-gradient text-on-primary text-sm font-bold rounded-md hover:opacity-90 transition cursor-pointer text-center">
          Deploy <%= @template[:name] %>
        </button>
      </div>
    <% end %>
  </div>
</div>
