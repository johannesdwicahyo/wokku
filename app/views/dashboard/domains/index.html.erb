<%= render "dashboard/apps/tabs", app: @app %>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-base font-semibold text-gray-900">Custom Domains</h2>
    <p class="text-sm text-gray-500 mt-1">Domains pointing to <%= @app.name %></p>
  </div>

  <% if @domains.any? %>
    <div class="divide-y divide-gray-200">
      <% @domains.each do |domain| %>
        <div class="px-6 py-3 flex items-center justify-between hover:bg-gray-50">
          <div class="flex items-center space-x-3">
            <span class="text-sm font-medium text-gray-900"><%= domain.hostname %></span>
            <% if domain.ssl_enabled? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">SSL</span>
            <% end %>
          </div>
          <%= link_to "Remove", dashboard_app_domain_path(@app, domain), data: { turbo_method: :delete, turbo_confirm: "Remove #{domain.hostname}?" }, class: "text-sm text-red-600 hover:text-red-800 transition" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="px-6 py-8 text-center">
      <p class="text-sm text-gray-500">No custom domains configured.</p>
    </div>
  <% end %>
</div>

<div class="bg-white rounded-xl border border-gray-200 p-6">
  <h3 class="text-sm font-semibold text-gray-900 mb-4">Add Domain</h3>
  <%= form_with(model: Domain.new, url: dashboard_app_domains_path(@app), class: "flex items-end space-x-3") do |f| %>
    <div class="flex-1">
      <%= f.label :hostname, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :hostname, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm", placeholder: "app.example.com" %>
    </div>
    <%= f.submit "Add", class: "px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 transition shadow-sm cursor-pointer" %>
  <% end %>
</div>
