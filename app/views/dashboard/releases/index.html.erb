<%= render "dashboard/apps/tabs", app: @app %>

<%# Deployment Method %>
<div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-[#334155]/50">
    <h2 class="text-base font-semibold text-white">Deploy</h2>
    <p class="text-sm text-gray-500 mt-1">Push code to your Dokku server</p>
  </div>

  <div class="p-6 space-y-6">
    <%# Git Remote %>
    <div>
      <h3 class="text-sm font-semibold text-white mb-2 flex items-center space-x-2">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <span>Git Remote</span>
      </h3>
      <p class="text-xs text-gray-500 mb-3">Add the Dokku remote to your repository and push to deploy.</p>
      <% git_remote = "dokku@#{@app.server.host}:#{@app.name}" %>
      <div class="space-y-2">
        <div class="flex items-center space-x-2">
          <code class="flex-1 bg-[#0B1120] border border-[#334155] rounded-md px-3 py-2 text-sm text-gray-300 font-mono">git remote add dokku <%= git_remote %></code>
          <button onclick="navigator.clipboard.writeText('git remote add dokku <%= git_remote %>')" class="p-2 text-gray-500 hover:text-green-400 transition cursor-pointer" title="Copy">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
          </button>
        </div>
        <div class="flex items-center space-x-2">
          <code class="flex-1 bg-[#0B1120] border border-[#334155] rounded-md px-3 py-2 text-sm text-gray-300 font-mono">git push dokku <%= @app.deploy_branch || "main" %></code>
          <button onclick="navigator.clipboard.writeText('git push dokku <%= @app.deploy_branch || "main" %>')" class="p-2 text-gray-500 hover:text-green-400 transition cursor-pointer" title="Copy">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div class="border-t border-[#334155]/50"></div>

    <%# GitHub Integration (future) %>
    <div>
      <h3 class="text-sm font-semibold text-white mb-2 flex items-center space-x-2">
        <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <span>GitHub</span>
        <span class="px-1.5 py-0.5 text-[10px] text-gray-500 border border-[#334155] rounded">Coming Soon</span>
      </h3>
      <p class="text-xs text-gray-500">Connect a GitHub repository for automatic deploys on push.</p>
    </div>

    <div class="border-t border-[#334155]/50"></div>

    <%# Manual Deploy %>
    <div>
      <h3 class="text-sm font-semibold text-white mb-2 flex items-center space-x-2">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        <span>Manual Deploy</span>
      </h3>
      <p class="text-xs text-gray-500 mb-3">Trigger a rebuild of the current codebase on the server.</p>
      <%= button_to "Deploy Now", deploy_dashboard_app_releases_path(@app), method: :post, data: { turbo_confirm: "Rebuild and deploy #{@app.name}?" }, class: "inline-flex items-center px-3 py-1.5 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer" %>
    </div>
  </div>
</div>

<%# Release History %>
<div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 overflow-hidden">
  <div class="px-6 py-4 border-b border-[#334155]/50">
    <h2 class="text-base font-semibold text-white">Release History</h2>
    <p class="text-sm text-gray-500 mt-1">Deploy history for <span class="font-mono"><%= @app.name %></span></p>
  </div>

  <% if @releases.any? %>
    <div class="divide-y divide-[#334155]/50">
      <% @releases.each do |release| %>
        <div class="px-6 py-4 flex items-center justify-between hover:bg-[#334155]/20 transition">
          <div class="flex items-center space-x-4">
            <% if release.deploy %>
              <% case release.deploy.status %>
              <% when "succeeded" %>
                <div class="flex items-center justify-center w-8 h-8 rounded-full bg-green-500/10 border border-green-500/20">
                  <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
              <% when "failed", "timed_out" %>
                <div class="flex items-center justify-center w-8 h-8 rounded-full bg-red-500/10 border border-red-500/20">
                  <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </div>
              <% when "building" %>
                <div class="flex items-center justify-center w-8 h-8 rounded-full bg-yellow-500/10 border border-yellow-500/20">
                  <svg class="w-4 h-4 text-yellow-500 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                </div>
              <% else %>
                <div class="flex items-center justify-center w-8 h-8 rounded-full bg-gray-500/10 border border-gray-500/20">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
              <% end %>
            <% else %>
              <div class="flex items-center justify-center w-8 h-8 rounded-full bg-blue-500/10 border border-blue-500/20">
                <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
            <% end %>

            <div>
              <div class="flex items-center space-x-2">
                <span class="text-sm font-semibold text-white font-mono">v<%= release.version %></span>
                <% if release.deploy&.commit_sha.present? %>
                  <span class="text-xs text-gray-500 font-mono bg-[#0B1120] px-1.5 py-0.5 rounded"><%= release.deploy.commit_sha.first(7) %></span>
                <% end %>
                <% if release.deploy %>
                  <% case release.deploy.status %>
                  <% when "succeeded" %>
                    <span class="text-xs text-green-400">Succeeded</span>
                  <% when "failed" %>
                    <span class="text-xs text-red-400">Failed</span>
                  <% when "timed_out" %>
                    <span class="text-xs text-red-400">Timed out</span>
                  <% when "building" %>
                    <span class="text-xs text-yellow-500">Building...</span>
                  <% when "pending" %>
                    <span class="text-xs text-gray-400">Pending</span>
                  <% end %>
                <% else %>
                  <span class="text-xs text-blue-400">Config change</span>
                <% end %>
              </div>
              <div class="flex items-center space-x-3 mt-0.5">
                <span class="text-xs text-gray-500"><%= release.description || "Deploy" %></span>
                <% if release.deploy&.duration %>
                  <span class="text-xs text-gray-600">(<%= release.deploy.duration.round %>s)</span>
                <% end %>
              </div>
            </div>
          </div>

          <span class="text-xs text-gray-500"><%= time_ago_in_words(release.created_at) %> ago</span>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="px-6 py-12 text-center">
      <svg class="mx-auto h-10 w-10 text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg>
      <h3 class="text-sm font-medium text-gray-300">No releases yet</h3>
      <p class="text-xs text-gray-500 mt-1">Push code via git or trigger a manual deploy to create your first release.</p>
    </div>
  <% end %>
</div>
