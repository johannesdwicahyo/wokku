<%= render "dashboard/apps/tabs", app: @app %>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-base font-semibold text-gray-900">Releases</h2>
    <p class="text-sm text-gray-500 mt-1">Deploy history for <%= @app.name %></p>
  </div>

  <% if @releases.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Version</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @releases.each do |release| %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-6 py-4 text-sm font-medium text-gray-900">v<%= release.version %></td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= release.description || "-" %></td>
            <td class="px-6 py-4">
              <% if release.deploy %>
                <% case release.deploy.status %>
                <% when "succeeded" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Succeeded</span>
                <% when "failed" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Failed</span>
                <% when "building" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Building</span>
                <% when "pending" %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Pending</span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800"><%= release.deploy.status.capitalize %></span>
                <% end %>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Config change</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= time_ago_in_words(release.created_at) %> ago</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="px-6 py-8 text-center">
      <p class="text-sm text-gray-500">No releases yet.</p>
    </div>
  <% end %>
</div>
