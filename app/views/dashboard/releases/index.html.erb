<%= render "dashboard/apps/tabs", app: @app %>

<%# Deployment Method %>
<div class="bg-surface-container-low rounded-xl overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-outline-variant/15">
    <h2 class="text-base font-semibold text-on-surface font-headline">Deploy</h2>
    <p class="text-sm text-outline mt-1">Push code to your Dokku server</p>
  </div>

  <div class="p-6 space-y-6">
    <%# Git Remote %>
    <div>
      <h3 class="text-sm font-semibold text-on-surface font-headline mb-2 flex items-center space-x-2">
        <span class="material-symbols-outlined text-on-surface-variant text-[18px]">terminal</span>
        <span>Git Remote</span>
      </h3>
      <p class="text-xs text-outline mb-3">Add the Dokku remote to your repository and push to deploy.</p>
      <% git_remote = "dokku@#{@app.server.host}:#{@app.name}" %>
      <div class="space-y-2">
        <div class="flex items-center space-x-2">
          <code class="flex-1 bg-surface border border-outline-variant/15 rounded-md px-3 py-2 text-sm text-on-surface-variant font-mono">git remote add dokku <%= git_remote %></code>
          <button type="button" data-controller="clipboard" data-clipboard-text-value="git remote add dokku <%= git_remote %>" data-action="click->clipboard#copy" class="p-2 text-outline hover:text-primary transition cursor-pointer" title="Copy">
            <span data-clipboard-target="label" class="material-symbols-outlined text-[18px]">content_copy</span>
          </button>
        </div>
        <div class="flex items-center space-x-2">
          <code class="flex-1 bg-surface border border-outline-variant/15 rounded-md px-3 py-2 text-sm text-on-surface-variant font-mono">git push dokku <%= @app.deploy_branch || "main" %></code>
          <button type="button" data-controller="clipboard" data-clipboard-text-value="git push dokku <%= @app.deploy_branch || "main" %>" data-action="click->clipboard#copy" class="p-2 text-outline hover:text-primary transition cursor-pointer" title="Copy">
            <span data-clipboard-target="label" class="material-symbols-outlined text-[18px]">content_copy</span>
          </button>
        </div>
      </div>
    </div>

    <div class="border-t border-outline-variant/15"></div>

    <%# GitHub Integration %>
    <div class="bg-surface-container-high/50 rounded-lg border border-outline-variant/15 p-4">
      <div class="flex items-center space-x-2 mb-2">
        <svg class="w-4 h-4 text-on-surface-variant" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <h3 class="text-[10px] font-bold text-on-surface-variant uppercase tracking-wider">GitHub</h3>
      </div>
      <% if @app.github_repo_full_name.present? %>
        <div class="flex items-center justify-between">
          <div>
            <span class="text-sm text-on-surface font-mono"><%= @app.github_repo_full_name %></span>
            <span class="text-xs text-outline ml-1">(<%= @app.deploy_branch %>)</span>
          </div>
          <%= button_to "Disconnect", dashboard_app_github_disconnect_path(@app), method: :delete, class: "text-xs text-error hover:text-error/80 transition", data: { turbo_confirm: "Disconnect GitHub?" } %>
        </div>
        <p class="text-xs text-outline mt-1">Auto-deploys on push to <span class="font-mono"><%= @app.deploy_branch %></span></p>
      <% else %>
        <p class="text-xs text-outline mb-3">Connect a GitHub repository for automatic deploys on push.</p>
        <% if GithubApp.configured? %>
          <% if current_user.github_installation_id %>
            <%= link_to dashboard_app_github_repos_path(@app), class: "inline-flex items-center px-3 py-1.5 bg-surface border border-outline-variant/15 text-on-surface-variant text-xs font-medium rounded-md hover:bg-surface-container-high hover:text-on-surface transition" do %>
              Connect Repository
            <% end %>
          <% else %>
            <a href="<%= GithubApp.installation_url %>" class="inline-flex items-center px-3 py-1.5 bg-surface border border-outline-variant/15 text-on-surface-variant text-xs font-medium rounded-md hover:bg-surface-container-high hover:text-on-surface transition">
              Install GitHub App
            </a>
          <% end %>
        <% else %>
          <span class="text-xs text-outline-variant">GitHub App not configured. Set GITHUB_APP_ID and GITHUB_APP_PRIVATE_KEY env vars.</span>
        <% end %>
      <% end %>
    </div>

    <div class="border-t border-outline-variant/15"></div>

    <%# Manual Deploy %>
    <div>
      <h3 class="text-sm font-semibold text-on-surface font-headline mb-2 flex items-center space-x-2">
        <span class="material-symbols-outlined text-on-surface-variant text-[18px]">refresh</span>
        <span>Manual Deploy</span>
      </h3>
      <p class="text-xs text-outline mb-3">Trigger a rebuild of the current codebase on the server.</p>
      <%= button_to "Deploy Now", deploy_dashboard_app_releases_path(@app), method: :post, data: { turbo_confirm: "Rebuild and deploy #{@app.name}?" }, class: "inline-flex items-center px-3 py-1.5 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer" %>
    </div>
  </div>
</div>

<%# Release History %>
<div class="bg-surface-container-low rounded-xl overflow-hidden">
  <div class="px-6 py-4 border-b border-outline-variant/15">
    <h2 class="text-base font-semibold text-on-surface font-headline">Release History</h2>
    <p class="text-sm text-outline mt-1">Deploy history for <span class="font-mono"><%= @app.name %></span></p>
  </div>

  <% if @releases.any? %>
    <div class="divide-y divide-outline-variant/15">
      <% @releases.each do |release| %>
        <div class="px-6 py-4 flex items-center justify-between hover:bg-surface-container-high/30 transition">
          <div class="flex items-center space-x-4">
            <% if release.deploy %>
              <% case release.deploy.status %>
              <% when "succeeded" %>
                <div class="flex items-center justify-center w-8 h-8 rounded-full bg-secondary-container/20 border border-primary/20">
                  <span class="material-symbols-outlined text-primary text-[18px]">check_circle</span>
                </div>
              <% when "failed", "timed_out" %>
                <div class="flex items-center justify-center w-8 h-8 rounded-full bg-error-container/20 border border-error/20">
                  <span class="material-symbols-outlined text-error text-[18px]">cancel</span>
                </div>
              <% when "building" %>
                <div class="flex items-center justify-center w-8 h-8 rounded-full bg-tertiary-container/20 border border-tertiary/20">
                  <span class="material-symbols-outlined text-tertiary text-[18px] animate-spin">progress_activity</span>
                </div>
              <% else %>
                <div class="flex items-center justify-center w-8 h-8 rounded-full bg-surface-container-high border border-outline-variant/15">
                  <span class="material-symbols-outlined text-outline text-[18px]">schedule</span>
                </div>
              <% end %>
            <% else %>
              <div class="flex items-center justify-center w-8 h-8 rounded-full bg-secondary-container/20 border border-secondary/20">
                <span class="material-symbols-outlined text-secondary text-[18px]">settings</span>
              </div>
            <% end %>

            <div>
              <div class="flex items-center space-x-2">
                <span class="text-sm font-semibold text-on-surface font-mono">v<%= release.version %></span>
                <% if release.deploy&.commit_sha.present? %>
                  <span class="text-xs text-outline font-mono bg-surface px-1.5 py-0.5 rounded"><%= release.deploy.commit_sha.first(7) %></span>
                <% end %>
                <% if release.deploy %>
                  <% case release.deploy.status %>
                  <% when "succeeded" %>
                    <span class="text-xs text-primary">Succeeded</span>
                  <% when "failed" %>
                    <span class="text-xs text-error">Failed</span>
                  <% when "timed_out" %>
                    <span class="text-xs text-error">Timed out</span>
                  <% when "building" %>
                    <span class="text-xs text-tertiary">Building...</span>
                  <% when "pending" %>
                    <span class="text-xs text-on-surface-variant">Pending</span>
                  <% end %>
                <% else %>
                  <span class="text-xs text-secondary">Config change</span>
                <% end %>
              </div>
              <div class="flex items-center space-x-3 mt-0.5">
                <span class="text-xs text-outline"><%= release.description || "Deploy" %></span>
                <% if release.deploy&.duration %>
                  <span class="text-xs text-outline-variant">(<%= release.deploy.duration.round %>s)</span>
                <% end %>
              </div>
            </div>
          </div>

          <span class="text-xs text-outline"><%= time_ago_in_words(release.created_at) %> ago</span>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="px-6 py-12 text-center">
      <span class="material-symbols-outlined text-outline-variant text-[40px] mb-3">swap_vert</span>
      <h3 class="text-sm font-medium text-on-surface-variant">No releases yet</h3>
      <p class="text-xs text-outline mt-1">Push code via git or trigger a manual deploy to create your first release.</p>
    </div>
  <% end %>
</div>
