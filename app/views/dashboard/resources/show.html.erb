<%= render "dashboard/apps/tabs", app: @app %>
<%# Adding/removing an add-on involves SSH work and invalidates most of
    the panel state; Turbo's preview cache can show a pre-submit snapshot
    after the redirect completes. Disable the preview for this page. %>
<% content_for(:head) do %>
  <meta name="turbo-cache-control" content="no-preview">
<% end %>

<div data-controller="slide-panel">

  <%# Container / Dyno overview + inline tier picker (Heroku-style — was
      its own /scaling page; merged here so the user sees compute, add-ons,
      and total cost without navigating away). %>
  <%
    web_allocation = @app.dyno_allocations.includes(:dyno_tier).find_by(process_type: "web")
    tier = web_allocation&.dyno_tier
    total_dynos = @app.dyno_allocations.sum(:count)
  %>
  <div class="bg-surface-container-low rounded-md overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-outline-variant/15">
      <h2 class="text-base font-semibold text-on-surface font-headline">Container</h2>
      <p class="text-sm text-outline mt-1">Compute + memory allocated to <span class="font-mono"><%= @app.name %></span></p>
    </div>
    <% if tier %>
      <div class="px-6 py-4 grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div>
          <p class="text-[10px] text-outline uppercase tracking-wider font-bold mb-1">Tier</p>
          <p class="text-sm font-bold text-on-surface capitalize"><%= tier.name %></p>
        </div>
        <div>
          <p class="text-[10px] text-outline uppercase tracking-wider font-bold mb-1">Memory</p>
          <p class="text-sm font-mono text-on-surface-variant"><%= tier.memory_mb >= 1024 ? "#{tier.memory_mb / 1024} GB" : "#{tier.memory_mb} MB" %></p>
        </div>
        <div>
          <p class="text-[10px] text-outline uppercase tracking-wider font-bold mb-1">CPU</p>
          <p class="text-sm font-mono text-on-surface-variant"><%= tier.vcpu_label %></p>
        </div>
        <div>
          <p class="text-[10px] text-outline uppercase tracking-wider font-bold mb-1">Estimated / month</p>
          <% if tier.free? %>
            <p class="text-sm font-bold text-on-surface">Free</p>
          <% else %>
            <p class="text-sm font-bold text-primary font-mono"><%= format_usd_for_user(total_dynos * tier.monthly_price_dollars) %></p>
          <% end %>
        </div>
      </div>
      <% if total_dynos > 1 || @app.dyno_allocations.count > 1 %>
        <div class="px-6 py-3 border-t border-outline-variant/10 flex flex-wrap items-center gap-2 text-xs text-outline">
          <span>Dynos:</span>
          <% @app.dyno_allocations.each do |alloc| %>
            <span class="font-mono bg-surface-container-highest px-2 py-0.5 rounded"><%= alloc.process_type %> × <%= alloc.count %></span>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="px-6 py-6 text-center">
        <p class="text-xs text-outline">No container tier assigned yet — deploy the app once to pick the free tier automatically.</p>
      </div>
    <% end %>

    <%# Inline tier picker (was the /scaling page) %>
    <% if @dyno_tiers.any? %>
      <div class="px-6 py-4 border-t border-outline-variant/10">
        <p class="text-xs text-outline mb-3">Change tier</p>
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-3">
          <% @dyno_tiers.each do |dt| %>
            <% is_current = @current_allocation&.dyno_tier_id == dt.id %>
            <div class="rounded-md p-3 transition <%= is_current ? 'bg-primary/5 ring-1 ring-primary/40' : 'bg-surface-container hover:bg-surface-container-high' %>">
              <div class="flex items-baseline justify-between mb-1">
                <h3 class="text-sm font-semibold text-on-surface capitalize"><%= dt.name %></h3>
                <% if is_current %>
                  <span class="text-[10px] font-bold uppercase text-primary">Current</span>
                <% end %>
              </div>
              <p class="text-xs text-on-surface-variant mb-2">
                <%= dt.free? ? "Free" : "#{format_usd_for_user(dt.monthly_price_dollars)}#{price_period(Wokku::LaunchMode.idr_only? ? 'idr' : nil)}" %>
              </p>
              <ul class="text-[11px] text-outline space-y-0.5 mb-3">
                <li><%= dt.memory_mb >= 1024 ? "#{dt.memory_mb / 1024} GB" : "#{dt.memory_mb} MB" %> RAM</li>
                <li><%= dt.vcpu_label %></li>
                <% if dt.respond_to?(:storage_mb) && dt.storage_mb > 0 %>
                  <li><%= dt.storage_mb >= 1024 ? "#{dt.storage_mb / 1024} GB" : "#{dt.storage_mb} MB" %> storage</li>
                <% end %>
              </ul>
              <% unless is_current %>
                <%= button_to((@current_allocation && dt.memory_mb > @current_allocation.dyno_tier.memory_mb) ? "Upgrade" : "Select",
                      change_tier_dashboard_app_scaling_path(@app),
                      params: { dyno_tier_id: dt.id, process_type: "web" },
                      method: :post,
                      data: { turbo_confirm: "Change to #{dt.name} (#{dt.memory_mb >= 1024 ? "#{dt.memory_mb / 1024}GB" : "#{dt.memory_mb}MB"}, #{dt.vcpu_label})?" },
                      class: "w-full text-center px-2 py-1 text-[11px] font-semibold rounded-md #{(@current_allocation && dt.memory_mb > @current_allocation.dyno_tier.memory_mb) ? 'bg-primary text-on-primary hover:opacity-90' : 'bg-surface-container-highest text-on-surface-variant hover:text-on-surface'} transition cursor-pointer border-0") %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Attached Add-ons %>
  <div class="bg-surface-container-low rounded-md overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-outline-variant/15 flex items-center justify-between">
      <div>
        <h2 class="text-base font-semibold text-on-surface font-headline">Add-ons</h2>
        <p class="text-sm text-outline mt-1">Databases, caches, and services attached to this app</p>
      </div>
      <button data-action="click->slide-panel#open" class="inline-flex items-center px-3 py-1.5 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">
        <span class="material-symbols-outlined text-[16px] mr-1.5">add</span>
        Add
      </button>
    </div>

    <% if @addons.any? %>
      <div class="divide-y divide-outline-variant/15">
        <% @addons.each do |addon| %>
          <% addon_tier = addon.service_tier %>
          <% addon_monthly = addon_tier&.monthly_price_dollars.to_f %>
          <div class="px-6 py-4 flex items-center justify-between hover:bg-surface-container-high/30 transition">
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <span class="text-sm font-semibold text-on-surface"><%= addon.name %></span>
                <span class="text-xs text-outline capitalize"><%= addon.service_type %></span>
                <% if addon.tier_name.present? %>
                  <span class="text-xs text-outline">·</span>
                  <span class="text-xs text-outline capitalize"><%= addon.tier_name.tr("_", " ") %></span>
                <% end %>
              </div>
              <% if addon.status != "running" %>
                <p class="text-xs text-outline mt-0.5 capitalize"><%= addon.status %></p>
              <% end %>
            </div>
            <div class="flex items-center gap-4">
              <div class="text-right">
                <% if addon.shared? || addon_monthly.zero? %>
                  <span class="text-xs text-outline">Free</span>
                <% else %>
                  <span class="text-sm font-semibold text-on-surface-variant"><%= format_usd_for_user(addon_monthly) %></span>
                  <span class="text-xs text-outline">/bln</span>
                <% end %>
              </div>
              <%= link_to "Info", dashboard_addon_path(addon), class: "text-xs text-on-surface-variant hover:text-primary border border-outline-variant/30 px-2 py-1 rounded transition" %>
              <%= button_to "Remove",
                    dashboard_app_resources_path(@app, addon_id: addon.id),
                    method: :delete,
                    data: { turbo_confirm: "Remove #{addon.name}? This will delete all data in this service." },
                    class: "text-xs text-outline hover:text-error transition cursor-pointer bg-transparent border-0" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center">
        <span class="material-symbols-outlined text-outline-variant text-[40px] mb-3">widgets</span>
        <h3 class="text-sm font-medium text-on-surface-variant">No add-ons yet</h3>
        <p class="text-xs text-outline mt-1">Add a database, cache, or other service to get started.</p>
        <div class="mt-4">
          <button data-action="click->slide-panel#open" class="inline-flex items-center px-3 py-1.5 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">Add an Add-on</button>
        </div>
      </div>
    <% end %>
  </div>

  <%# Estimated total — container + addons. Mirrors the right-side card on
      apps#show so users see the same number wherever they land. %>
  <%
    container_monthly_usd = tier ? total_dynos * tier.monthly_price_dollars : 0.0
    addons_monthly_usd = @addons.sum { |a| a.shared? ? 0.0 : (a.service_tier&.monthly_price_dollars.to_f) }
    total_monthly_usd = container_monthly_usd + addons_monthly_usd
  %>
  <div class="bg-surface-container-low rounded-md overflow-hidden mb-6">
    <div class="px-6 py-4">
      <p class="text-xs text-outline uppercase tracking-wider font-medium mb-3">Estimated Monthly Cost</p>
      <div class="space-y-1.5 text-sm">
        <div class="flex items-center justify-between text-on-surface-variant">
          <span>Container · <span class="text-outline"><%= tier&.name&.upcase || "—" %> × <%= total_dynos %></span></span>
          <span class="font-mono"><%= tier&.free? ? "Free" : format_usd_for_user(container_monthly_usd) %></span>
        </div>
        <% @addons.each do |a| %>
          <% am = a.shared? ? 0.0 : (a.service_tier&.monthly_price_dollars.to_f) %>
          <% atier = a.tier_name.to_s.tr("_", " ").upcase.presence || a.service_type.upcase %>
          <div class="flex items-center justify-between text-on-surface-variant">
            <span><%= a.name %> <span class="text-outline"><%= atier %></span></span>
            <span class="font-mono"><%= a.shared? || am.zero? ? "Free" : format_usd_for_user(am) %></span>
          </div>
        <% end %>
      </div>
      <div class="border-t border-outline-variant/15 mt-3 pt-3 flex items-baseline justify-between">
        <span class="text-sm font-semibold text-on-surface">Total</span>
        <span class="text-lg font-bold text-primary font-mono"><%= format_usd_for_user(total_monthly_usd) %><%= price_period(Wokku::LaunchMode.idr_only? ? "idr" : nil) %></span>
      </div>
    </div>
  </div>

  <%# Add-on Slide Panel %>
  <%= render layout: "dashboard/shared/slide_panel", locals: { title: "New Add-on", subtitle: "Provision a database or service for #{@app.name}" } do %>
    <%
      tiers_by_type = ServiceTier.available.where.not(name: "shared_free")
                                 .order(:monthly_price_cents).group_by(&:service_type)
      tier_payload = tiers_by_type.transform_values do |tiers|
        tiers.map { |t| { name: t.name, monthly_price_cents: t.monthly_price_cents, spec: t.spec } }
      end
      service_type_options = [
        ["PostgreSQL", "postgres"], ["MySQL", "mysql"], ["MongoDB", "mongodb"],
        ["Redis", "redis"], ["Memcached", "memcached"],
        ["Elasticsearch", "elasticsearch"], ["RabbitMQ", "rabbitmq"]
      ]
      label_classes = "block text-xs font-semibold text-on-surface-variant mb-1.5 uppercase tracking-wider"
      input_classes = "w-full rounded-md bg-surface-container-low border border-outline-variant/15 px-4 py-2.5 text-sm text-on-surface placeholder-outline-variant font-mono focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition"
    %>
    <%= form_with url: dashboard_addons_path, method: :post, class: "space-y-5",
                  data: { controller: "addon-tier-picker", "addon-tier-picker-tiers-value": tier_payload.to_json } do |f| %>
      <%# App is fixed on this page — submit it as hidden so the form
          posts to the canonical DatabasesController#create path. %>
      <%= hidden_field_tag "database_service[app_id]", @app.id %>

      <div>
        <label class="<%= label_classes %>">Attached to</label>
        <div class="rounded-md bg-surface-container-low border border-outline-variant/15 px-4 py-2.5 text-sm text-on-surface font-mono">
          <%= @app.name %> <span class="text-outline">· <%= @app.server.name %></span>
        </div>
        <p class="text-[11px] text-outline mt-1">Linked automatically; runs on the same server.</p>
      </div>

      <div>
        <label for="database_service_name" class="<%= label_classes %>">Name</label>
        <%= text_field_tag "database_service[name]", nil, class: input_classes, placeholder: "my-database" %>
      </div>

      <div>
        <label class="<%= label_classes %>">Service Type</label>
        <%= combobox_tag "database_service[service_type]", service_type_options, value: "postgres", placeholder: "Select a service type",
            data: { "addon-tier-picker-target": "serviceType", action: "change->addon-tier-picker#refresh" } %>
      </div>

      <div>
        <label class="<%= label_classes %>">Plan</label>
        <%= hidden_field_tag "database_service[tier_name]", "basic", data: { "addon-tier-picker-target": "tierInput" } %>
        <div class="grid grid-cols-1 gap-2" data-addon-tier-picker-target="cards">
          <div class="text-xs text-outline px-3 py-2">Loading plans…</div>
        </div>
      </div>

      <div class="flex items-center gap-2 pt-2">
        <button type="submit" class="flex-1 py-2.5 px-4 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">Create Add-on</button>
        <button type="button" data-action="click->slide-panel#close" class="py-2.5 px-4 text-sm font-medium text-on-surface-variant border border-outline-variant/30 rounded-md hover:bg-surface-container-high transition cursor-pointer">Cancel</button>
      </div>
    <% end %>
  <% end %>

</div>
