<div class="max-w-lg">
  <div class="mb-6">
    <h1 class="text-2xl font-headline text-on-surface">New Team</h1>
    <p class="mt-1 text-sm text-outline">Create a team to collaborate with others</p>
  </div>

  <%= form_with(model: @team, url: dashboard_teams_path, class: "bg-surface-container-low rounded-xl border border-outline-variant/15 p-6 space-y-5") do |f| %>
    <% if @team.errors.any? %>
      <div class="bg-error-container/20 border border-error/20 rounded-lg p-4">
        <ul class="list-disc list-inside text-sm text-error space-y-1">
          <% @team.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-xs text-on-surface-variant uppercase tracking-wider mb-1" %>
      <%= f.text_field :name, class: "w-full rounded-md bg-surface border-outline-variant/15 text-on-surface font-mono text-sm focus:ring-primary focus:border-primary", placeholder: "My Team", autofocus: true %>
    </div>

    <div class="flex items-center space-x-3 pt-2">
      <%= f.submit "Create Team", class: "px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer" %>
      <%= link_to "Cancel", dashboard_teams_path, class: "text-sm text-outline hover:text-on-surface-variant transition" %>
    </div>
  <% end %>
</div>
