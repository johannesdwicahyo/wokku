<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Teams</h1>
    <p class="mt-1 text-sm text-gray-500">Manage your teams</p>
  </div>
  <%= link_to new_dashboard_team_path, class: "inline-flex items-center px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 transition shadow-sm" do %>
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    New Team
  <% end %>
</div>

<% if @teams.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @teams.each do |team| %>
      <%= link_to dashboard_team_path(team), class: "block bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md hover:border-purple-300 transition" do %>
        <h3 class="text-base font-semibold text-gray-900 mb-2"><%= team.name %></h3>
        <div class="flex items-center space-x-4 text-sm text-gray-500">
          <span><%= team.users.size %> members</span>
          <span><%= team.servers.size %> servers</span>
          <span><%= team.app_records.size %> apps</span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-16 bg-white rounded-xl border border-gray-200">
    <h3 class="mt-4 text-lg font-medium text-gray-900">No teams yet</h3>
    <p class="mt-2 text-sm text-gray-500">Create a team to start collaborating.</p>
    <div class="mt-6">
      <%= link_to "New Team", new_dashboard_team_path, class: "inline-flex items-center px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 transition" %>
    </div>
  </div>
<% end %>
