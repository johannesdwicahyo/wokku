<div data-controller="slide-panel">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Teams</h1>
      <p class="mt-1 text-sm text-gray-500">Manage your teams</p>
    </div>
    <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Team
    </button>
  </div>

  <% if @teams.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @teams.each do |team| %>
        <%= link_to dashboard_team_path(team), class: "block bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 p-5 hover:border-green-500/50 transition" do %>
          <h3 class="text-base font-semibold text-white mb-2"><%= team.name %></h3>
          <div class="flex items-center space-x-4 text-sm text-gray-400">
            <span><%= team.users.size %> members</span>
            <span><%= team.servers.size %> servers</span>
            <span><%= team.app_records.size %> apps</span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-[#1E293B]/60 rounded-xl border border-[#334155]/50">
      <h3 class="mt-4 text-lg font-medium text-white">No teams yet</h3>
      <p class="mt-2 text-sm text-gray-500">Create a team to start collaborating.</p>
      <div class="mt-6">
        <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer">New Team</button>
      </div>
    </div>
  <% end %>

  <%= render layout: "dashboard/shared/slide_panel", locals: { title: "New Team", subtitle: "Create a new team" } do %>
    <%= render "form", team: @team %>
  <% end %>
</div>
