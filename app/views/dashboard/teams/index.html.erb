<div data-controller="slide-panel">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-headline text-on-surface">Teams</h1>
      <p class="mt-1 text-sm text-outline">Manage your teams</p>
    </div>
    <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">
      <span class="material-symbols-outlined text-[18px] mr-1.5">add</span>
      New Team
    </button>
  </div>

  <% if @teams.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @teams.each do |team| %>
        <%= link_to dashboard_team_path(team), class: "block bg-surface-container-low rounded-xl border border-outline-variant/15 p-5 hover:border-primary/50 transition" do %>
          <h3 class="text-base font-semibold text-on-surface mb-2"><%= team.name %></h3>
          <div class="flex items-center space-x-4 text-sm text-on-surface-variant">
            <span><%= team.users.size %> members</span>
            <span><%= team.servers.size %> servers</span>
            <span><%= team.app_records.size %> apps</span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-surface-container-low rounded-xl border border-outline-variant/15">
      <span class="material-symbols-outlined text-[40px] text-outline-variant mb-2">group</span>
      <h3 class="mt-2 text-lg font-medium text-on-surface">No teams yet</h3>
      <p class="mt-2 text-sm text-outline">Create a team to start collaborating.</p>
      <div class="mt-6">
        <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">New Team</button>
      </div>
    </div>
  <% end %>

  <%= render layout: "dashboard/shared/slide_panel", locals: { title: "New Team", subtitle: "Create a new team" } do %>
    <%= render "form", team: @team %>
  <% end %>
</div>
