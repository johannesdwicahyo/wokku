<div class="mb-6">
  <div class="flex items-center space-x-3 mb-1">
    <%= link_to "Teams", dashboard_teams_path, class: "text-sm text-gray-500 hover:text-purple-600 transition" %>
    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <span class="text-sm text-gray-900 font-medium"><%= @team.name %></span>
  </div>
</div>

<h1 class="text-2xl font-bold text-gray-900 mb-6"><%= @team.name %></h1>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200">
    <h2 class="text-base font-semibold text-gray-900">Members</h2>
  </div>

  <div class="divide-y divide-gray-200">
    <% @members.each do |membership| %>
      <div class="px-6 py-3 flex items-center justify-between hover:bg-gray-50">
        <div class="flex items-center space-x-3">
          <div class="w-8 h-8 bg-purple-600 rounded-full flex items-center justify-center text-white text-sm font-medium">
            <%= membership.user.email[0].upcase %>
          </div>
          <span class="text-sm font-medium text-gray-900"><%= membership.user.email %></span>
        </div>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800"><%= membership.role.capitalize %></span>
      </div>
    <% end %>
  </div>
</div>
