<div class="mb-6">
  <div class="flex items-center space-x-3 mb-1">
    <%= link_to "Teams", dashboard_teams_path, class: "text-sm text-gray-500 hover:text-green-400 transition" %>
    <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <span class="text-sm text-white font-medium"><%= @team.name %></span>
  </div>
</div>

<h1 class="text-2xl font-bold text-white mb-6"><%= @team.name %></h1>

<div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 overflow-hidden">
  <div class="px-6 py-4 border-b border-[#334155]/50">
    <h2 class="text-base font-semibold text-white">Members</h2>
  </div>

  <div class="divide-y divide-[#334155]/50">
    <% @members.each do |membership| %>
      <div class="px-6 py-3 flex items-center justify-between hover:bg-[#334155]/20">
        <div class="flex items-center space-x-3">
          <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center text-[#0B1120] text-sm font-semibold">
            <%= membership.user.email[0].upcase %>
          </div>
          <span class="text-sm font-medium text-white"><%= membership.user.email %></span>
        </div>
        <span class="text-xs text-gray-400 uppercase tracking-wider"><%= membership.role.capitalize %></span>
      </div>
    <% end %>
  </div>
</div>
