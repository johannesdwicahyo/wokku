<div class="mb-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <%= link_to dashboard_app_path(app), class: "flex items-center gap-2 text-sm text-outline hover:text-primary transition" do %>
        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
        <span class="font-mono"><%= app.name %></span>
      <% end %>
    </div>
    <div class="flex items-center gap-2">
      <% page_name = request.path.split("/").last %>
      <span class="text-[10px] text-outline uppercase tracking-widest font-bold"><%= page_name.humanize %></span>
    </div>
  </div>
</div>
