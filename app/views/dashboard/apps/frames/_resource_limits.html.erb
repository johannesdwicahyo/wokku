<%= turbo_frame_tag "resource_limits" do %>
  <%
    mem_limit = @resources["default_limit_memory"]
    cpu_limit = @resources["default_limit_cpu"]
    shown = mem_limit.present? || cpu_limit.present?
  %>
  <% if shown %>
    <div class="bg-surface-container-low rounded-md overflow-hidden">
      <div class="px-5 py-3 border-b border-outline-variant/10">
        <p class="text-[10px] text-outline uppercase tracking-widest font-bold">Resource Limits</p>
      </div>
      <div class="grid grid-cols-2 divide-x divide-outline-variant/10">
        <div class="p-4 text-center">
          <p class="text-[10px] text-outline uppercase tracking-wider font-bold mb-1">Memory</p>
          <span class="text-lg font-bold text-on-surface font-mono"><%= mem_limit || "—" %> MB</span>
        </div>
        <div class="p-4 text-center">
          <p class="text-[10px] text-outline uppercase tracking-wider font-bold mb-1">CPU</p>
          <span class="text-lg font-bold text-on-surface font-mono"><%= vcpu_display(cpu_limit) %> vCPU</span>
        </div>
      </div>
      <div class="px-5 py-2.5 bg-surface/30 text-center">
        <%= link_to "Change Plan", dashboard_app_scaling_path(@app), class: "text-xs text-primary hover:underline font-semibold" %>
      </div>
    </div>
  <% end %>
<% end %>
