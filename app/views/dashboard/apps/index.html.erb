<div data-controller="slide-panel">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-on-surface font-headline"><%= t("dashboard.apps.title") %></h1>
      <p class="text-[10px] text-outline uppercase tracking-wider font-bold mt-1">All deployed applications</p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to dashboard_templates_path, class: "inline-flex items-center px-4 py-2 bg-surface-container-low text-on-surface-variant text-sm font-semibold rounded-md hover:bg-surface-container-high transition" do %>
        <span class="material-symbols-outlined text-[18px] mr-2">rocket_launch</span>
        <%= t("dashboard.nav.templates") %>
      <% end %>
      <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">
        <span class="material-symbols-outlined text-[18px] mr-2">add</span>
        <%= t("dashboard.apps.new_app") %>
      </button>
    </div>
  </div>

  <% if @apps.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      <% @apps.each do |app| %>
        <%= link_to dashboard_app_path(app), class: "block bg-surface-container-low rounded-md overflow-hidden hover:bg-surface-container-high/60 transition group" do %>
          <%# Progress bar %>
          <div class="h-0.5 w-full bg-outline-variant/10">
            <% if app.running? %>
              <div class="h-full technical-gradient w-full"></div>
            <% elsif app.deploying? %>
              <div class="h-full technical-gradient w-1/3 animate-pulse"></div>
            <% end %>
          </div>

          <div class="p-5">
            <div class="flex justify-between items-start mb-4">
              <div class="flex items-center space-x-3">
                <div class="w-9 h-9 rounded-md bg-primary-container/20 flex items-center justify-center">
                  <span class="material-symbols-outlined text-primary text-[20px]">terminal</span>
                </div>
                <div>
                  <h3 class="font-headline text-sm font-bold text-on-surface group-hover:text-primary transition"><%= app.name %></h3>
                  <p class="font-mono text-[10px] text-outline"><%= app.server.name %></p>
                </div>
              </div>
              <% case app.status %>
              <% when "running" %>
                <span class="bg-secondary-container text-on-secondary-container text-[10px] px-2 py-0.5 rounded-full font-bold uppercase glow-running"><%= t("common.running") %></span>
              <% when "crashed" %>
                <span class="bg-error-container text-on-error-container text-[10px] px-2 py-0.5 rounded-full font-bold uppercase glow-error"><%= t("common.crashed") %></span>
              <% when "deploying" %>
                <span class="bg-surface-variant text-on-surface-variant text-[10px] px-2 py-0.5 rounded-full font-bold uppercase"><%= t("common.deploying") %></span>
              <% when "stopped" %>
                <span class="bg-surface-variant text-outline text-[10px] px-2 py-0.5 rounded-full font-bold uppercase"><%= t("common.stopped") %></span>
              <% when "created" %>
                <span class="bg-surface-variant text-outline text-[10px] px-2 py-0.5 rounded-full font-bold uppercase">AWAITING DEPLOY</span>
              <% end %>
            </div>

            <% if (domain = app.domains.first) %>
              <div class="flex items-center space-x-1.5 text-xs text-on-surface-variant">
                <span class="material-symbols-outlined text-[14px]">language</span>
                <span class="font-mono text-primary truncate"><%= domain.hostname %></span>
              </div>
            <% end %>

            <div class="flex items-center space-x-1.5 mt-2 text-xs text-outline">
              <span class="material-symbols-outlined text-[14px]">schedule</span>
              <span><%= time_ago_in_words(app.updated_at) %> ago</span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-surface-container-low rounded-md p-16 text-center">
      <span class="material-symbols-outlined text-outline-variant text-[48px] mb-4">terminal</span>
      <h3 class="text-lg font-medium text-on-surface font-headline"><%= t("dashboard.apps.no_apps") %></h3>
      <p class="text-sm text-outline mt-2"><%= t("dashboard.apps.no_apps_desc") %></p>
      <div class="mt-6 flex items-center justify-center gap-3">
        <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer"><%= t("dashboard.apps.create_app") %></button>
        <%= link_to t("dashboard.apps.browse_templates"), dashboard_templates_path, class: "inline-flex items-center px-4 py-2 bg-surface-container text-on-surface-variant text-sm font-medium rounded-md hover:bg-surface-container-high transition" %>
      </div>
    </div>
  <% end %>

  <%# New App Slide Panel %>
  <%= render layout: "dashboard/shared/slide_panel", locals: { title: t("dashboard.apps.new_app"), subtitle: "Deploy a new application" } do %>
    <%= render "form", app: AppRecord.new, servers: policy_scope(Server) %>
  <% end %>
</div>
