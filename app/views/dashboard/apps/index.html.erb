<div data-controller="slide-panel">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-on-surface font-headline"><%= t("dashboard.apps.title") %></h1>
    <div class="flex items-center gap-2">
      <%= link_to dashboard_templates_path, class: "inline-flex items-center px-4 py-2 text-on-surface-variant text-sm font-medium rounded-md hover:bg-surface-container-high transition" do %>
        <%= t("dashboard.nav.templates") %>
      <% end %>
      <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">
        <%= t("dashboard.apps.new_app") %>
      </button>
    </div>
  </div>

  <% if @apps.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-3">
      <% @apps.each do |app| %>
        <%= link_to dashboard_app_path(app), class: "block bg-surface-container-low rounded-lg p-5 hover:bg-surface-container transition group" do %>
          <div class="flex items-start justify-between mb-3">
            <div class="min-w-0">
              <h3 class="text-base font-semibold text-on-surface group-hover:text-primary transition truncate"><%= app.name %></h3>
              <p class="text-xs text-outline mt-0.5"><%= app.server.name %></p>
            </div>
            <%# Status pill — only render when status is *not* the happy path %>
            <% case app.status %>
            <% when "crashed" %>
              <span class="text-[11px] text-error font-medium">Crashed</span>
            <% when "deploying" %>
              <span class="text-[11px] text-tertiary font-medium">Deploying…</span>
            <% when "stopped" %>
              <span class="text-[11px] text-outline font-medium">Stopped</span>
            <% when "created" %>
              <span class="text-[11px] text-outline font-medium">Awaiting deploy</span>
            <% end %>
          </div>

          <% if (domain = app.domains.first) %>
            <p class="text-xs text-on-surface-variant truncate font-mono mb-1.5"><%= domain.hostname %></p>
          <% end %>

          <p class="text-xs text-outline">Updated <%= time_ago_in_words(app.updated_at) %> ago</p>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-surface-container-low rounded-lg p-16 text-center">
      <h3 class="text-lg font-semibold text-on-surface font-headline"><%= t("dashboard.apps.no_apps") %></h3>
      <p class="text-sm text-outline mt-2"><%= t("dashboard.apps.no_apps_desc") %></p>
      <div class="mt-6 flex items-center justify-center gap-3">
        <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer"><%= t("dashboard.apps.create_app") %></button>
        <%= link_to t("dashboard.apps.browse_templates"), dashboard_templates_path, class: "inline-flex items-center px-4 py-2 text-on-surface-variant text-sm font-medium rounded-md hover:bg-surface-container-high transition" %>
      </div>
    </div>
  <% end %>

  <%= render layout: "dashboard/shared/slide_panel", locals: { title: t("dashboard.apps.new_app"), subtitle: "Deploy a new application" } do %>
    <%= render "form", app: AppRecord.new, servers: policy_scope(Server) %>
  <% end %>
</div>
