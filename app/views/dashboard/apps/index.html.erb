<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Apps</h1>
    <p class="mt-1 text-sm text-gray-500">Manage your deployed applications</p>
  </div>
  <%= link_to new_dashboard_app_path, class: "inline-flex items-center px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 transition shadow-sm" do %>
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    New App
  <% end %>
</div>

<% if @apps.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @apps.each do |app| %>
      <%= link_to dashboard_app_path(app), class: "block bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md hover:border-purple-300 transition group" do %>
        <div class="flex items-start justify-between mb-3">
          <h3 class="text-base font-semibold text-gray-900 group-hover:text-purple-600 transition"><%= app.name %></h3>
          <% case app.status %>
          <% when "running" %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Running</span>
          <% when "crashed" %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Crashed</span>
          <% when "stopped" %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Stopped</span>
          <% when "deploying" %>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Deploying</span>
          <% end %>
        </div>
        <div class="space-y-1.5 text-sm text-gray-500">
          <div class="flex items-center space-x-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/></svg>
            <span><%= app.server.name %></span>
          </div>
          <div class="flex items-center space-x-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>Created <%= time_ago_in_words(app.created_at) %> ago</span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-16 bg-white rounded-xl border border-gray-200">
    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
    <h3 class="mt-4 text-lg font-medium text-gray-900">No apps yet</h3>
    <p class="mt-2 text-sm text-gray-500">Get started by creating your first application.</p>
    <div class="mt-6">
      <%= link_to "Create App", new_dashboard_app_path, class: "inline-flex items-center px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 transition" %>
    </div>
  </div>
<% end %>
