<div data-controller="slide-panel">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-semibold text-white">Apps</h1>
      <p class="mt-0.5 text-sm text-gray-500">Manage your deployed applications</p>
    </div>
    <div class="flex items-center space-x-2">
      <%= link_to dashboard_templates_path, class: "inline-flex items-center px-3 py-1.5 bg-[#1E293B] border border-[#334155] text-gray-300 text-sm font-medium rounded-md hover:bg-[#334155] hover:text-white transition" do %>
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
        Templates
      <% end %>
      <button data-action="click->slide-panel#open" class="inline-flex items-center px-3 py-1.5 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer">
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        New App
      </button>
    </div>
  </div>

  <% if @apps.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
      <% @apps.each do |app| %>
        <%= link_to dashboard_app_path(app), class: "block bg-[#1E293B]/60 rounded-lg border border-[#334155]/50 p-4 hover:bg-[#1E293B] hover:border-[#334155] transition cursor-pointer group" do %>
          <div class="flex items-start justify-between mb-3">
            <h3 class="text-sm font-semibold text-white font-mono group-hover:text-green-400 transition"><%= app.name %></h3>
            <% case app.status %>
            <% when "running" %>
              <span class="inline-flex items-center space-x-1 text-xs text-green-400">
                <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span>
                <span>Running</span>
              </span>
            <% when "crashed" %>
              <span class="inline-flex items-center space-x-1 text-xs text-red-400">
                <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>
                <span>Crashed</span>
              </span>
            <% when "stopped" %>
              <span class="inline-flex items-center space-x-1 text-xs text-gray-500">
                <span class="w-1.5 h-1.5 rounded-full bg-gray-500"></span>
                <span>Stopped</span>
              </span>
            <% when "deploying" %>
              <span class="inline-flex items-center space-x-1 text-xs text-yellow-500">
                <span class="w-1.5 h-1.5 rounded-full bg-yellow-500 animate-pulse"></span>
                <span>Deploying</span>
              </span>
            <% when "sleeping" %>
              <span class="inline-flex items-center space-x-1 text-xs text-gray-500">
                <span class="w-1.5 h-1.5 rounded-full bg-gray-500"></span>
                <span>Sleeping</span>
              </span>
            <% end %>
          </div>
          <% if (primary_domain = app.domains.find { |d| d.hostname.end_with?(".wokku.dev") } || app.domains.first) %>
            <div class="flex items-center space-x-1.5 text-xs text-gray-500 mb-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
              <span class="font-mono truncate"><%= primary_domain.hostname %></span>
            </div>
          <% end %>
          <div class="space-y-1 text-xs text-gray-500">
            <div class="flex items-center space-x-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/></svg>
              <span class="font-mono"><%= app.server.name %></span>
            </div>
            <div class="flex items-center space-x-1.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span><%= time_ago_in_words(app.created_at) %> ago</span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-[#1E293B]/40 rounded-lg border border-[#334155]/30">
      <svg class="mx-auto h-10 w-10 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
      <h3 class="mt-3 text-sm font-medium text-gray-300">No apps yet</h3>
      <p class="mt-1 text-xs text-gray-500">Get started by creating your first application.</p>
      <div class="mt-4">
        <button data-action="click->slide-panel#open" class="inline-flex items-center px-3 py-1.5 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer">Create App</button>
      </div>
    </div>
  <% end %>

  <%= render layout: "dashboard/shared/slide_panel", locals: { title: "New App", subtitle: "Deploy a new application" } do %>
    <%= render "form", app: @app, servers: @servers %>
  <% end %>
</div>
