<div class="mb-6">
  <div class="flex items-center space-x-3 mb-1">
    <%= link_to "Apps", dashboard_apps_path, class: "text-sm text-gray-500 hover:text-green-400 transition" %>
    <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <span class="text-sm text-white font-medium font-mono"><%= @app.name %></span>
  </div>
</div>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center space-x-4">
    <h1 class="text-2xl font-bold text-white font-mono"><%= @app.name %></h1>
    <% case @app.status %>
    <% when "running" %>
      <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-green-400"></span><span class="text-xs text-gray-400">Running</span></span>
    <% when "crashed" %>
      <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-red-400"></span><span class="text-xs text-gray-400">Crashed</span></span>
    <% when "stopped" %>
      <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-gray-500"></span><span class="text-xs text-gray-400">Stopped</span></span>
    <% when "deploying" %>
      <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-yellow-500 animate-pulse"></span><span class="text-xs text-gray-400">Deploying</span></span>
    <% end %>
  </div>
  <div class="flex items-center space-x-3">
    <% if (primary_domain = @app.domains.first) %>
      <%= link_to "https://#{primary_domain.hostname}", "https://#{primary_domain.hostname}", target: "_blank", rel: "noopener", class: "inline-flex items-center space-x-1.5 text-sm text-gray-400 hover:text-green-400 transition" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        <span class="font-mono"><%= primary_domain.hostname %></span>
      <% end %>
    <% end %>

    <%# Lifecycle Buttons %>
    <div class="flex items-center space-x-1 border-l border-[#334155]/50 pl-3">
      <% if @app.stopped? %>
        <%= button_to start_dashboard_app_path(@app), method: :post, class: "inline-flex items-center px-2.5 py-1 text-xs text-green-400 border border-green-500/30 rounded-md hover:bg-green-500/10 transition cursor-pointer", title: "Start" do %>
          <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/></svg>
          Start
        <% end %>
      <% else %>
        <%= button_to restart_dashboard_app_path(@app), method: :post, class: "inline-flex items-center px-2.5 py-1 text-xs text-gray-400 border border-[#334155] rounded-md hover:border-green-500/50 hover:text-green-400 transition cursor-pointer", title: "Restart" do %>
          <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          Restart
        <% end %>
        <%= button_to stop_dashboard_app_path(@app), method: :post, data: { turbo_confirm: "Stop #{@app.name}?" }, class: "inline-flex items-center px-2.5 py-1 text-xs text-gray-400 border border-[#334155] rounded-md hover:border-red-500/50 hover:text-red-400 transition cursor-pointer", title: "Stop" do %>
          <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 10a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1h-4a1 1 0 01-1-1v-4z"/></svg>
          Stop
        <% end %>
      <% end %>
    </div>

    <%= link_to "Delete", dashboard_app_path(@app), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete #{@app.name}?" }, class: "text-sm text-red-400/70 hover:text-red-400 font-medium transition" %>
  </div>
</div>

<%# Tabs %>
<div class="border-b border-[#334155]/50 mb-6">
  <nav class="-mb-px flex space-x-6">
    <%
      tabs = [
        { name: "Overview", path: dashboard_app_path(@app), exact: true },
        { name: "Config", path: dashboard_app_config_index_path(@app) },
        { name: "Domains", path: dashboard_app_domains_path(@app) },
        { name: "Releases", path: dashboard_app_releases_path(@app) },
        { name: "Scaling", path: dashboard_app_scaling_path(@app) },
        { name: "Logs", path: dashboard_app_logs_path(@app) },
        { name: "Metrics", path: dashboard_app_metrics_path(@app) },
      ]
    %>
    <% tabs.each do |tab| %>
      <%
        active = tab[:exact] ? request.path == tab[:path] : request.path.start_with?(tab[:path])
        classes = active ?
          "border-b-2 border-green-400 text-green-400 py-3 text-sm font-medium" :
          "border-b-2 border-transparent text-gray-400 hover:text-green-400 hover:border-[#334155] py-3 text-sm font-medium transition"
      %>
      <%= link_to tab[:name], tab[:path], class: classes %>
    <% end %>
  </nav>
</div>

<%# Overview Content %>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 p-6">
    <h3 class="text-xs text-gray-400 uppercase tracking-wider font-semibold mb-4">Details</h3>
    <dl class="space-y-3">
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Server</dt>
        <dd class="text-sm text-white font-mono"><%= @app.server.name %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Branch</dt>
        <dd class="text-sm text-white font-mono"><%= @app.deploy_branch || "main" %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Team</dt>
        <dd class="text-sm text-white"><%= @app.team.name %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Created</dt>
        <dd class="text-sm text-gray-400"><%= @app.created_at.strftime("%b %d, %Y") %></dd>
      </div>
    </dl>
  </div>

  <div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 p-6">
    <h3 class="text-xs text-gray-400 uppercase tracking-wider font-semibold mb-4">Recent Activity</h3>
    <% recent_deploys = @app.deploys.recent.limit(5) %>
    <% if recent_deploys.any? %>
      <div class="space-y-3">
        <% recent_deploys.each do |deploy| %>
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-2">
              <% case deploy.status %>
              <% when "succeeded" %>
                <span class="w-2 h-2 rounded-full bg-green-400"></span>
              <% when "failed" %>
                <span class="w-2 h-2 rounded-full bg-red-400"></span>
              <% when "building" %>
                <span class="w-2 h-2 rounded-full bg-yellow-500 animate-pulse"></span>
              <% else %>
                <span class="w-2 h-2 rounded-full bg-gray-500"></span>
              <% end %>
              <span class="text-sm text-gray-400 font-mono"><%= deploy.commit_sha&.first(7) || "manual" %></span>
            </div>
            <span class="text-xs text-gray-500"><%= time_ago_in_words(deploy.created_at) %> ago</span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-500">No deploys yet.</p>
    <% end %>
  </div>
</div>
