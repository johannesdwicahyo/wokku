<div class="mb-6">
  <div class="flex items-center space-x-3 mb-1">
    <%= link_to "Apps", dashboard_apps_path, class: "text-sm text-outline hover:text-primary transition" %>
    <span class="material-symbols-outlined text-[16px] text-outline-variant">chevron_right</span>
    <span class="text-sm text-on-surface font-medium font-mono"><%= @app.name %></span>
  </div>
</div>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center space-x-4">
    <h1 class="text-2xl font-bold text-on-surface font-headline"><%= @app.name %></h1>
    <% case @app.status %>
    <% when "running" %>
      <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-primary"></span><span class="text-xs text-on-surface-variant">Running</span></span>
    <% when "crashed" %>
      <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-error"></span><span class="text-xs text-on-surface-variant">Crashed</span></span>
    <% when "stopped" %>
      <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-outline"></span><span class="text-xs text-on-surface-variant">Stopped</span></span>
    <% when "deploying" %>
      <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-tertiary animate-pulse"></span><span class="text-xs text-on-surface-variant">Deploying</span></span>
    <% end %>
  </div>
  <div class="flex items-center space-x-3">
    <% if (primary_domain = @app.domains.first) %>
      <%= link_to "https://#{primary_domain.hostname}", target: "_blank", rel: "noopener", class: "inline-flex items-center space-x-1.5 text-sm text-on-surface-variant hover:text-primary transition" do %>
        <span class="material-symbols-outlined text-[16px]">open_in_new</span>
        <span class="font-mono"><%= primary_domain.hostname %></span>
      <% end %>
    <% end %>

    <%# Lifecycle Buttons %>
    <div class="flex items-center space-x-1 border-l border-outline-variant/15 pl-3">
      <% if @app.stopped? %>
        <%= button_to start_dashboard_app_path(@app), method: :post, class: "inline-flex items-center px-2.5 py-1 text-xs text-primary border border-primary/30 rounded-md hover:bg-secondary-container/20 transition cursor-pointer", title: "Start" do %>
          <span class="material-symbols-outlined text-[16px] mr-1">play_arrow</span>
          Start
        <% end %>
      <% else %>
        <%= button_to restart_dashboard_app_path(@app), method: :post, class: "inline-flex items-center px-2.5 py-1 text-xs text-on-surface-variant border border-outline-variant/15 rounded-md hover:border-primary/50 hover:text-primary transition cursor-pointer", title: "Restart" do %>
          <span class="material-symbols-outlined text-[16px] mr-1">refresh</span>
          Restart
        <% end %>
        <%= button_to stop_dashboard_app_path(@app), method: :post, data: { turbo_confirm: "Stop #{@app.name}?" }, class: "inline-flex items-center px-2.5 py-1 text-xs text-on-surface-variant border border-outline-variant/15 rounded-md hover:border-error/50 hover:text-error transition cursor-pointer", title: "Stop" do %>
          <span class="material-symbols-outlined text-[16px] mr-1">stop_circle</span>
          Stop
        <% end %>
      <% end %>
    </div>

    <%= link_to "Delete", dashboard_app_path(@app), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete #{@app.name}?" }, class: "text-sm text-error/70 hover:text-error font-medium transition" %>
  </div>
</div>

<% if @app.deploying? %>
  <% latest_deploy = @app.deploys.order(created_at: :desc).first %>
  <% if latest_deploy %>
    <div class="mb-4 bg-tertiary-container/20 border border-tertiary/20 rounded-lg p-3 flex items-center justify-between">
      <div class="flex items-center space-x-2">
        <span class="w-2 h-2 rounded-full bg-tertiary animate-pulse"></span>
        <span class="text-sm text-tertiary">Deploying...</span>
      </div>
      <%= link_to "View logs", dashboard_app_deploy_path(@app, latest_deploy), class: "text-xs text-tertiary hover:text-tertiary/80 font-medium transition" %>
    </div>
  <% end %>
<% end %>

<%# Tabs %>
<div class="border-b border-outline-variant/15 mb-6">
  <nav class="-mb-px flex space-x-6">
    <%
      tabs = [
        { name: "Overview", path: dashboard_app_path(@app), exact: true },
        { name: "Config", path: dashboard_app_config_index_path(@app) },
        { name: "Domains", path: dashboard_app_domains_path(@app) },
        { name: "Releases", path: dashboard_app_releases_path(@app) },
        { name: "Scaling", path: dashboard_app_scaling_path(@app) },
        { name: "Logs", path: dashboard_app_logs_path(@app) },
        { name: "Metrics", path: dashboard_app_metrics_path(@app) },
        { name: "Terminal", path: dashboard_app_terminal_path(@app) },
      ]
    %>
    <% tabs.each do |tab| %>
      <%
        active = tab[:exact] ? request.path == tab[:path] : request.path.start_with?(tab[:path])
        classes = active ?
          "border-b-2 border-primary text-primary py-3 text-sm font-medium" :
          "border-b-2 border-transparent text-on-surface-variant hover:text-primary hover:border-outline-variant/15 py-3 text-sm font-medium transition"
      %>
      <%= link_to tab[:name], tab[:path], class: classes %>
    <% end %>
  </nav>
</div>

<%# Overview Content %>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  <div class="bg-surface-container-low rounded-xl p-6">
    <h3 class="text-[10px] text-outline uppercase tracking-wider font-bold mb-4">Details</h3>
    <dl class="space-y-3">
      <div class="flex justify-between">
        <dt class="text-sm text-outline">Server</dt>
        <dd class="text-sm text-on-surface font-mono"><%= @app.server.name %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-outline">Branch</dt>
        <dd class="text-sm text-on-surface font-mono"><%= @app.deploy_branch || "main" %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-outline">Team</dt>
        <dd class="text-sm text-on-surface"><%= @app.team.name %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-outline">Created</dt>
        <dd class="text-sm text-on-surface-variant"><%= @app.created_at.strftime("%b %d, %Y") %></dd>
      </div>
    </dl>
  </div>

  <div class="bg-surface-container-low rounded-xl p-6">
    <h3 class="text-[10px] text-outline uppercase tracking-wider font-bold mb-4">Recent Activity</h3>
    <% recent_deploys = @app.deploys.recent.limit(5) %>
    <% if recent_deploys.any? %>
      <div class="space-y-3">
        <% recent_deploys.each do |deploy| %>
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-2">
              <% case deploy.status %>
              <% when "succeeded" %>
                <span class="w-2 h-2 rounded-full bg-primary"></span>
              <% when "failed" %>
                <span class="w-2 h-2 rounded-full bg-error"></span>
              <% when "building" %>
                <span class="w-2 h-2 rounded-full bg-tertiary animate-pulse"></span>
              <% else %>
                <span class="w-2 h-2 rounded-full bg-outline"></span>
              <% end %>
              <span class="text-sm text-on-surface-variant font-mono"><%= deploy.commit_sha&.first(7) || "manual" %></span>
            </div>
            <span class="text-xs text-outline"><%= time_ago_in_words(deploy.created_at) %> ago</span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-outline">No deploys yet.</p>
    <% end %>
  </div>
</div>
