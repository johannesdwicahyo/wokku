<%# App Header %>
<div class="flex items-center justify-between mb-8">
  <div class="flex items-center gap-4">
    <div class="flex items-center gap-3">
      <%= link_to t("dashboard.apps.title"), dashboard_apps_path, class: "text-sm text-outline hover:text-primary transition" %>
      <span class="material-symbols-outlined text-outline-variant text-[16px]">chevron_right</span>
    </div>
    <div class="flex items-center gap-3">
      <span class="material-symbols-outlined text-primary text-[24px]">terminal</span>
      <h1 class="text-2xl font-bold text-on-surface font-headline"><%= @app.name %></h1>
    </div>
    <% case @app.status %>
    <% when "running" %>
      <span class="bg-secondary-container text-on-secondary-container text-[10px] px-2.5 py-1 rounded-full font-bold uppercase glow-running"><%= t("common.running") %></span>
    <% when "crashed" %>
      <span class="bg-error-container text-on-error-container text-[10px] px-2.5 py-1 rounded-full font-bold uppercase glow-error"><%= t("common.crashed") %></span>
    <% when "stopped" %>
      <span class="bg-surface-variant text-outline text-[10px] px-2.5 py-1 rounded-full font-bold uppercase"><%= t("common.stopped") %></span>
    <% when "deploying" %>
      <span class="bg-primary/15 text-primary text-[10px] px-2.5 py-1 rounded-full font-bold uppercase flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
        <%= t("common.deploying") %>
      </span>
    <% when "created" %>
      <span class="bg-surface-variant text-outline text-[10px] px-2.5 py-1 rounded-full font-bold uppercase">AWAITING DEPLOY</span>
    <% end %>
  </div>
  <div class="flex items-center gap-2">
    <% if @app.server && !@app.created? %>
      <%= link_to dashboard_app_terminal_path(@app), class: "inline-flex items-center px-3 py-1.5 text-xs text-on-surface-variant border border-outline-variant/15 rounded-md hover:border-primary/50 hover:text-primary transition" do %>
        <span class="material-symbols-outlined text-[16px] mr-1">terminal</span> Console
      <% end %>
    <% end %>
    <% if @app.created? %>
      <%# No actions for apps that haven't been deployed yet %>
    <% elsif @app.stopped? %>
      <%= button_to start_dashboard_app_path(@app), method: :post, class: "inline-flex items-center px-3 py-1.5 text-xs text-primary border border-primary/30 rounded-md hover:bg-secondary-container/20 transition cursor-pointer" do %>
        <span class="material-symbols-outlined text-[16px] mr-1">play_arrow</span> Start
      <% end %>
    <% else %>
      <%= button_to restart_dashboard_app_path(@app), method: :post, class: "inline-flex items-center px-3 py-1.5 text-xs text-on-surface-variant border border-outline-variant/15 rounded-md hover:border-primary/50 hover:text-primary transition cursor-pointer" do %>
        <span class="material-symbols-outlined text-[16px] mr-1">refresh</span> Restart
      <% end %>
      <%= button_to stop_dashboard_app_path(@app), method: :post, data: { turbo_confirm: "Stop #{@app.name}?" }, class: "inline-flex items-center px-3 py-1.5 text-xs text-on-surface-variant border border-outline-variant/15 rounded-md hover:border-error/50 hover:text-error transition cursor-pointer" do %>
        <span class="material-symbols-outlined text-[16px] mr-1">stop_circle</span> Stop
      <% end %>
    <% end %>
  </div>
</div>

<%# Getting started guide for new apps %>
<% if @app.created? %>
  <div class="mb-6 bg-primary/5 border border-primary/20 rounded-xl p-6">
    <div class="flex items-start gap-4">
      <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0">
        <span class="material-symbols-outlined text-primary text-[20px]">rocket_launch</span>
      </div>
      <div class="flex-1">
        <h3 class="text-sm font-bold text-on-surface font-headline mb-1">Deploy your app</h3>
        <p class="text-xs text-outline mb-4">Push your code via Git or connect a GitHub repository for automatic deploys.</p>

        <div class="space-y-3">
          <div class="bg-surface rounded-md p-3">
            <p class="text-[10px] text-outline uppercase tracking-wider font-bold mb-2">Option 1: Git Push</p>
            <div class="space-y-1.5">
              <code class="block text-xs font-mono text-on-surface-variant bg-surface-container-low rounded px-2 py-1">git remote add wokku <%= @app.git_remote_url %></code>
              <code class="block text-xs font-mono text-on-surface-variant bg-surface-container-low rounded px-2 py-1">git push wokku <%= @app.deploy_branch || "main" %></code>
            </div>
          </div>

          <div class="bg-surface rounded-md p-3">
            <p class="text-[10px] text-outline uppercase tracking-wider font-bold mb-2">Option 2: GitHub Auto-Deploy</p>
            <p class="text-xs text-outline">Connect a repo from the <%= link_to "Releases", dashboard_app_releases_path(@app), class: "text-primary hover:underline" %> tab.</p>
          </div>
        </div>

        <div class="flex items-center gap-3 mt-4">
          <%= link_to docs_page_path("getting-started/first-deploy"), class: "text-xs text-primary hover:underline flex items-center gap-1" do %>
            <span class="material-symbols-outlined text-[14px]">menu_book</span> Deployment Guide
          <% end %>
          <%= link_to docs_page_path("apps/config"), class: "text-xs text-primary hover:underline flex items-center gap-1" do %>
            <span class="material-symbols-outlined text-[14px]">settings</span> Environment Variables
          <% end %>
          <%= link_to docs_page_path("domains-ssl/custom-domains"), class: "text-xs text-primary hover:underline flex items-center gap-1" do %>
            <span class="material-symbols-outlined text-[14px]">language</span> Custom Domains
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<%# In-progress deploy banner — prominent feedback during the 30+ second build %>
<% if @app.deploying? %>
  <% active_deploy = @app.deploys.where(status: [ :pending, :building ]).order(created_at: :desc).first %>
  <% if active_deploy %>
    <div class="mb-6 bg-primary/5 border border-primary/20 rounded-md p-4">
      <div class="flex items-start justify-between gap-4">
        <div class="flex items-start gap-3 flex-1">
          <div class="w-10 h-10 rounded-full bg-primary/15 flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-primary animate-spin">progress_activity</span>
          </div>
          <div class="flex-1">
            <h3 class="text-sm font-bold text-on-surface mb-1">Deploy in progress</h3>
            <p class="text-xs text-outline mb-2">
              Building and deploying <%= @app.name %>. This usually takes 30 seconds to 5 minutes depending on the app size.
            </p>
            <%# Indeterminate progress bar %>
            <div class="relative h-1 bg-surface-container rounded-full overflow-hidden">
              <div class="absolute inset-y-0 w-1/3 technical-gradient rounded-full animate-pulse"
                   style="animation: deploy-progress 2s ease-in-out infinite;"></div>
            </div>
          </div>
        </div>
        <%= link_to dashboard_app_deploy_path(@app, active_deploy), class: "flex-shrink-0 inline-flex items-center gap-1 px-3 py-1.5 text-xs text-primary border border-primary/30 rounded-md hover:bg-primary/10 transition" do %>
          View live logs
          <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
        <% end %>
      </div>
    </div>
    <style>
      @keyframes deploy-progress {
        0%   { transform: translateX(-100%); }
        50%  { transform: translateX(200%); }
        100% { transform: translateX(-100%); }
      }
    </style>
  <% end %>
<% end %>

<div class="grid grid-cols-12 gap-6">
  <%# ===== LEFT COLUMN (8-col) ===== %>
  <div class="col-span-8 space-y-6">

    <%# Live Metrics — lazy-loaded Turbo Frame (defers SSH to keep #show fast) %>
    <%= turbo_frame_tag "runtime_metrics", src: runtime_metrics_frame_dashboard_app_path(@app), loading: "lazy" do %>
      <div class="grid grid-cols-3 gap-4">
        <% 3.times do %>
          <div class="bg-surface-container-low rounded-md p-5">
            <div class="h-3 w-20 bg-surface rounded animate-pulse mb-3"></div>
            <div class="h-8 w-24 bg-surface rounded animate-pulse mb-3"></div>
            <div class="h-1.5 w-full bg-surface rounded animate-pulse"></div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Live Logs — lazy-loaded Turbo Frame %>
    <%= turbo_frame_tag "live_logs", src: live_logs_frame_dashboard_app_path(@app), loading: "lazy" do %>
      <div class="bg-surface-container-lowest rounded-md overflow-hidden">
        <div class="px-6 py-3 border-b border-outline-variant/10 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <h2 class="font-headline text-sm font-bold text-on-surface"><%= t("dashboard.apps.logs") %></h2>
            <span class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-outline-variant animate-pulse"></span><span class="text-[10px] text-outline uppercase font-bold">Loading</span></span>
          </div>
        </div>
        <div class="p-4 font-mono text-xs leading-relaxed h-40 flex flex-col gap-2">
          <% 4.times do |i| %>
            <div class="h-3 bg-surface rounded animate-pulse" style="width: <%= [60, 80, 70, 90][i] %>%"></div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Environment Variables %>
    <div class="bg-surface-container-low rounded-md overflow-hidden">
      <div class="px-6 py-3 border-b border-outline-variant/10 flex items-center justify-between">
        <h2 class="font-headline text-sm font-bold text-on-surface"><%= t("dashboard.apps.environment_variables") %></h2>
        <%= link_to dashboard_app_config_index_path(@app), class: "text-xs text-outline hover:text-primary transition flex items-center gap-1" do %>
          <span class="material-symbols-outlined text-[14px]">edit</span> Manage
        <% end %>
      </div>
      <% if @env_vars.any? %>
        <div class="divide-y divide-outline-variant/10">
          <% @env_vars.first(8).each do |var| %>
            <div class="px-6 py-2.5 flex items-center justify-between hover:bg-surface-container-high/20 transition">
              <span class="text-xs font-mono font-bold text-primary"><%= var.key %></span>
              <span class="text-xs font-mono text-outline">••••••••</span>
            </div>
          <% end %>
          <% if @env_vars.size > 8 %>
            <div class="px-6 py-2.5 text-center">
              <%= link_to "+#{@env_vars.size - 8} more", dashboard_app_config_index_path(@app), class: "text-xs text-outline hover:text-primary transition" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="px-6 py-6 text-center">
          <p class="text-xs text-outline">No environment variables configured.</p>
        </div>
      <% end %>
    </div>

    <%# Domains %>
    <div class="bg-surface-container-low rounded-md overflow-hidden">
      <div class="px-6 py-3 border-b border-outline-variant/10 flex items-center justify-between">
        <h2 class="font-headline text-sm font-bold text-on-surface"><%= t("dashboard.apps.domains") %></h2>
        <%= link_to dashboard_app_domains_path(@app), class: "text-xs text-outline hover:text-primary transition flex items-center gap-1" do %>
          <span class="material-symbols-outlined text-[14px]">edit</span> Manage
        <% end %>
      </div>
      <% if @domains.any? %>
        <div class="divide-y divide-outline-variant/10">
          <% @domains.each do |domain| %>
            <div class="px-6 py-2.5 flex items-center justify-between hover:bg-surface-container-high/20 transition">
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-[14px]">language</span>
                <a href="https://<%= domain.hostname %>" target="_blank" class="text-xs font-mono text-primary hover:underline"><%= domain.hostname %></a>
              </div>
              <% if domain.respond_to?(:ssl_enabled?) && domain.ssl_enabled? %>
                <span class="flex items-center gap-1 text-[10px] text-secondary"><span class="material-symbols-outlined text-[12px]">lock</span>SSL</span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="px-6 py-6 text-center">
          <p class="text-xs text-outline">No custom domains.</p>
        </div>
      <% end %>
    </div>

    <%# Add-ons %>
    <div class="bg-surface-container-low rounded-md overflow-hidden">
      <div class="px-6 py-3 border-b border-outline-variant/10 flex items-center justify-between">
        <h2 class="font-headline text-sm font-bold text-on-surface">Add-ons</h2>
        <%= link_to dashboard_app_resources_path(@app), class: "text-xs text-outline hover:text-primary transition flex items-center gap-1" do %>
          <span class="material-symbols-outlined text-[14px]">add</span> Manage
        <% end %>
      </div>
      <% if @addons.any? %>
        <div class="divide-y divide-outline-variant/10">
          <% @addons.each do |addon| %>
            <div class="px-6 py-2.5 flex items-center justify-between hover:bg-surface-container-high/20 transition">
              <div class="flex items-center gap-3">
                <% case addon.service_type %>
                <% when "postgres", "mysql", "mariadb", "mongodb", "clickhouse" %>
                  <span class="material-symbols-outlined text-secondary text-[16px]">database</span>
                <% when "redis", "memcached" %>
                  <span class="material-symbols-outlined text-tertiary text-[16px]">bolt</span>
                <% else %>
                  <span class="material-symbols-outlined text-primary text-[16px]">dns</span>
                <% end %>
                <span class="text-xs font-mono font-bold text-on-surface"><%= addon.name %></span>
                <span class="text-[10px] text-outline"><%= addon.service_type %></span>
              </div>
              <span class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-secondary glow-running"></span><span class="text-[10px] text-outline">Running</span></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="px-6 py-6 text-center">
          <p class="text-xs text-outline">No add-ons attached.</p>
          <%= link_to "Add an add-on", dashboard_app_resources_path(@app), class: "text-xs text-primary hover:underline" %>
        </div>
      <% end %>
    </div>

    <%# Full Metrics — link row below Add-ons %>
    <%= link_to dashboard_app_metrics_path(@app), class: "block bg-surface-container-low rounded-md px-6 py-3 hover:bg-surface-container-high/40 transition flex items-center justify-between group" do %>
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary text-[18px]">monitoring</span>
        <div>
          <p class="text-sm font-bold text-on-surface font-headline">Full Metrics</p>
          <p class="text-[10px] text-outline">CPU, memory, and request charts over time</p>
        </div>
      </div>
      <span class="material-symbols-outlined text-outline group-hover:text-primary text-[18px]">chevron_right</span>
    <% end %>

    <%# Preview Apps (only shown for main apps that have PR previews) %>
    <% if @preview_apps&.any? %>
      <div class="bg-surface-container-low rounded-md overflow-hidden">
        <div class="px-6 py-3 border-b border-outline-variant/10 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-[16px]">fork_right</span>
            <h2 class="font-headline text-sm font-bold text-on-surface">Preview Apps</h2>
            <span class="text-[10px] bg-primary-container text-on-primary-container px-2 py-0.5 rounded-full font-bold"><%= @preview_apps.size %></span>
          </div>
        </div>
        <div class="divide-y divide-outline-variant/10">
          <% @preview_apps.each do |preview| %>
            <div class="px-6 py-3 flex items-center justify-between hover:bg-surface-container-high/20 transition">
              <div class="flex items-center gap-3">
                <% case preview.status %>
                <% when "running" %>
                  <span class="w-2 h-2 rounded-full bg-secondary glow-running flex-shrink-0"></span>
                <% when "crashed" %>
                  <span class="w-2 h-2 rounded-full bg-error flex-shrink-0"></span>
                <% when "deploying" %>
                  <span class="w-2 h-2 rounded-full bg-outline animate-pulse flex-shrink-0"></span>
                <% else %>
                  <span class="w-2 h-2 rounded-full bg-outline-variant flex-shrink-0"></span>
                <% end %>
                <div>
                  <%= link_to dashboard_app_path(preview), class: "text-xs font-mono font-bold text-on-surface hover:text-primary transition" do %>
                    PR #<%= preview.pr_number %>
                  <% end %>
                  <p class="text-[10px] text-outline mt-0.5"><%= preview.name %></p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-[10px] text-outline capitalize"><%= preview.status %></span>
                <% if @app.github_repo_full_name.present? %>
                  <%= link_to "https://github.com/#{@app.github_repo_full_name}/pull/#{preview.pr_number}",
                        target: "_blank", rel: "noopener noreferrer",
                        class: "text-outline hover:text-primary transition",
                        title: "View PR on GitHub" do %>
                    <span class="material-symbols-outlined text-[16px]">open_in_new</span>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# ===== RIGHT COLUMN (4-col) ===== %>
  <div class="col-span-4 space-y-6">

    <%# App Information %>
    <div class="bg-surface-container-low rounded-md overflow-hidden">
      <div class="px-5 py-3 border-b border-outline-variant/10">
        <p class="text-[10px] text-outline uppercase tracking-widest font-bold">App Information</p>
      </div>
      <div class="divide-y divide-outline-variant/10">
        <div class="px-5 py-3 flex items-center justify-between">
          <span class="text-xs text-outline"><%= t("dashboard.apps.server") %></span>
          <span class="text-xs font-mono font-bold text-on-surface"><%= @app.server.name %></span>
        </div>
        <div class="px-5 py-3 flex items-center justify-between">
          <span class="text-xs text-outline">Branch</span>
          <span class="text-xs font-mono font-bold text-on-surface"><%= @app.deploy_branch || "main" %></span>
        </div>
        <div class="px-5 py-3 flex items-center justify-between">
          <span class="text-xs text-outline">Git Remote</span>
          <code class="text-xs font-mono text-primary"><%= @app.git_remote_url %></code>
        </div>
        <div class="px-5 py-3 flex items-center justify-between">
          <span class="text-xs text-outline">Team</span>
          <span class="text-xs font-bold text-on-surface"><%= @app.team.name %></span>
        </div>
        <% if @current_allocation %>
          <div class="px-5 py-3 flex items-center justify-between">
            <span class="text-xs text-outline">Container</span>
            <span class="text-xs font-bold text-on-surface capitalize"><%= @current_allocation.dyno_tier.name %></span>
          </div>
        <% end %>
        <% if (last_deploy = @app.deploys.order(created_at: :desc).first) && last_deploy.commit_sha.present? %>
          <div class="px-5 py-3 flex items-center justify-between">
            <span class="text-xs text-outline">Commit</span>
            <span class="text-xs font-mono font-bold text-primary">#<%= last_deploy.commit_sha.first(7) %></span>
          </div>
        <% end %>
        <div class="px-5 py-3 flex items-center justify-between">
          <span class="text-xs text-outline"><%= t("dashboard.apps.created") %></span>
          <span class="text-xs text-on-surface-variant"><%= @app.created_at.strftime("%b %d, %Y") %></span>
        </div>
        <div class="px-5 py-3 flex items-center justify-between border-t border-outline-variant/10">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[14px] text-outline">lock</span>
            <span class="text-xs text-outline">Force HTTPS</span>
          </div>
          <%= button_to toggle_https_dashboard_app_path(@app), method: :post, class: "text-xs text-primary hover:underline cursor-pointer" do %>
            Enable
          <% end %>
        </div>
        <div class="px-5 py-3 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[14px] text-outline">construction</span>
            <span class="text-xs text-outline">Maintenance Mode</span>
          </div>
          <%= button_to toggle_maintenance_dashboard_app_path(@app), method: :post, data: { turbo_confirm: "Toggle maintenance mode for #{@app.name}?" }, class: "relative inline-flex h-5 w-9 items-center rounded-full transition-colors cursor-pointer #{@maintenance_enabled ? 'bg-primary' : 'bg-outline-variant/30'}" do %>
            <span class="inline-block h-3.5 w-3.5 rounded-full bg-white shadow transition-transform <%= @maintenance_enabled ? 'translate-x-4' : 'translate-x-0.5' %>"></span>
          <% end %>
        </div>
      </div>
    </div>

    <%# Billing %>
    <% if @current_allocation %>
      <%
        tier = @current_allocation.dyno_tier
        total_dynos = @app.dyno_allocations.sum(:count)
        monthly_cost_usd = total_dynos * tier.monthly_price_dollars
      %>
      <div class="bg-surface-container-low rounded-md overflow-hidden">
        <div class="px-5 py-3 border-b border-outline-variant/10 flex items-center justify-between">
          <p class="text-[10px] text-outline uppercase tracking-widest font-bold">Billing</p>
          <%= link_to "Resources", dashboard_app_resources_path(@app), class: "text-[10px] text-primary hover:underline" %>
        </div>
        <div class="divide-y divide-outline-variant/10">
          <div class="px-5 py-3 flex items-center justify-between">
            <span class="text-xs text-outline">Tier</span>
            <span class="text-xs font-bold text-on-surface capitalize"><%= tier.name %></span>
          </div>
          <div class="px-5 py-3 flex items-center justify-between">
            <span class="text-xs text-outline">Dynos</span>
            <span class="text-xs font-mono text-on-surface-variant"><%= total_dynos %></span>
          </div>
          <div class="px-5 py-3 flex items-center justify-between">
            <span class="text-xs text-outline">Estimated / month</span>
            <% if tier.free? %>
              <span class="text-xs font-bold text-on-surface">Free</span>
            <% else %>
              <span class="text-xs font-bold text-primary font-mono"><%= format_usd_for_user(monthly_cost_usd) %><%= price_period(Wokku::LaunchMode.idr_only? ? "idr" : nil) %></span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%# Resource Limits — lazy-loaded Turbo Frame %>
    <%= turbo_frame_tag "resource_limits", src: resource_limits_frame_dashboard_app_path(@app), loading: "lazy" do %>
      <div class="bg-surface-container-low rounded-md overflow-hidden">
        <div class="px-5 py-3 border-b border-outline-variant/10">
          <p class="text-[10px] text-outline uppercase tracking-widest font-bold">Resource Limits</p>
        </div>
        <div class="grid grid-cols-2 divide-x divide-outline-variant/10">
          <% 2.times do %>
            <div class="p-4 text-center">
              <div class="h-3 w-12 bg-surface rounded animate-pulse mx-auto mb-2"></div>
              <div class="h-5 w-16 bg-surface rounded animate-pulse mx-auto"></div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Pipeline Status — Recent Deploys %>
    <div class="bg-surface-container-low rounded-md overflow-hidden">
      <div class="px-5 py-3 border-b border-outline-variant/10 flex items-center justify-between">
        <p class="text-[10px] text-outline uppercase tracking-widest font-bold">Pipeline Status</p>
        <%= link_to dashboard_app_releases_path(@app), class: "text-xs text-outline hover:text-primary transition" do %>
          All Releases
        <% end %>
      </div>
      <% if @releases.any? %>
        <div class="px-5 py-4">
          <div class="space-y-4">
            <% @releases.first(3).each do |release| %>
              <div class="flex gap-3">
                <div class="flex flex-col items-center">
                  <% if release.deploy&.succeeded? %>
                    <span class="w-2 h-2 rounded-full bg-secondary mt-1"></span>
                  <% elsif release.deploy&.failed? %>
                    <span class="w-2 h-2 rounded-full bg-error mt-1"></span>
                  <% else %>
                    <span class="w-2 h-2 rounded-full bg-outline mt-1"></span>
                  <% end %>
                  <div class="w-px flex-1 bg-outline-variant/20 my-1"></div>
                </div>
                <div class="pb-2">
                  <p class="text-xs font-bold text-on-surface">
                    <% if release.deploy&.succeeded? %>Build Succeeded
                    <% elsif release.deploy&.failed? %>Build Failed
                    <% elsif release.deploy&.building? %>Building...
                    <% else %><%= release.description || "Release" %>
                    <% end %>
                  </p>
                  <p class="text-[10px] text-outline mt-0.5">
                    v<%= release.version %>
                    <% if release.deploy&.commit_sha.present? %> · <%= release.deploy.commit_sha.first(7) %><% end %>
                    · <%= time_ago_in_words(release.created_at) %> ago
                  </p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="px-5 py-6 text-center">
          <p class="text-xs text-outline">No deploys yet.</p>
        </div>
      <% end %>
    </div>

    <%# Ownership %>
    <div class="bg-surface-container-low rounded-md p-5">
      <p class="text-[10px] text-outline uppercase tracking-widest font-bold mb-3">Ownership</p>
      <div class="flex items-center gap-3">
        <div class="h-8 w-8 rounded-lg bg-primary-container flex items-center justify-center">
          <span class="text-primary text-xs font-bold"><%= @app.creator&.email&.first&.upcase || "?" %></span>
        </div>
        <div>
          <p class="text-xs font-bold text-on-surface"><%= @app.team.name %></p>
          <p class="text-[10px] text-outline"><%= @app.creator&.email %></p>
        </div>
      </div>
    </div>

    <%# Danger Zone %>
    <div class="bg-error-container/10 border border-error/20 rounded-md p-5 text-center">
      <%= button_to t("dashboard.apps.delete_application"), dashboard_app_path(@app),
            method: :delete,
            form: {
              data: {
                controller: "confirm-delete",
                confirm_delete_name_value: @app.name,
                confirm_delete_impact_value: "This will permanently delete #{@app.name}, all its deploys, logs, config, domains, and linked databases. This cannot be undone.",
                confirm_delete_resource_value: "app"
              }
            },
            class: "text-sm text-error hover:text-error font-semibold transition bg-transparent border-0 cursor-pointer" %>
    </div>
  </div>
</div>
