<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-xl font-headline text-on-surface">Notifications</h1>
    <p class="mt-0.5 text-sm text-outline">Get notified about deploys, failures, and other events</p>
  </div>
</div>

<%# Existing Rules %>
<div class="bg-surface-container-low rounded-xl border border-outline-variant/15 overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-outline-variant/15">
    <h2 class="text-base font-semibold text-on-surface">Notification Rules</h2>
  </div>

  <% if @notifications.any? %>
    <div class="divide-y divide-outline-variant/15">
      <% @notifications.each do |notification| %>
        <div class="px-6 py-4 flex items-center justify-between hover:bg-surface-container-highest transition">
          <div class="flex items-center space-x-4">
            <div class="flex items-center justify-center w-9 h-9 rounded-lg bg-surface border border-outline-variant/15">
              <% case notification.channel %>
              <% when "email" %>
                <span class="material-symbols-outlined text-[18px] text-primary">mail</span>
              <% when "slack" %>
                <span class="material-symbols-outlined text-[18px] text-secondary">tag</span>
              <% when "webhook" %>
                <span class="material-symbols-outlined text-[18px] text-tertiary">webhook</span>
              <% end %>
            </div>
            <div>
              <div class="flex items-center space-x-2">
                <span class="text-sm font-semibold text-on-surface capitalize"><%= notification.channel %></span>
                <% if notification.app_record %>
                  <span class="text-xs text-outline font-mono bg-surface px-1.5 py-0.5 rounded"><%= notification.app_record.name %></span>
                <% else %>
                  <span class="text-xs text-outline">All apps</span>
                <% end %>
              </div>
              <div class="flex items-center space-x-2 mt-0.5">
                <% (notification.events || []).each do |event| %>
                  <span class="text-xs text-on-surface-variant"><%= event.humanize %></span>
                <% end %>
              </div>
            </div>
          </div>
          <%= link_to "Remove", dashboard_notification_path(notification), data: { turbo_method: :delete, turbo_confirm: "Remove this notification rule?" }, class: "text-xs text-error/70 hover:text-error transition" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="px-6 py-8 text-center">
      <span class="material-symbols-outlined text-[40px] text-outline-variant mb-3">notifications_off</span>
      <p class="text-sm text-on-surface-variant">No notification rules configured.</p>
      <p class="text-xs text-outline mt-1">Add a rule below to get notified about events.</p>
    </div>
  <% end %>
</div>

<%# Add Notification %>
<div class="bg-surface-container-low rounded-xl border border-outline-variant/15 p-6">
  <h3 class="text-sm font-semibold text-on-surface mb-4">Add Notification Rule</h3>
  <%= form_with(model: @notification, url: dashboard_notifications_path, class: "space-y-4") do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div>
        <label class="block text-xs text-on-surface-variant uppercase tracking-wider mb-1">Channel</label>
        <%= f.select :channel, [
          ["Email", "email"],
          ["Slack", "slack"],
          ["Discord", "discord"],
          ["Telegram", "telegram"],
          ["Webhook", "webhook"]
        ], { prompt: "Select channel" }, class: "w-full rounded-md bg-surface border-outline-variant/15 text-on-surface text-sm focus:ring-primary focus:border-primary" %>
        <p class="mt-1 text-[10px] text-outline-variant">
          Slack/Discord: paste webhook URL. Telegram: set bot_token and chat_id in config.
        </p>
      </div>
      <div>
        <label class="block text-xs text-on-surface-variant uppercase tracking-wider mb-1">App (optional)</label>
        <%= f.collection_select :app_record_id, @apps, :id, :name, { prompt: "All apps", include_blank: false }, class: "w-full rounded-md bg-surface border-outline-variant/15 text-on-surface text-sm focus:ring-primary focus:border-primary" %>
      </div>
      <div>
        <label class="block text-xs text-on-surface-variant uppercase tracking-wider mb-1">Events</label>
        <div class="space-y-1.5 mt-1">
          <% ["deploy_succeeded", "deploy_failed", "app_crashed", "domain_added"].each do |event| %>
            <label class="flex items-center space-x-2 cursor-pointer">
              <input type="checkbox" name="notification[events][]" value="<%= event %>" class="rounded bg-surface border-outline-variant/15 text-primary focus:ring-primary">
              <span class="text-xs text-on-surface-variant"><%= event.humanize %></span>
            </label>
          <% end %>
        </div>
      </div>
    </div>
    <%= f.submit "Add Rule", class: "px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer" %>
  <% end %>
</div>
