<%
  nav_items = [
    { name: "Apps", path: dashboard_apps_path, icon: "M4 6h16M4 12h16M4 18h16", pattern: "apps" },
    { name: "Servers", path: dashboard_servers_path, icon: "M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2", pattern: "servers" },
    { name: "Databases", path: dashboard_databases_path, icon: "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4", pattern: "databases" },
    { name: "Teams", path: dashboard_teams_path, icon: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z", pattern: "teams" },
    { name: "Profile", path: dashboard_profile_path, icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z", pattern: "profile" },
  ]
%>

<aside class="w-56 bg-[#16162a] min-h-screen border-r border-[#2d2d4a] flex-shrink-0">
  <nav class="py-4 space-y-1">
    <% nav_items.each do |item| %>
      <%
        active = request.path.include?(item[:pattern])
        classes = active ?
          "flex items-center space-x-3 px-4 py-2.5 text-white bg-[#2d2d4a] border-l-2 border-purple-500" :
          "flex items-center space-x-3 px-4 py-2.5 text-gray-400 hover:text-white hover:bg-[#2d2d4a] border-l-2 border-transparent transition"
      %>
      <a href="<%= item[:path] %>" class="<%= classes %>">
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= item[:icon] %>"/>
        </svg>
        <span class="text-sm font-medium"><%= item[:name] %></span>
      </a>
    <% end %>
  </nav>
</aside>
