<aside class="fixed left-0 top-0 bottom-0 w-64 bg-surface-container-lowest flex flex-col h-full py-6 z-30 -translate-x-full lg:translate-x-0 transition-transform duration-200"
       id="dashboard-sidebar"
       data-controller="mobile-nav"
       data-mobile-nav-target="sidebar">
  <div class="px-6 mb-8">
    <a href="<%= root_path %>" class="block">
      <h1 class="text-lg font-black text-white font-headline tracking-tight">Wokku</h1>
      <p class="text-[10px] text-outline font-mono mt-1">Dokku v0.37.2 · CE v1.0</p>
    </a>
  </div>

  <%
    # Simplified nav. Activity + 1-Click Deploy moved out of the primary
    # nav — Deploy is a prominent button in the navbar, Activity is a
    # Quick Link on the profile page. Primary = the 4 nouns a user
    # actually navigates between.
    nav_items = [
      { name: t("dashboard.nav.dashboard"), path: dashboard_root_path, pattern: "/dashboard", icon: "dashboard", exact: true },
      { name: t("dashboard.nav.apps"), path: dashboard_apps_path, pattern: "/dashboard/apps", icon: "terminal" },
      { name: t("dashboard.nav.databases"), path: dashboard_resources_path, pattern: "/dashboard/resources", icon: "database" },
    ]
  %>
  <nav class="flex-1 space-y-0.5">
    <% nav_items.each do |item| %>
      <%
        active = item[:exact] ? request.path == item[:pattern] : request.path.start_with?(item[:pattern])
        active_classes = "text-primary bg-surface-container-high border-r-2 border-primary font-semibold"
        inactive_classes = "text-outline hover:text-on-surface-variant hover:bg-surface transition-all"
      %>
      <a href="<%= item[:path] %>" class="flex items-center px-6 py-3 text-sm font-label <%= active ? active_classes : inactive_classes %>">
        <span class="material-symbols-outlined mr-3 text-[20px]"><%= item[:icon] %></span>
        <span class="font-medium"><%= item[:name] %></span>
      </a>
    <% end %>
    <% if current_user.admin? %>
      <%
        server_active = request.path.start_with?("/dashboard/servers")
        server_classes = server_active ? "text-primary bg-surface-container-high border-r-2 border-primary font-semibold" : "text-outline hover:text-on-surface-variant hover:bg-surface transition-all"
      %>
      <a href="<%= dashboard_servers_path %>" class="flex items-center px-6 py-3 text-sm font-label <%= server_classes %>">
        <span class="material-symbols-outlined mr-3 text-[20px]">storage</span>
        <span class="font-medium"><%= t("dashboard.nav.servers") %></span>
      </a>
    <% end %>
  </nav>

  <div class="mt-auto px-6 pt-6 border-t border-outline-variant/10 space-y-1">
    <a href="/docs" target="_blank" class="flex items-center py-2 text-outline hover:text-on-surface-variant transition-all">
      <span class="material-symbols-outlined mr-3 text-[18px]">menu_book</span>
      <span class="text-xs font-medium font-label"><%= t("dashboard.nav.documentation") %></span>
    </a>
    <a href="mailto:support@wokku.cloud" class="flex items-center py-2 text-outline hover:text-on-surface-variant transition-all">
      <span class="material-symbols-outlined mr-3 text-[18px]">contact_support</span>
      <span class="text-xs font-medium font-label"><%= t("dashboard.nav.support") %></span>
    </a>
    <% if defined?(dashboard_billing_path) %>
      <a href="<%= dashboard_billing_path %>" class="flex items-center py-2 text-outline hover:text-on-surface-variant transition-all">
        <span class="material-symbols-outlined mr-3 text-[18px]">payments</span>
        <span class="text-xs font-medium font-label"><%= t("dashboard.nav.billing") %></span>
      </a>
    <% end %>
    <a href="<%= dashboard_profile_path %>" class="flex items-center py-2 text-outline hover:text-on-surface-variant transition-all">
      <span class="material-symbols-outlined mr-3 text-[18px]">settings</span>
      <span class="text-xs font-medium font-label"><%= t("dashboard.nav.settings") %></span>
    </a>
  </div>
</aside>
