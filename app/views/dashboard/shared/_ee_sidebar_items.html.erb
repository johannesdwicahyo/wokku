<%
  ee_nav_items = [
    { name: "Billing", path: dashboard_billing_path, pattern: "billing", icon_path: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" },
  ]
%>

<% ee_nav_items.each do |item| %>
  <%
    active = request.path.include?(item[:pattern])
    classes = active ?
      "flex items-center space-x-2.5 px-3 py-2 text-white bg-[#1E293B] rounded-md text-sm cursor-pointer" :
      "flex items-center space-x-2.5 px-3 py-2 text-gray-500 hover:text-gray-200 hover:bg-[#1E293B]/50 rounded-md text-sm cursor-pointer transition"
  %>
  <a href="<%= item[:path] %>" class="<%= classes %>">
    <svg class="w-4 h-4 flex-shrink-0 <%= active ? 'text-green-400' : '' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= item[:icon_path] %>"/>
    </svg>
    <span class="font-medium"><%= item[:name] %></span>
  </a>
<% end %>
