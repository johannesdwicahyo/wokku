<nav class="bg-[#0B1120] border-b border-[#1E293B] px-4 py-2.5 flex items-center justify-between">
  <div class="flex items-center space-x-6">
    <a href="<%= root_path %>" class="flex items-center space-x-2 cursor-pointer">
      <div class="w-6 h-6 bg-green-500 rounded flex items-center justify-center">
        <svg class="w-3.5 h-3.5 text-[#0B1120]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
      <span class="text-base font-semibold text-white tracking-tight">wokku</span>
    </a>

    <% if user_teams.any? %>
      <div class="relative" data-controller="dropdown">
        <button data-action="click->dropdown#toggle" class="flex items-center space-x-2 text-gray-400 hover:text-white text-sm bg-[#1E293B] rounded-md px-2.5 py-1 border border-[#334155] transition cursor-pointer">
          <span class="font-mono text-xs"><%= current_team&.name || "Select Team" %></span>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div data-dropdown-target="menu" class="hidden absolute left-0 mt-1 w-48 bg-[#1E293B] rounded-md shadow-xl border border-[#334155] z-50">
          <% user_teams.each do |team| %>
            <a href="<%= root_path(team_id: team.id) %>" class="block px-3 py-2 text-sm text-gray-300 hover:bg-[#334155] hover:text-white first:rounded-t-md last:rounded-b-md cursor-pointer transition">
              <%= team.name %>
            </a>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="relative" data-controller="dropdown">
    <button data-action="click->dropdown#toggle" class="flex items-center space-x-2 text-gray-400 hover:text-white text-sm transition cursor-pointer">
      <div class="w-7 h-7 bg-[#334155] rounded-md flex items-center justify-center text-green-400 text-xs font-mono font-semibold">
        <%= current_user.email[0].upcase %>
      </div>
      <span class="hidden md:inline text-xs font-mono text-gray-400"><%= current_user.email %></span>
    </button>
    <div data-dropdown-target="menu" class="hidden absolute right-0 mt-1 w-56 bg-[#1E293B] rounded-md shadow-xl border border-[#334155] z-50">
      <div class="px-3 py-2.5 border-b border-[#334155]">
        <p class="text-xs text-white font-medium truncate"><%= current_user.email %></p>
        <p class="text-xs text-gray-500 font-mono mt-0.5"><%= current_user.role %></p>
      </div>
      <a href="<%= dashboard_profile_path %>" class="block px-3 py-2 text-sm text-gray-300 hover:bg-[#334155] hover:text-white cursor-pointer transition">Profile</a>
      <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "block px-3 py-2 text-sm text-gray-300 hover:bg-[#334155] hover:text-white rounded-b-md cursor-pointer transition" %>
    </div>
  </div>
</nav>
