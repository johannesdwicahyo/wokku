<nav class="bg-[#1a1a2e] border-b border-[#2d2d4a] px-4 py-3 flex items-center justify-between">
  <div class="flex items-center space-x-6">
    <%# Logo %>
    <a href="<%= root_path %>" class="flex items-center space-x-2">
      <span class="text-xl font-bold text-white tracking-tight">Wokku</span>
    </a>

    <%# Team Selector %>
    <% if user_teams.any? %>
      <div class="relative" data-controller="dropdown">
        <button data-action="click->dropdown#toggle" class="flex items-center space-x-2 text-gray-300 hover:text-white text-sm bg-[#2d2d4a] rounded-lg px-3 py-1.5 transition">
          <span><%= current_team&.name || "Select Team" %></span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div data-dropdown-target="menu" class="hidden absolute left-0 mt-2 w-48 bg-[#2d2d4a] rounded-lg shadow-lg border border-[#3d3d5c] z-50">
          <% user_teams.each do |team| %>
            <a href="<%= root_path(team_id: team.id) %>" class="block px-4 py-2 text-sm text-gray-300 hover:bg-[#3d3d5c] hover:text-white first:rounded-t-lg last:rounded-b-lg">
              <%= team.name %>
            </a>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# User Menu %>
  <div class="relative" data-controller="dropdown">
    <button data-action="click->dropdown#toggle" class="flex items-center space-x-2 text-gray-300 hover:text-white text-sm transition">
      <div class="w-8 h-8 bg-purple-600 rounded-full flex items-center justify-center text-white text-sm font-medium">
        <%= current_user.email[0].upcase %>
      </div>
      <span class="hidden md:inline"><%= current_user.email %></span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    </button>
    <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-56 bg-[#2d2d4a] rounded-lg shadow-lg border border-[#3d3d5c] z-50">
      <div class="px-4 py-3 border-b border-[#3d3d5c]">
        <p class="text-sm text-white font-medium truncate"><%= current_user.email %></p>
      </div>
      <a href="<%= dashboard_profile_path %>" class="block px-4 py-2 text-sm text-gray-300 hover:bg-[#3d3d5c] hover:text-white">Profile</a>
      <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "block px-4 py-2 text-sm text-gray-300 hover:bg-[#3d3d5c] hover:text-white rounded-b-lg" %>
    </div>
  </div>
</nav>
