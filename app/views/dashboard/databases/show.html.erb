<div class="mb-4">
  <%= link_to "← Add-ons", dashboard_addons_path, class: "text-sm text-outline hover:text-on-surface transition" %>
</div>

<div class="flex items-start justify-between mb-8">
  <div>
    <div class="flex items-center gap-3 mb-1">
      <h1 class="text-2xl font-headline text-on-surface"><%= @database.name %></h1>
      <span class="text-xs text-outline capitalize"><%= @database.service_type %></span>
      <%# Status only when non-running %>
      <% case @database.status %>
      <% when "stopped" %>
        <span class="text-xs text-outline">Stopped</span>
      <% when "error" %>
        <span class="text-xs text-error">Error</span>
      <% end %>
    </div>
    <p class="text-sm text-outline">On <%= @database.server.name %> · <%= @linked_apps.size %> linked app<%= @linked_apps.size == 1 ? '' : 's' %></p>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to dashboard_addon_backups_path(@database), class: "inline-flex items-center px-3 py-1.5 text-on-surface-variant text-sm font-medium border border-outline-variant/30 rounded-md hover:bg-surface-container-high transition" do %>
      <%= t("dashboard.databases.backups") %>
    <% end %>
    <%= button_to "Delete", dashboard_addon_path(@database),
          method: :delete,
          form: {
            data: {
              controller: "confirm-delete",
              confirm_delete_name_value: @database.name,
              confirm_delete_impact_value: "This will permanently delete the #{@database.service_type} database #{@database.name} and ALL its data. Existing backups will remain in your backup destination until they expire.",
              confirm_delete_resource_value: "database"
            }
          },
          class: "text-sm font-medium text-error border border-error/30 hover:bg-error-container/10 px-3 py-1.5 rounded-md transition bg-transparent cursor-pointer" %>
  </div>
</div>

<% if @database.over_quota? %>
  <%
    cap_gb = (@database.service_tier&.spec || {})["storage_gb"].to_i
    used_mb = @database.live_db_bytes ? (@database.live_db_bytes.to_f / 1.megabyte).round(1) : nil
    grace_left = ((@database.over_quota_at + 24.hours) - Time.current) / 1.hour
  %>
  <div class="mb-6 rounded-lg bg-error-container/15 border border-error/30 px-5 py-4">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-sm font-semibold text-error mb-1">Storage quota reached</p>
        <p class="text-xs text-on-surface-variant">
          Using <%= used_mb %> MB of <%= cap_gb %> GB allowed on the <%= @database.tier_name %> plan.
          <% if grace_left > 0 %>
            Database stays writable for ~<%= grace_left.round %>h before it's flagged stopped.
          <% else %>
            Database has been flagged stopped — upgrade to restore service.
          <% end %>
        </p>
      </div>
      <%= link_to "Upgrade plan", "#change-plan", class: "px-3 py-1.5 text-xs font-semibold bg-primary text-on-primary rounded-md hover:opacity-90 transition flex-shrink-0" %>
    </div>
  </div>
<% end %>

<%# Current Plan + Usage %>
<div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-8">
  <%# Current tier card %>
  <div class="bg-surface-container-low rounded-lg p-5">
    <div class="flex items-baseline justify-between mb-3">
      <p class="text-xs text-outline uppercase tracking-wider font-medium">Current Plan</p>
      <% if @current_tier %>
        <span class="text-xs text-on-surface-variant"><%= format_price(@current_tier.monthly_price_dollars) %>/bln</span>
      <% end %>
    </div>
    <p class="text-2xl font-semibold text-on-surface font-headline mb-3"><%= @current_tier&.name&.capitalize || "—" %></p>
    <% if (spec = @current_tier&.spec) %>
      <div class="grid grid-cols-3 gap-2 text-xs">
        <div>
          <p class="text-outline">RAM</p>
          <p class="text-on-surface-variant"><%= spec["memory_mb"] || "—" %> MB</p>
        </div>
        <div>
          <p class="text-outline">Storage</p>
          <p class="text-on-surface-variant"><%= spec["storage_gb"] || "—" %> GB</p>
        </div>
        <div>
          <p class="text-outline">Connections</p>
          <p class="text-on-surface-variant"><%= spec["connections"] || "—" %></p>
        </div>
      </div>
    <% end %>
  </div>

  <%# Usage card %>
  <%
    spec = @current_tier&.spec || {}
    storage_gb = spec["storage_gb"].to_i
    ram_cap_mb = spec["memory_mb"].to_i
    used_bytes = @usage[:db_bytes]
    used_mb = used_bytes ? (used_bytes.to_f / 1.megabyte).round(1) : nil
    storage_pct = (used_bytes && storage_gb.positive?) ? [(used_bytes.to_f / (storage_gb * 1.gigabyte) * 100).round(1), 100].min : nil
    ram_bytes = @usage[:ram_bytes]
    ram_used_mb = ram_bytes ? (ram_bytes.to_f / 1.megabyte).round(1) : nil
    ram_pct = (ram_used_mb && ram_cap_mb.positive?) ? [(ram_used_mb / ram_cap_mb * 100).round(1), 100].min : nil
  %>
  <div class="bg-surface-container-low rounded-lg p-5">
    <p class="text-xs text-outline uppercase tracking-wider font-medium mb-3">Usage</p>

    <div class="space-y-3">
      <div>
        <div class="flex items-baseline justify-between mb-1">
          <span class="text-xs text-outline">Storage</span>
          <span class="text-xs text-on-surface-variant"><%= used_mb ? "#{used_mb} MB" : "—" %><% if storage_pct %> · <%= storage_pct %>% of <%= storage_gb %> GB<% end %></span>
        </div>
        <% if storage_pct %>
          <div class="w-full h-1 bg-surface-container rounded-full overflow-hidden">
            <div class="h-full <%= storage_pct >= 90 ? "bg-error" : storage_pct >= 75 ? "bg-tertiary" : "bg-primary" %>" style="width: <%= storage_pct %>%"></div>
          </div>
        <% end %>
      </div>

      <div>
        <div class="flex items-baseline justify-between mb-1">
          <span class="text-xs text-outline">RAM</span>
          <span class="text-xs text-on-surface-variant"><%= ram_used_mb ? "#{ram_used_mb} MB" : "—" %><% if ram_pct %> · <%= ram_pct %>% of <%= ram_cap_mb %> MB<% end %></span>
        </div>
        <% if ram_pct %>
          <div class="w-full h-1 bg-surface-container rounded-full overflow-hidden">
            <div class="h-full <%= ram_pct >= 90 ? "bg-error" : ram_pct >= 75 ? "bg-tertiary" : "bg-primary" %>" style="width: <%= ram_pct %>%"></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# Tier Picker (dedicated only) %>
<% unless @database.shared? %>
  <div class="mb-8">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="text-base font-semibold text-on-surface">Change Plan</h2>
      <p class="text-xs text-outline">RAM updates live · connection-cap changes restart the database (~5s)</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <% @available_tiers.each do |tier| %>
        <% spec = tier.spec || {} %>
        <% is_current = tier.name == @current_tier&.name %>
        <div class="bg-surface-container-low rounded-lg p-5 <%= "ring-1 ring-primary/40" if is_current %>">
          <div class="flex items-center justify-between mb-1">
            <h3 class="text-base font-semibold text-on-surface capitalize"><%= tier.name %></h3>
            <% if is_current %>
              <span class="text-[10px] font-bold uppercase tracking-wider text-primary">Current</span>
            <% end %>
          </div>
          <p class="text-sm text-on-surface-variant mb-4"><%= format_price(tier.monthly_price_dollars) %>/bln</p>
          <ul class="text-xs text-outline space-y-1 mb-4">
            <li><span class="text-on-surface-variant"><%= spec["memory_mb"] %> MB</span> RAM</li>
            <li><span class="text-on-surface-variant"><%= spec["storage_gb"] %> GB</span> storage</li>
            <li><span class="text-on-surface-variant"><%= spec["connections"] %></span> max connections</li>
            <li><%= spec["backups"] %><% if spec["backup_retention"] %> · <%= spec["backup_retention"] %> retained<% end %></li>
          </ul>
          <% unless is_current %>
            <%= button_to change_tier_dashboard_addon_path(@database, tier_name: tier.name), method: :post, data: { turbo_confirm: "Change #{@database.name} to #{tier.name}? This will briefly restart the database." }, class: "w-full px-3 py-1.5 bg-primary text-on-primary text-xs font-semibold rounded-md hover:opacity-90 transition cursor-pointer" do %>
              <%= tier.monthly_price_cents > (@current_tier&.monthly_price_cents || 0) ? "Upgrade" : "Downgrade" %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Linked Apps %>
<div class="mb-8" data-controller="slide-panel">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-base font-semibold text-on-surface"><%= t("dashboard.databases.linked_apps") %></h2>
    <% if @available_apps.any? %>
      <button data-action="click->slide-panel#open" class="text-sm text-primary hover:underline cursor-pointer">+ Link app</button>
    <% end %>
  </div>

  <div class="bg-surface-container-low rounded-lg overflow-hidden">
    <% if @linked_apps.any? %>
      <div class="divide-y divide-outline-variant/10">
        <% @linked_apps.each do |app| %>
          <div class="flex items-center justify-between px-5 py-3">
            <%= link_to app.name, dashboard_app_path(app), class: "text-sm text-on-surface hover:text-primary transition" %>
            <%= button_to "Unlink", unlink_dashboard_addon_path(@database, app_id: app.id), method: :post, data: { turbo_confirm: "Unlink #{app.name} from #{@database.name}?" }, class: "text-xs text-outline hover:text-error transition cursor-pointer bg-transparent border-0" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-5 py-8 text-center">
        <p class="text-sm text-outline">No apps linked yet.</p>
      </div>
    <% end %>
  </div>

  <% if @available_apps.any? %>
    <%= render layout: "dashboard/shared/slide_panel", locals: { title: "Link App", subtitle: "Connect an app to #{@database.name}" } do %>
      <%= form_with(url: link_dashboard_addon_path(@database), method: :post, class: "space-y-4") do %>
        <div>
          <label class="block text-xs font-semibold text-on-surface-variant mb-1.5 uppercase tracking-wider">Application</label>
          <%= combobox_tag "app_id", @available_apps.map { |a| { value: a.id, label: a.name, description: a.server.name } }, placeholder: "Search apps…", required: true %>
        </div>
        <div class="flex items-center gap-2">
          <%= submit_tag "Link App", class: "px-4 py-2.5 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer" %>
          <button type="button" data-action="click->slide-panel#close" class="px-4 py-2.5 text-sm font-medium text-on-surface-variant border border-outline-variant/30 rounded-md hover:bg-surface-container-high transition cursor-pointer">Cancel</button>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>

<%# Connection Info — collapsed-feel, less prominent %>
<% if @info.any? %>
  <details class="bg-surface-container-low rounded-lg overflow-hidden">
    <summary class="px-5 py-3 cursor-pointer text-sm font-medium text-on-surface-variant hover:text-on-surface flex items-center justify-between">
      <span><%= t("dashboard.databases.connection_info") %></span>
      <span class="text-xs text-outline">Show</span>
    </summary>
    <div class="divide-y divide-outline-variant/10 border-t border-outline-variant/10">
      <% @info.each do |key, value| %>
        <% next if value.blank? %>
        <div class="px-5 py-2.5 flex items-center justify-between">
          <span class="text-xs text-outline"><%= key.humanize %></span>
          <span class="text-xs text-on-surface-variant font-mono truncate ml-4 max-w-md text-right"><%= value %></span>
        </div>
      <% end %>
    </div>
  </details>
<% end %>
