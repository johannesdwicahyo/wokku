<div class="mb-6">
  <div class="flex items-center space-x-3 mb-1">
    <%= link_to "Databases", dashboard_databases_path, class: "text-sm text-gray-500 hover:text-green-400 transition" %>
    <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <span class="text-sm text-white font-medium font-mono"><%= @database.name %></span>
  </div>
</div>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center space-x-4">
    <h1 class="text-2xl font-bold text-white font-mono"><%= @database.name %></h1>
    <span class="text-sm text-gray-400 font-mono"><%= @database.service_type %></span>
  </div>
  <%= link_to "Delete", dashboard_database_path(@database), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "text-sm text-red-400/70 hover:text-red-400 font-medium transition" %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 p-5">
    <p class="text-xs text-gray-400 uppercase tracking-wider">Server</p>
    <p class="mt-1 text-lg font-semibold text-white font-mono"><%= @database.server.name %></p>
  </div>
  <div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 p-5">
    <p class="text-xs text-gray-400 uppercase tracking-wider">Type</p>
    <p class="mt-1 text-lg font-semibold text-white font-mono"><%= @database.service_type.capitalize %></p>
  </div>
  <div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 p-5">
    <p class="text-xs text-gray-400 uppercase tracking-wider">Linked Apps</p>
    <p class="mt-1 text-lg font-semibold text-white"><%= @database.app_records.size %></p>
  </div>
</div>
