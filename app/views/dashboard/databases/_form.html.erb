<%= form_with(model: database, url: dashboard_resources_path, class: "space-y-4") do |f| %>
  <% if database.errors.any? %>
    <div class="rounded-md bg-error-container/20 border border-error/20 p-3">
      <ul class="text-xs text-error space-y-1">
        <% database.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-xs font-medium text-on-surface-variant mb-1.5 uppercase tracking-wider" %>
    <%= f.text_field :name, class: "w-full rounded-md bg-surface border border-outline-variant/15 px-3 py-2 text-sm text-on-surface placeholder-outline-variant focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary font-mono", placeholder: "my-database" %>
  </div>

  <div>
    <%= f.label :service_type, "Service Type", class: "block text-xs font-medium text-on-surface-variant mb-1.5 uppercase tracking-wider" %>
    <%= f.select :service_type, [["PostgreSQL", "postgres"], ["Redis", "redis"], ["MySQL", "mysql"], ["MongoDB", "mongodb"], ["Memcached", "memcached"], ["RabbitMQ", "rabbitmq"], ["Elasticsearch", "elasticsearch"], ["MariaDB", "mariadb"], ["MinIO", "minio"]], { prompt: "Select a service type" }, class: "w-full rounded-md bg-surface border border-outline-variant/15 px-3 py-2 text-sm text-on-surface placeholder-outline-variant focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary" %>
  </div>

  <div>
    <%= f.label :server_id, "Server", class: "block text-xs font-medium text-on-surface-variant mb-1.5 uppercase tracking-wider" %>
    <%= f.collection_select :server_id, servers, :id, :name, { prompt: "Select a server" }, class: "w-full rounded-md bg-surface border border-outline-variant/15 px-3 py-2 text-sm text-on-surface placeholder-outline-variant focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary" %>
  </div>

  <div class="flex items-center space-x-3 pt-2">
    <%= f.submit "Create Database", class: "flex-1 py-2 px-4 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer text-center" %>
    <button type="button" data-action="click->slide-panel#close" class="py-2 px-4 text-sm text-on-surface-variant hover:text-on-surface transition cursor-pointer">Cancel</button>
  </div>
<% end %>
