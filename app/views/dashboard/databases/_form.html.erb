<%= form_with(model: database, url: dashboard_databases_path, class: "space-y-4") do |f| %>
  <% if database.errors.any? %>
    <div class="rounded-md bg-red-500/10 border border-red-500/20 p-3">
      <ul class="text-xs text-red-400 space-y-1">
        <% database.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider" %>
    <%= f.text_field :name, class: "w-full rounded-md bg-[#0B1120] border border-[#334155] px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-green-500 font-mono", placeholder: "my-database" %>
  </div>

  <div>
    <%= f.label :service_type, "Service Type", class: "block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider" %>
    <%= f.select :service_type, [["PostgreSQL", "postgres"], ["MySQL", "mysql"], ["MariaDB", "mariadb"], ["MongoDB", "mongodb"], ["Redis", "redis"], ["Memcached", "memcached"], ["RabbitMQ", "rabbitmq"], ["Elasticsearch", "elasticsearch"]], { prompt: "Select a service type" }, class: "w-full rounded-md bg-[#0B1120] border border-[#334155] px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-green-500" %>
  </div>

  <div>
    <%= f.label :server_id, "Server", class: "block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider" %>
    <%= f.collection_select :server_id, servers, :id, :name, { prompt: "Select a server" }, class: "w-full rounded-md bg-[#0B1120] border border-[#334155] px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-green-500" %>
  </div>

  <div class="flex items-center space-x-3 pt-2">
    <%= f.submit "Create Database", class: "flex-1 py-2 px-4 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer text-center" %>
    <button type="button" data-action="click->slide-panel#close" class="py-2 px-4 text-sm text-gray-400 hover:text-white transition cursor-pointer">Cancel</button>
  </div>
<% end %>
