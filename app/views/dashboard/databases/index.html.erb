<div data-controller="slide-panel">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Databases</h1>
      <p class="mt-1 text-sm text-gray-500">Manage your database services</p>
    </div>
    <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Database
    </button>
  </div>

  <% if @databases.any? %>
    <div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 overflow-hidden">
      <table class="min-w-full divide-y divide-[#334155]/50">
        <thead>
          <tr>
            <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider">Type</th>
            <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider">Server</th>
            <th class="px-6 py-3 text-left text-xs text-gray-400 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[#334155]/50">
          <% @databases.each do |db| %>
            <tr class="hover:bg-[#334155]/20 transition">
              <td class="px-6 py-4">
                <%= link_to db.name, dashboard_database_path(db), class: "text-sm font-medium font-mono text-green-400 hover:text-green-300" %>
              </td>
              <td class="px-6 py-4">
                <span class="text-sm text-gray-400 font-mono"><%= db.service_type %></span>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500 font-mono"><%= db.server.name %></td>
              <td class="px-6 py-4">
                <% case db.status %>
                <% when "running" %>
                  <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-green-400"></span><span class="text-xs text-gray-400">Running</span></span>
                <% when "stopped" %>
                  <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-gray-500"></span><span class="text-xs text-gray-400">Stopped</span></span>
                <% when "creating" %>
                  <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-yellow-500 animate-pulse"></span><span class="text-xs text-gray-400">Creating</span></span>
                <% when "error" %>
                  <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-red-400"></span><span class="text-xs text-gray-400">Error</span></span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-right">
                <%= link_to "View", dashboard_database_path(db), class: "text-sm text-green-400 hover:text-green-300" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-16 bg-[#1E293B]/60 rounded-xl border border-[#334155]/50">
      <svg class="mx-auto h-12 w-12 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>
      <h3 class="mt-4 text-lg font-medium text-white">No databases yet</h3>
      <p class="mt-2 text-sm text-gray-500">Provision your first database service.</p>
      <div class="mt-6">
        <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer">New Database</button>
      </div>
    </div>
  <% end %>

  <%= render layout: "dashboard/shared/slide_panel", locals: { title: "New Database", subtitle: "Provision a database service" } do %>
    <%= render "form", database: @database, servers: @servers %>
  <% end %>
</div>
