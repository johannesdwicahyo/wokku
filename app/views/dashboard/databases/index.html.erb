<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Databases</h1>
    <p class="mt-1 text-sm text-gray-500">Manage your database services</p>
  </div>
  <%= link_to new_dashboard_database_path, class: "inline-flex items-center px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 transition shadow-sm" do %>
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    New Database
  <% end %>
</div>

<% if @databases.any? %>
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Server</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @databases.each do |db| %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-6 py-4">
              <%= link_to db.name, dashboard_database_path(db), class: "text-sm font-medium text-purple-600 hover:text-purple-800" %>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800"><%= db.service_type %></span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500"><%= db.server.name %></td>
            <td class="px-6 py-4">
              <% case db.status %>
              <% when "running" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Running</span>
              <% when "stopped" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Stopped</span>
              <% when "creating" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Creating</span>
              <% when "error" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Error</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-right">
              <%= link_to "View", dashboard_database_path(db), class: "text-sm text-purple-600 hover:text-purple-800" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="text-center py-16 bg-white rounded-xl border border-gray-200">
    <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/></svg>
    <h3 class="mt-4 text-lg font-medium text-gray-900">No databases yet</h3>
    <p class="mt-2 text-sm text-gray-500">Provision your first database service.</p>
    <div class="mt-6">
      <%= link_to "New Database", new_dashboard_database_path, class: "inline-flex items-center px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 transition" %>
    </div>
  </div>
<% end %>
