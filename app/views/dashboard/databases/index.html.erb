<div data-controller="slide-panel">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-on-surface font-headline"><%= t("dashboard.nav.addons") %></h1>
    <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">
      New Add-on
    </button>
  </div>

  <% if @databases.any? %>
    <%# Group toggle %>
    <div class="flex items-center gap-1 mb-6">
      <%= link_to "By type", dashboard_addons_path(group: "type"), class: "px-3 py-1.5 text-xs font-medium rounded-md transition #{@group_by == 'type' ? 'bg-surface-container-high text-on-surface' : 'text-outline hover:text-on-surface-variant'}" %>
      <%= link_to "By app", dashboard_addons_path(group: "app"), class: "px-3 py-1.5 text-xs font-medium rounded-md transition #{@group_by == 'app' ? 'bg-surface-container-high text-on-surface' : 'text-outline hover:text-on-surface-variant'}" %>
    </div>

    <% if @group_by == "type" %>
      <div class="space-y-6">
        <% @by_type.each do |type, resources| %>
          <div>
            <div class="flex items-baseline gap-2 mb-2 px-1">
              <h3 class="text-sm font-semibold text-on-surface capitalize"><%= type %></h3>
              <span class="text-xs text-outline"><%= resources.size %></span>
            </div>
            <div class="bg-surface-container-low rounded-lg divide-y divide-outline-variant/10 overflow-hidden">
              <% resources.each do |db| %>
                <%= link_to dashboard_addon_path(db), class: "flex items-center justify-between px-5 py-3 hover:bg-surface-container transition" do %>
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-on-surface truncate"><%= db.name %></p>
                    <div class="flex items-center gap-2 mt-0.5 text-xs text-outline">
                      <% db.app_records.each do |app| %>
                        <span><%= app.name %></span>
                      <% end %>
                      <% if db.app_records.empty? %>
                        <span>Not linked</span>
                      <% end %>
                    </div>
                  </div>
                  <% case db.status %>
                  <% when "error" %>
                    <span class="text-xs text-error font-medium">Error</span>
                  <% when "stopped" %>
                    <span class="text-xs text-outline">Stopped</span>
                  <% when "creating" %>
                    <span class="text-xs text-tertiary">Creating…</span>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="space-y-6">
        <% @by_app.each do |app_name, resources| %>
          <div>
            <div class="flex items-baseline gap-2 mb-2 px-1">
              <h3 class="text-sm font-semibold text-on-surface"><%= app_name %></h3>
              <span class="text-xs text-outline"><%= resources.size %> add-on<%= resources.size == 1 ? '' : 's' %></span>
            </div>
            <div class="bg-surface-container-low rounded-lg divide-y divide-outline-variant/10 overflow-hidden">
              <% resources.each do |db| %>
                <%= link_to dashboard_addon_path(db), class: "flex items-center justify-between px-5 py-3 hover:bg-surface-container transition" do %>
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-on-surface truncate"><%= db.name %></p>
                    <p class="text-xs text-outline mt-0.5 capitalize"><%= db.service_type %></p>
                  </div>
                  <% if db.status != "running" %>
                    <span class="text-xs text-outline capitalize"><%= db.status %></span>
                  <% end %>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

  <% else %>
    <div class="bg-surface-container-low rounded-lg p-16 text-center">
      <h3 class="text-lg font-semibold text-on-surface font-headline"><%= t("dashboard.databases.no_databases") %></h3>
      <p class="text-sm text-outline mt-2">Add databases, caches, and services for your apps.</p>
      <div class="mt-6">
        <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">New Add-on</button>
      </div>
    </div>
  <% end %>

  <%= render layout: "dashboard/shared/slide_panel", locals: { title: "New Add-on", subtitle: "Provision a database or service" } do %>
    <%= render "form", database: @database, apps: @apps, tiers_by_type: @tiers_by_type %>
  <% end %>
</div>
