<div data-controller="slide-panel">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-headline text-on-surface">Databases</h1>
      <p class="mt-1 text-sm text-outline">Manage your database services</p>
    </div>
    <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">
      <span class="material-symbols-outlined text-[18px] mr-1.5">add</span>
      New Database
    </button>
  </div>

  <% if @databases.any? %>
    <div class="bg-surface-container-low rounded-xl border border-outline-variant/15 overflow-hidden">
      <table class="min-w-full divide-y divide-outline-variant/15">
        <thead class="bg-surface-container-highest">
          <tr>
            <th class="px-6 py-3 text-left text-xs text-outline uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs text-outline uppercase tracking-wider">Type</th>
            <th class="px-6 py-3 text-left text-xs text-outline uppercase tracking-wider">Server</th>
            <th class="px-6 py-3 text-left text-xs text-outline uppercase tracking-wider">Status</th>
            <th class="px-6 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/15">
          <% @databases.each do |db| %>
            <tr class="hover:bg-surface-container-highest transition">
              <td class="px-6 py-4">
                <%= link_to db.name, dashboard_database_path(db), class: "text-sm font-medium font-mono text-primary hover:text-primary" %>
              </td>
              <td class="px-6 py-4">
                <span class="text-sm text-on-surface-variant font-mono"><%= db.service_type %></span>
              </td>
              <td class="px-6 py-4 text-sm text-outline font-mono"><%= db.server.name %></td>
              <td class="px-6 py-4">
                <% case db.status %>
                <% when "running" %>
                  <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-primary"></span><span class="text-xs text-on-surface-variant">Running</span></span>
                <% when "stopped" %>
                  <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-outline"></span><span class="text-xs text-on-surface-variant">Stopped</span></span>
                <% when "creating" %>
                  <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-yellow-500 animate-pulse"></span><span class="text-xs text-on-surface-variant">Creating</span></span>
                <% when "error" %>
                  <span class="flex items-center space-x-1.5"><span class="w-2 h-2 rounded-full bg-error"></span><span class="text-xs text-on-surface-variant">Error</span></span>
                <% end %>
              </td>
              <td class="px-6 py-4 text-right">
                <%= link_to "View", dashboard_database_path(db), class: "text-sm text-primary hover:text-primary" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-16 bg-surface-container-low rounded-xl border border-outline-variant/15">
      <span class="material-symbols-outlined text-[48px] text-outline-variant mb-2">database</span>
      <h3 class="mt-4 text-lg font-medium text-on-surface">No databases yet</h3>
      <p class="mt-2 text-sm text-outline">Provision your first database service.</p>
      <div class="mt-6">
        <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">New Database</button>
      </div>
    </div>
  <% end %>

  <%= render layout: "dashboard/shared/slide_panel", locals: { title: "New Database", subtitle: "Provision a database service" } do %>
    <%= render "form", database: @database, servers: @servers %>
  <% end %>
</div>
