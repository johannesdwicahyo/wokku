<%= render "dashboard/apps/tabs", app: @app %>

<div class="bg-surface-container-low rounded-xl overflow-hidden" data-controller="log-viewer">
  <div class="px-6 py-4 border-b border-outline-variant/15 flex items-center justify-between">
    <div>
      <h2 class="text-base font-semibold text-on-surface font-headline">Application Logs</h2>
      <p class="text-sm text-outline mt-1">Recent logs for <span class="font-mono"><%= @app.name %></span></p>
    </div>
    <div class="flex items-center space-x-3">
      <a href="<%= dashboard_app_logs_path(@app) %>" data-turbo-action="replace" class="inline-flex items-center px-2.5 py-1 text-xs text-on-surface-variant border border-outline-variant/15 rounded-md hover:border-primary/50 hover:text-primary transition cursor-pointer">
        <span class="material-symbols-outlined text-[16px] mr-1">refresh</span>
        Refresh
      </a>
    </div>
  </div>

  <div class="px-6 py-3 flex items-center gap-3 border-b border-outline-variant/15">
    <div class="relative flex-1">
      <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[16px]">search</span>
      <input type="text" placeholder="Filter logs..." data-log-viewer-target="search" data-action="input->log-viewer#filter" class="w-full pl-9 pr-4 py-1.5 rounded-md bg-surface border-none text-xs text-on-surface placeholder-outline focus:ring-1 focus:ring-primary font-mono">
    </div>
    <%= link_to dashboard_app_logs_path(@app, lines: 50), class: "text-[10px] px-2 py-1 rounded #{(params[:lines] || '200') == '50' ? 'bg-primary text-on-primary' : 'bg-surface-container-high text-outline'}" do %>50<% end %>
    <%= link_to dashboard_app_logs_path(@app, lines: 100), class: "text-[10px] px-2 py-1 rounded #{(params[:lines] || '200') == '100' ? 'bg-primary text-on-primary' : 'bg-surface-container-high text-outline'}" do %>100<% end %>
    <%= link_to dashboard_app_logs_path(@app, lines: 200), class: "text-[10px] px-2 py-1 rounded #{(params[:lines] || '200') == '200' ? 'bg-primary text-on-primary' : 'bg-surface-container-high text-outline'}" do %>200<% end %>
    <%= link_to dashboard_app_logs_path(@app, lines: 500), class: "text-[10px] px-2 py-1 rounded #{params[:lines] == '500' ? 'bg-primary text-on-primary' : 'bg-surface-container-high text-outline'}" do %>500<% end %>
  </div>

  <div class="bg-surface p-4 font-mono text-xs leading-5 h-[600px] overflow-y-auto" data-log-viewer-target="output">
    <% if @logs.present? %>
      <% @logs.each_line do |line| %>
        <div class="log-line <%= log_line_class(line) %> whitespace-pre-wrap break-all" data-log-viewer-target="line"><%= line.rstrip %></div>
      <% end %>
    <% else %>
      <p class="text-outline-variant">No logs available. The app may not have been deployed yet.</p>
    <% end %>
  </div>
</div>

<%# Log Drains Section %>
<div class="bg-surface-container-low rounded-xl overflow-hidden mt-6">
  <div class="px-6 py-4 border-b border-outline-variant/15">
    <h2 class="text-base font-semibold text-on-surface font-headline">Log Drains</h2>
    <p class="text-sm text-outline mt-1">Forward application logs to an external service</p>
  </div>

  <% if @log_drains.any? %>
    <div class="divide-y divide-outline-variant/15">
      <% @log_drains.each do |drain| %>
        <div class="px-6 py-3 flex items-center justify-between hover:bg-surface-container-high/30">
          <div class="flex items-center space-x-3">
            <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-secondary-container/20 border border-primary/20">
              <span class="material-symbols-outlined text-primary text-[18px]">output</span>
            </div>
            <div>
              <span class="text-sm font-medium text-on-surface font-mono"><%= drain.url %></span>
              <div class="text-xs text-outline mt-0.5">Type: <%= drain.drain_type %></div>
            </div>
          </div>
          <%= link_to "Remove", dashboard_app_log_drain_path(@app, drain),
                data: { turbo_method: :delete, turbo_confirm: "Remove this log drain?" },
                class: "text-xs text-error/70 hover:text-error transition" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="px-6 py-8 text-center">
      <p class="text-sm text-outline">No log drains configured.</p>
    </div>
  <% end %>
</div>

<%# Add Log Drain %>
<div class="bg-surface-container-low rounded-xl p-6 mt-6">
  <h3 class="text-sm font-semibold text-on-surface font-headline mb-1">Add Log Drain</h3>
  <p class="text-xs text-outline mb-4">Forward logs to a syslog or HTTP endpoint. Example: <span class="font-mono text-on-surface-variant">syslog://logs.example.com:514</span></p>
  <%= form_with(model: LogDrain.new, url: dashboard_app_log_drains_path(@app), class: "flex items-end space-x-3") do |f| %>
    <div class="flex-1">
      <%= f.label :url, "Drain URL", class: "block text-[10px] text-outline uppercase tracking-wider font-bold mb-1" %>
      <%= f.text_field :url, class: "w-full rounded-md bg-surface border-outline-variant/15 text-on-surface font-mono text-sm focus:ring-primary focus:border-primary", placeholder: "syslog://logs.example.com:514" %>
    </div>
    <div>
      <%= f.label :drain_type, "Type", class: "block text-[10px] text-outline uppercase tracking-wider font-bold mb-1" %>
      <%= f.select :drain_type, [["Syslog", "syslog"], ["HTTPS", "https"]], {}, class: "rounded-md bg-surface border-outline-variant/15 text-on-surface text-sm focus:ring-primary focus:border-primary" %>
    </div>
    <%= f.submit "Add Drain", class: "px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer" %>
  <% end %>
</div>

