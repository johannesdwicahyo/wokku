<%= render "dashboard/apps/tabs", app: @app %>

<div class="bg-surface-container-low rounded-xl overflow-hidden">
  <div class="px-6 py-4 border-b border-outline-variant/15 flex items-center justify-between">
    <div>
      <h2 class="text-base font-semibold text-on-surface font-headline">Application Logs</h2>
      <p class="text-sm text-outline mt-1">Recent logs for <span class="font-mono"><%= @app.name %></span></p>
    </div>
    <div class="flex items-center space-x-3">
      <a href="<%= dashboard_app_logs_path(@app) %>" data-turbo-action="replace" class="inline-flex items-center px-2.5 py-1 text-xs text-on-surface-variant border border-outline-variant/15 rounded-md hover:border-primary/50 hover:text-primary transition cursor-pointer">
        <span class="material-symbols-outlined text-[16px] mr-1">refresh</span>
        Refresh
      </a>
    </div>
  </div>

  <div class="px-6 py-3 flex items-center gap-3 border-b border-outline-variant/15">
    <div class="relative flex-1">
      <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[16px]">search</span>
      <input type="text" id="log-search" placeholder="Filter logs..." oninput="filterLogs(this.value)" class="w-full pl-9 pr-4 py-1.5 rounded-md bg-surface border-none text-xs text-on-surface placeholder-outline focus:ring-1 focus:ring-primary font-mono">
    </div>
    <%= link_to dashboard_app_logs_path(@app, lines: 50), class: "text-[10px] px-2 py-1 rounded #{(params[:lines] || '200') == '50' ? 'bg-primary text-on-primary' : 'bg-surface-container-high text-outline'}" do %>50<% end %>
    <%= link_to dashboard_app_logs_path(@app, lines: 100), class: "text-[10px] px-2 py-1 rounded #{(params[:lines] || '200') == '100' ? 'bg-primary text-on-primary' : 'bg-surface-container-high text-outline'}" do %>100<% end %>
    <%= link_to dashboard_app_logs_path(@app, lines: 200), class: "text-[10px] px-2 py-1 rounded #{(params[:lines] || '200') == '200' ? 'bg-primary text-on-primary' : 'bg-surface-container-high text-outline'}" do %>200<% end %>
    <%= link_to dashboard_app_logs_path(@app, lines: 500), class: "text-[10px] px-2 py-1 rounded #{params[:lines] == '500' ? 'bg-primary text-on-primary' : 'bg-surface-container-high text-outline'}" do %>500<% end %>
  </div>

  <div class="bg-surface p-4 font-mono text-xs leading-5 h-[600px] overflow-y-auto" id="log-output">
    <% if @logs.present? %>
      <% @logs.each_line do |line| %>
        <div class="log-line <%= log_line_class(line) %> whitespace-pre-wrap break-all"><%= line.rstrip %></div>
      <% end %>
    <% else %>
      <p class="text-outline-variant">No logs available. The app may not have been deployed yet.</p>
    <% end %>
  </div>
</div>

<script>
  function filterLogs(query) {
    const lines = document.querySelectorAll('.log-line');
    const q = query.toLowerCase();
    lines.forEach(line => {
      line.style.display = q === '' || line.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  }

  // Auto-scroll to bottom on load
  document.addEventListener("turbo:load", function() {
    const output = document.getElementById("log-output");
    if (output) output.scrollTop = output.scrollHeight;
  });
  const output = document.getElementById("log-output");
  if (output) output.scrollTop = output.scrollHeight;
</script>
