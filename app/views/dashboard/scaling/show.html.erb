<%= render "dashboard/apps/tabs", app: @app %>

<%# Container Size / Dyno Tier Selection %>
<% if @dyno_tiers.any? %>
  <div class="bg-surface-container-low rounded-md overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-outline-variant/15">
      <h2 class="text-base font-semibold text-on-surface font-headline">Container Size</h2>
      <p class="text-sm text-outline mt-1">Choose the resource allocation for your containers</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4 p-6">
      <% @dyno_tiers.each do |tier| %>
        <% is_current = @current_allocation&.dyno_tier_id == tier.id %>
        <div class="relative rounded-md p-4 transition <%= is_current ? 'bg-primary-container/20 border border-primary/30' : 'bg-surface border border-outline-variant/15 hover:border-outline' %>">
          <% if is_current %>
            <div class="absolute -top-2 right-3">
              <span class="text-[10px] font-bold uppercase tracking-wider technical-gradient text-on-primary px-2 py-0.5 rounded">Current</span>
            </div>
          <% end %>

          <h3 class="text-sm font-bold text-on-surface font-headline capitalize"><%= tier.name %></h3>
          <div class="mt-3 space-y-1.5">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary text-[14px]">memory</span>
              <span class="text-xs text-on-surface-variant"><span class="font-mono font-bold text-on-surface"><%= tier.memory_mb >= 1024 ? "#{tier.memory_mb / 1024} GB" : "#{tier.memory_mb} MB" %></span> RAM</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-secondary text-[14px]">speed</span>
              <span class="text-xs text-on-surface-variant"><span class="font-mono font-bold text-on-surface"><%= tier.cpu_shares %></span> vCPU</span>
            </div>
            <% if tier.respond_to?(:storage_mb) && tier.storage_mb > 0 %>
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-secondary text-[14px]">hard_drive</span>
                <span class="text-xs text-on-surface-variant"><span class="font-mono font-bold text-on-surface"><%= tier.storage_mb >= 1024 ? "#{tier.storage_mb / 1024} GB" : "#{tier.storage_mb} MB" %></span> storage</span>
              </div>
            <% end %>
            <% if tier.sleeps %>
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-tertiary text-[14px]">bedtime</span>
                <span class="text-xs text-tertiary">Sleeps after idle</span>
              </div>
            <% end %>
            <% if tier.respond_to?(:max_per_user) && tier.max_per_user.present? %>
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-outline text-[14px]">info</span>
                <span class="text-xs text-outline">Max <%= tier.max_per_user %> per user</span>
              </div>
            <% end %>
          </div>

          <div class="mt-4 pt-3 border-t border-outline-variant/15">
            <% if tier.free? %>
              <p class="text-lg font-bold text-on-surface font-headline">Free</p>
            <% else %>
              <p class="text-lg font-bold text-on-surface font-headline">$<%= "%.2f" % tier.monthly_price_dollars %><span class="text-xs text-outline font-normal">/mo</span></p>
            <% end %>
          </div>

          <% unless is_current %>
            <%= button_to is_current ? "" : ((@current_allocation && tier.memory_mb > @current_allocation.dyno_tier.memory_mb) ? "Upgrade" : "Select"),
                  change_tier_dashboard_app_scaling_path(@app),
                  params: { dyno_tier_id: tier.id, process_type: "web" },
                  method: :post,
                  data: { turbo_confirm: "Change to #{tier.name} (#{tier.memory_mb >= 1024 ? "#{tier.memory_mb / 1024}GB" : "#{tier.memory_mb}MB"}, #{tier.cpu_shares} vCPU) at $#{"%.2f" % tier.monthly_price_dollars}/mo?" },
                  class: "mt-3 w-full text-center px-3 py-1.5 text-xs font-semibold rounded-md #{@current_allocation && tier.memory_mb > @current_allocation.dyno_tier.memory_mb ? 'technical-gradient text-on-primary hover:opacity-90' : 'bg-surface-container-high text-on-surface-variant hover:text-on-surface'} transition cursor-pointer" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Pricing preview %>
    <% if @current_allocation %>
      <%
        tier = @current_allocation.dyno_tier
        total_dynos = @process_scales.any? ? @process_scales.sum(&:count) : 1
        monthly_cost = total_dynos * tier.monthly_price_dollars
      %>
      <div class="px-6 py-4 bg-surface/50 border-t border-outline-variant/10">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-6">
            <div class="flex items-center gap-2">
              <span class="text-xs text-outline">Container:</span>
              <span class="text-sm font-bold text-on-surface font-headline capitalize"><%= tier.name %></span>
              <span class="text-xs text-outline">(<%= tier.memory_mb >= 1024 ? "#{tier.memory_mb / 1024}GB" : "#{tier.memory_mb}MB" %>, <%= tier.cpu_shares %> vCPU)</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs text-outline">Dynos:</span>
              <% @process_scales.each do |ps| %>
                <span class="text-xs font-mono bg-surface-container-highest px-2 py-0.5 rounded"><%= ps.process_type %> × <%= ps.count %></span>
              <% end %>
              <span class="text-xs text-outline">= <%= total_dynos %> total</span>
            </div>
          </div>
          <div class="text-right">
            <span class="text-xs text-outline">Estimated cost:</span>
            <span class="text-sm font-bold text-primary font-mono ml-2">$<%= "%.2f" % monthly_cost %>/mo</span>
            <% if total_dynos > 1 %>
              <span class="text-[10px] text-outline ml-1">(<%= total_dynos %> × $<%= "%.2f" % tier.monthly_price_dollars %>)</span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<%# Process Scaling %>
<div class="bg-surface-container-low rounded-md overflow-hidden">
  <div class="px-6 py-4 border-b border-outline-variant/15">
    <h2 class="text-base font-semibold text-on-surface font-headline">Process Scaling</h2>
    <p class="text-sm text-outline mt-1">Scale the number of dynos for each process type</p>
  </div>

  <% if @process_scales.any? %>
    <%= form_with(url: dashboard_app_scaling_path(@app), method: :patch, class: "divide-y divide-outline-variant/15") do |f| %>
      <% @process_scales.each do |ps| %>
        <div class="px-6 py-5 flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-surface border border-outline-variant/15">
              <% if ps.process_type == "web" %>
                <span class="material-symbols-outlined text-primary">language</span>
              <% else %>
                <span class="material-symbols-outlined text-secondary">settings</span>
              <% end %>
            </div>
            <div>
              <span class="text-sm font-semibold text-on-surface font-mono"><%= ps.process_type %></span>
              <p class="text-xs text-outline mt-0.5">
                <% if ps.process_type == "web" %>
                  Handles HTTP requests
                <% elsif ps.process_type == "worker" %>
                  Processes background jobs
                <% else %>
                  Custom process type
                <% end %>
              </p>
            </div>
          </div>
          <div class="flex items-center space-x-3">
            <div class="flex items-center bg-surface border border-outline-variant/15 rounded-lg overflow-hidden" data-controller="counter">
              <button type="button" data-action="click->counter#decrement"
                      class="px-3 py-2 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high/50 transition cursor-pointer">
                <span class="material-symbols-outlined text-[18px]">remove</span>
              </button>
              <input type="number" name="scaling[<%= ps.process_type %>]" value="<%= ps.count %>"
                     min="0" max="10" data-counter-target="input"
                     class="w-12 text-center bg-transparent border-x border-outline-variant/15 text-on-surface font-mono text-sm py-2 focus:outline-none [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none">
              <button type="button" data-action="click->counter#increment"
                      class="px-3 py-2 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high/50 transition cursor-pointer">
                <span class="material-symbols-outlined text-[18px]">add</span>
              </button>
            </div>
            <span class="text-xs text-outline w-12"><%= ps.count == 1 ? "1 dyno" : "#{ps.count} dynos" %></span>
          </div>
        </div>
      <% end %>

      <div class="px-6 py-4 bg-surface/50">
        <%= f.submit "Apply Changes", class: "px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer" %>
      </div>
    <% end %>
  <% else %>
    <div class="px-6 py-8 text-center">
      <p class="text-sm text-outline">No process types found. Deploy the app first to see available processes.</p>
    </div>
  <% end %>
</div>
