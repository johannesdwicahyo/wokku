<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-xl font-semibold text-white">Billing</h1>
    <p class="mt-0.5 text-sm text-gray-500">Manage your subscription and usage</p>
  </div>
</div>

<%# Current Plan %>
<div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-[#334155]/50">
    <h2 class="text-base font-semibold text-white">Current Plan</h2>
  </div>
  <div class="p-6">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h3 class="text-2xl font-bold text-white"><%= @plan&.name || "Free" %></h3>
        <% if @plan&.free? %>
          <p class="text-sm text-gray-500 mt-1">You're on the free plan</p>
        <% elsif @subscription %>
          <p class="text-sm text-gray-500 mt-1">
            $<%= @plan.price_cents_per_month / 100 %>/month
            <% if @subscription.current_period_end %>
              · Renews <%= @subscription.current_period_end.strftime("%b %d, %Y") %>
            <% end %>
          </p>
        <% end %>
      </div>
      <% if @plan&.free? %>
        <span class="px-3 py-1 text-xs font-semibold text-green-400 bg-green-500/10 border border-green-500/20 rounded-full">Free</span>
      <% else %>
        <span class="px-3 py-1 text-xs font-semibold text-green-400 bg-green-500/10 border border-green-500/20 rounded-full capitalize"><%= @subscription&.status || "Active" %></span>
      <% end %>
    </div>

    <%# Usage %>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="bg-[#0B1120] rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs text-gray-500 uppercase tracking-wider">Apps</span>
          <span class="text-xs text-gray-400"><%= @app_count %> / <%= @plan&.max_apps || "∞" %></span>
        </div>
        <div class="h-2 bg-[#1E293B] rounded-full overflow-hidden">
          <% app_pct = @plan&.max_apps.to_i > 0 ? (@app_count.to_f / @plan.max_apps * 100) : 0 %>
          <div class="h-full bg-green-500 rounded-full" style="width: <%= [app_pct, 100].min %>%"></div>
        </div>
      </div>
      <div class="bg-[#0B1120] rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs text-gray-500 uppercase tracking-wider">Databases</span>
          <span class="text-xs text-gray-400"><%= @db_count %> / <%= @plan&.max_databases || "∞" %></span>
        </div>
        <div class="h-2 bg-[#1E293B] rounded-full overflow-hidden">
          <% db_pct = @plan&.max_databases.to_i > 0 ? (@db_count.to_f / @plan.max_databases * 100) : 0 %>
          <div class="h-full bg-green-500 rounded-full" style="width: <%= [db_pct, 100].min %>%"></div>
        </div>
      </div>
      <div class="bg-[#0B1120] rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs text-gray-500 uppercase tracking-wider">Dynos</span>
          <span class="text-xs text-gray-400"><%= @plan&.max_dynos || "∞" %> max</span>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Available Plans %>
<div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 overflow-hidden">
  <div class="px-6 py-4 border-b border-[#334155]/50">
    <h2 class="text-base font-semibold text-white">Available Plans</h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 p-6">
    <% @plans.each do |plan| %>
      <div class="bg-[#0B1120] rounded-xl border <%= plan == @plan ? 'border-green-500/50' : 'border-[#334155]' %> p-5 relative">
        <% if plan == @plan %>
          <span class="absolute top-3 right-3 px-2 py-0.5 text-[10px] font-semibold text-green-400 bg-green-500/10 border border-green-500/20 rounded">Current</span>
        <% end %>
        <h3 class="text-lg font-bold text-white mb-1"><%= plan.name %></h3>
        <p class="text-2xl font-bold text-white mb-4">
          <% if plan.free? %>
            Free
          <% else %>
            $<%= plan.price_cents_per_month / 100 %><span class="text-sm text-gray-500 font-normal">/mo</span>
          <% end %>
        </p>
        <ul class="space-y-2 text-xs text-gray-400 mb-5">
          <li class="flex items-center space-x-2">
            <svg class="w-3.5 h-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span><%= plan.max_apps %> apps</span>
          </li>
          <li class="flex items-center space-x-2">
            <svg class="w-3.5 h-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span><%= plan.max_databases %> databases</span>
          </li>
          <li class="flex items-center space-x-2">
            <svg class="w-3.5 h-3.5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span><%= plan.max_dynos %> dynos</span>
          </li>
        </ul>
        <% if plan != @plan && !plan.free? %>
          <button class="w-full py-2 px-4 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer text-center">Upgrade</button>
        <% elsif plan != @plan && plan.free? %>
          <span class="block text-center text-xs text-gray-500 py-2">Free tier</span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
