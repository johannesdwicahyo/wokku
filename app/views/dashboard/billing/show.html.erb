<div class="mb-8">
  <h1 class="font-headline text-3xl font-bold text-on-surface mb-2">Billing</h1>
  <p class="text-sm text-outline">Real-time usage tracking and invoices.</p>
</div>

<% if @unpaid.any? %>
  <div class="mb-6 bg-error-container/20 border border-error/30 rounded-md p-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="material-symbols-outlined text-error text-[24px]">warning</span>
      <div>
        <p class="text-sm font-bold text-on-error-container">You have unpaid invoices</p>
        <p class="text-xs text-on-error-container/70">Please pay within the due date to avoid service interruption.</p>
      </div>
    </div>
    <%= link_to pay_dashboard_billing_path(@unpaid.first), class: "px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition", data: { turbo_method: :post } do %>Pay Now<% end %>
  </div>
<% end %>

<div class="grid grid-cols-12 gap-6">
  <div class="col-span-8 space-y-6">

    <%# Usage Counter %>
    <div class="bg-surface-container-low rounded-md overflow-hidden">
      <div class="px-6 py-4 border-b border-outline-variant/10">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="font-headline text-base font-bold text-on-surface">Usage This Month</h2>
            <p class="text-xs text-outline mt-0.5"><%= @billing[:period] %></p>
          </div>
          <div class="flex items-center gap-6">
            <div class="text-right">
              <p class="text-[10px] text-outline uppercase tracking-wider font-bold">Current</p>
              <span class="text-2xl font-bold text-primary font-headline">$<%= "%.2f" % @billing[:current_total] %></span>
            </div>
            <div class="text-right">
              <p class="text-[10px] text-outline uppercase tracking-wider font-bold">Projected</p>
              <span class="text-2xl font-bold text-on-surface font-headline">$<%= "%.2f" % @billing[:projected_total] %></span>
            </div>
          </div>
        </div>
      </div>

      <%# Progress bar %>
      <div class="px-6 py-3 bg-surface/30">
        <div class="flex items-center justify-between text-[10px] text-outline mb-1.5">
          <span><%= @billing[:hours_elapsed] %> hrs elapsed</span>
          <span><%= @billing[:hours_remaining] %> hrs remaining</span>
        </div>
        <div class="h-1.5 bg-surface rounded-full overflow-hidden">
          <div class="h-full technical-gradient rounded-full transition-all" style="width: <%= @billing[:period_progress] %>%"></div>
        </div>
      </div>
    </div>

    <%# Dyno Breakdown %>
    <div class="bg-surface-container-low rounded-md overflow-hidden">
      <div class="px-6 py-4 border-b border-outline-variant/10">
        <h2 class="font-headline text-base font-bold text-on-surface">Containers</h2>
      </div>
      <% if @dyno_items.any? %>
        <table class="w-full">
          <thead>
            <tr class="bg-surface-container-highest/50">
              <th class="px-6 py-2.5 text-left text-[10px] text-outline uppercase tracking-wider font-bold">App</th>
              <th class="px-6 py-2.5 text-left text-[10px] text-outline uppercase tracking-wider font-bold">Process</th>
              <th class="px-6 py-2.5 text-left text-[10px] text-outline uppercase tracking-wider font-bold">Tier</th>
              <th class="px-6 py-2.5 text-right text-[10px] text-outline uppercase tracking-wider font-bold">Dynos</th>
              <th class="px-6 py-2.5 text-right text-[10px] text-outline uppercase tracking-wider font-bold">Current</th>
              <th class="px-6 py-2.5 text-right text-[10px] text-outline uppercase tracking-wider font-bold">Projected</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant/10">
            <% @dyno_items.each do |item| %>
              <tr class="hover:bg-surface-container-high/20 transition">
                <td class="px-6 py-2.5 text-xs font-mono text-primary"><%= item[:name] %></td>
                <td class="px-6 py-2.5 text-xs text-on-surface-variant font-mono"><%= item[:process_type] %></td>
                <td class="px-6 py-2.5 text-xs text-on-surface-variant capitalize"><%= item[:tier] %></td>
                <td class="px-6 py-2.5 text-xs text-on-surface-variant text-right font-mono"><%= item[:count] %></td>
                <td class="px-6 py-2.5 text-xs font-bold text-on-surface text-right font-mono">$<%= "%.2f" % item[:current_cost] %></td>
                <td class="px-6 py-2.5 text-xs text-outline text-right font-mono">$<%= "%.2f" % item[:projected_cost] %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr class="bg-surface/30">
              <td colspan="4" class="px-6 py-2.5 text-xs font-bold text-on-surface">Containers Total</td>
              <td class="px-6 py-2.5 text-xs font-bold text-primary text-right font-mono">$<%= "%.2f" % @dyno_items.sum { |i| i[:current_cost] } %></td>
              <td class="px-6 py-2.5 text-xs text-outline text-right font-mono">$<%= "%.2f" % @dyno_items.sum { |i| i[:projected_cost] } %></td>
            </tr>
          </tfoot>
        </table>
      <% else %>
        <div class="px-6 py-6 text-center">
          <p class="text-xs text-outline">No active containers.</p>
        </div>
      <% end %>
    </div>

    <%# Add-on Breakdown %>
    <% if @addon_items.any? %>
      <div class="bg-surface-container-low rounded-md overflow-hidden">
        <div class="px-6 py-4 border-b border-outline-variant/10">
          <h2 class="font-headline text-base font-bold text-on-surface">Add-ons</h2>
        </div>
        <table class="w-full">
          <thead>
            <tr class="bg-surface-container-highest/50">
              <th class="px-6 py-2.5 text-left text-[10px] text-outline uppercase tracking-wider font-bold">Resource</th>
              <th class="px-6 py-2.5 text-left text-[10px] text-outline uppercase tracking-wider font-bold">Tier</th>
              <th class="px-6 py-2.5 text-left text-[10px] text-outline uppercase tracking-wider font-bold">Type</th>
              <th class="px-6 py-2.5 text-right text-[10px] text-outline uppercase tracking-wider font-bold">Current</th>
              <th class="px-6 py-2.5 text-right text-[10px] text-outline uppercase tracking-wider font-bold">Projected</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant/10">
            <% @addon_items.each do |item| %>
              <tr class="hover:bg-surface-container-high/20 transition">
                <td class="px-6 py-2.5 text-xs font-mono text-primary"><%= item[:name] %></td>
                <td class="px-6 py-2.5 text-xs text-on-surface-variant capitalize"><%= item[:tier] %></td>
                <td class="px-6 py-2.5 text-xs text-on-surface-variant"><%= item[:type] %></td>
                <td class="px-6 py-2.5 text-xs font-bold text-on-surface text-right font-mono">$<%= "%.2f" % item[:current_cost] %></td>
                <td class="px-6 py-2.5 text-xs text-outline text-right font-mono">$<%= "%.2f" % item[:projected_cost] %></td>
              </tr>
            <% end %>
          </tbody>
          <tfoot>
            <tr class="bg-surface/30">
              <td colspan="3" class="px-6 py-2.5 text-xs font-bold text-on-surface">Add-ons Total</td>
              <td class="px-6 py-2.5 text-xs font-bold text-primary text-right font-mono">$<%= "%.2f" % @addon_items.sum { |i| i[:current_cost] } %></td>
              <td class="px-6 py-2.5 text-xs text-outline text-right font-mono">$<%= "%.2f" % @addon_items.sum { |i| i[:projected_cost] } %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    <% end %>

    <%# Invoices %>
    <div class="bg-surface-container-low rounded-md overflow-hidden">
      <div class="px-6 py-4 border-b border-outline-variant/10">
        <h2 class="font-headline text-base font-bold text-on-surface">Invoice History</h2>
      </div>
      <% if @invoices.any? %>
        <table class="w-full">
          <thead>
            <tr class="bg-surface-container-highest/50">
              <th class="px-6 py-2.5 text-left text-[10px] text-outline uppercase tracking-wider font-bold">Invoice</th>
              <th class="px-6 py-2.5 text-left text-[10px] text-outline uppercase tracking-wider font-bold">Period</th>
              <th class="px-6 py-2.5 text-left text-[10px] text-outline uppercase tracking-wider font-bold">Amount</th>
              <th class="px-6 py-2.5 text-left text-[10px] text-outline uppercase tracking-wider font-bold">Status</th>
              <th class="px-6 py-2.5 text-right text-[10px] text-outline uppercase tracking-wider font-bold">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant/10">
            <% @invoices.each do |invoice| %>
              <tr class="hover:bg-surface-container-high/20 transition">
                <td class="px-6 py-2.5 text-xs font-mono text-primary"><%= invoice.reference_id %></td>
                <td class="px-6 py-2.5 text-xs text-on-surface-variant"><%= invoice.period_label %></td>
                <td class="px-6 py-2.5 text-xs font-bold text-on-surface">$<%= "%.2f" % invoice.amount_dollars %></td>
                <td class="px-6 py-2.5">
                  <% if invoice.respond_to?(:paid?) && invoice.paid? %>
                    <span class="text-[10px] font-bold text-secondary uppercase bg-secondary-container/20 px-2 py-0.5 rounded">Paid</span>
                  <% elsif invoice.respond_to?(:pending?) && invoice.pending? %>
                    <span class="text-[10px] font-bold text-tertiary uppercase bg-tertiary-container/20 px-2 py-0.5 rounded">Pending</span>
                  <% else %>
                    <span class="text-[10px] font-bold text-error uppercase bg-error-container/20 px-2 py-0.5 rounded">Expired</span>
                  <% end %>
                </td>
                <td class="px-6 py-2.5 text-right">
                  <% if invoice.respond_to?(:pending?) && invoice.pending? %>
                    <%= link_to "Pay", pay_dashboard_billing_path(invoice), class: "text-xs text-primary hover:underline font-semibold", data: { turbo_method: :post } %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="px-6 py-6 text-center">
          <span class="material-symbols-outlined text-outline-variant text-[32px] mb-2">receipt_long</span>
          <p class="text-xs text-outline">No invoices yet. Your first invoice will be generated at the end of the month.</p>
        </div>
      <% end %>
    </div>
  </div>

  <%# Right Column %>
  <div class="col-span-4 space-y-6">
    <%# Cost Summary %>
    <div class="bg-primary-container/20 rounded-md p-5">
      <p class="text-[10px] text-outline uppercase tracking-widest font-bold mb-3">Cost Summary</p>
      <div class="space-y-3">
        <div class="flex items-center justify-between">
          <span class="text-xs text-on-surface-variant">Current usage</span>
          <span class="text-sm font-bold text-primary font-mono">$<%= "%.2f" % @billing[:current_total] %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-xs text-on-surface-variant">Projected month-end</span>
          <span class="text-sm font-bold text-on-surface font-mono">$<%= "%.2f" % @billing[:projected_total] %></span>
        </div>
        <div class="border-t border-outline-variant/15 pt-3">
          <div class="flex items-center justify-between">
            <span class="text-xs text-outline">In IDR (est.)</span>
            <span class="text-xs text-outline font-mono">Rp <%= @billing[:projected_idr].to_s.reverse.gsub(/(\d{3})(?=\d)/, '\\1.').reverse %></span>
          </div>
        </div>
      </div>
    </div>

    <%# Payment Methods %>
    <div class="bg-surface-container-low rounded-md overflow-hidden">
      <div class="px-5 py-3 border-b border-outline-variant/10">
        <p class="text-[10px] text-outline uppercase tracking-widest font-bold">Payment Methods</p>
      </div>
      <div class="p-5 space-y-3">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary text-[20px]">qr_code_2</span>
          <div>
            <p class="text-xs font-bold text-on-surface">QRIS</p>
            <p class="text-[10px] text-outline">Scan with any e-wallet or banking app</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-secondary text-[20px]">account_balance</span>
          <div>
            <p class="text-xs font-bold text-on-surface">Bank Transfer</p>
            <p class="text-[10px] text-outline">BCA, BNI, BRI, Mandiri + more</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-tertiary text-[20px]">credit_card</span>
          <div>
            <p class="text-xs font-bold text-on-surface">Credit Card</p>
            <p class="text-[10px] text-outline">Visa, Mastercard</p>
          </div>
        </div>
      </div>
    </div>

    <%# Billing Policy %>
    <div class="bg-surface-container-low rounded-md p-5">
      <p class="text-[10px] text-outline uppercase tracking-widest font-bold mb-3">Billing Policy</p>
      <div class="space-y-2 text-xs text-outline">
        <p>• Billed hourly (÷720), capped at monthly max</p>
        <p>• Invoice generated at end of each month</p>
        <p>• <span class="text-on-surface-variant font-semibold">3 days</span> to pay after invoice</p>
        <p>• <span class="text-tertiary font-semibold">Grace period:</span> 4 days after due date</p>
        <p>• <span class="text-error font-semibold">Suspension:</span> apps stopped after grace</p>
        <p>• Free tier containers never billed</p>
      </div>
    </div>
  </div>
</div>
