<div class="max-w-lg">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Add Server</h1>
    <p class="mt-1 text-sm text-gray-500">Connect a new Dokku server</p>
  </div>

  <%= form_with(model: @server, url: dashboard_servers_path, class: "bg-white rounded-xl border border-gray-200 p-6 space-y-5") do |f| %>
    <% if @server.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <ul class="list-disc list-inside text-sm text-red-800 space-y-1">
          <% @server.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm", placeholder: "production", autofocus: true %>
    </div>

    <div>
      <%= f.label :host, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :host, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm", placeholder: "dokku.example.com" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= f.label :port, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.number_field :port, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm", value: 22 %>
      </div>
      <div>
        <%= f.label :ssh_user, "SSH User", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :ssh_user, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-purple-500 focus:ring-purple-500 text-sm", value: "dokku" %>
      </div>
    </div>

    <div class="flex items-center space-x-3 pt-2">
      <%= f.submit "Add Server", class: "px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 transition shadow-sm cursor-pointer" %>
      <%= link_to "Cancel", dashboard_servers_path, class: "text-sm text-gray-500 hover:text-gray-700 transition" %>
    </div>
  <% end %>
</div>
