<div data-controller="slide-panel">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-headline text-on-surface"><%= t("dashboard.servers.title") %></h1>
      <p class="mt-0.5 text-sm text-outline">
        <% if @can_manage %>Manage your Dokku servers<% else %>Pick a server when deploying — read-only for non-admins<% end %>
      </p>
    </div>
    <% if @can_manage %>
      <button data-action="click->slide-panel#open" class="inline-flex items-center px-3 py-1.5 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">
        <span class="material-symbols-outlined text-[18px] mr-1.5">add</span>
        <%= t("dashboard.servers.add_server") %>
      </button>
    <% end %>
  </div>

  <% if @servers.any? %>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      <% @servers.each do |server| %>
        <%
          # Prefer live metrics from MetricsPollJob (every 1m). When the poll
          # is stale (server unreachable / first boot), fall back to the
          # allocation-based estimate.
          live = server.live_metrics_fresh?
          if live
            allocated = server.live_mem_used_mb
            total = server.live_mem_total_mb
            pct = server.live_mem_pct
            cpu_pct = server.live_cpu_pct
            cont_count = server.live_container_count
          else
            allocated = server.allocated_memory_mb
            total = server.capacity_total_mb_or_nil
            pct = server.capacity_pct
            cpu_pct = nil
            cont_count = nil
          end
          pct_color = pct.nil? ? "bg-outline-variant" : (pct > 85 ? "bg-error" : pct > 65 ? "bg-orange-500" : "bg-primary")
        %>
        <%= link_to dashboard_server_path(server), class: "block bg-surface-container-low rounded-lg border border-outline-variant/15 hover:border-primary/40 transition p-4" do %>
          <div class="flex items-start justify-between mb-3">
            <div class="min-w-0">
              <p class="text-sm font-bold text-on-surface font-mono truncate"><%= server.name %></p>
              <p class="text-[11px] text-outline font-mono mt-0.5"><%= server.host %><% if server.region.present? %> · <%= server.region %><% end %></p>
            </div>
            <% case server.status %>
            <% when "connected" %>
              <span class="inline-flex items-center text-[10px] text-primary"><span class="w-1.5 h-1.5 rounded-full bg-primary mr-1"></span><%= t("dashboard.servers.connected") %></span>
            <% when "unreachable" %>
              <span class="inline-flex items-center text-[10px] text-error"><span class="w-1.5 h-1.5 rounded-full bg-error mr-1"></span><%= t("dashboard.servers.unreachable") %></span>
            <% when "auth_failed" %>
              <span class="inline-flex items-center text-[10px] text-orange-800"><span class="w-1.5 h-1.5 rounded-full bg-orange-800 mr-1"></span><%= t("dashboard.servers.auth_failed") %></span>
            <% when "syncing" %>
              <span class="inline-flex items-center text-[10px] text-yellow-500"><span class="w-1.5 h-1.5 rounded-full bg-yellow-500 animate-pulse mr-1"></span><%= t("dashboard.servers.syncing") %></span>
            <% end %>
          </div>

          <div class="space-y-2">
            <div>
              <div class="flex items-center justify-between text-[10px] text-outline mb-1">
                <span class="uppercase tracking-wider"><%= live ? "Memory (live)" : "Capacity" %></span>
                <span class="font-mono">
                  <% if pct %>
                    <%= pct %>% (<%= allocated %>MB / <%= total %>MB)
                  <% else %>
                    <%= allocated %>MB allocated
                  <% end %>
                </span>
              </div>
              <div class="h-1.5 rounded-full bg-surface-container-highest overflow-hidden">
                <div class="h-full <%= pct_color %> transition-all" style="width: <%= pct ? [pct, 100].min : 0 %>%"></div>
              </div>
            </div>

            <% if cpu_pct %>
              <div>
                <div class="flex items-center justify-between text-[10px] text-outline mb-1">
                  <span class="uppercase tracking-wider">CPU (live)</span>
                  <span class="font-mono"><%= cpu_pct %>%</span>
                </div>
                <div class="h-1.5 rounded-full bg-surface-container-highest overflow-hidden">
                  <%
                    cpu_color = cpu_pct > 80 ? "bg-error" : cpu_pct > 50 ? "bg-orange-500" : "bg-primary"
                    cpu_bar = [ cpu_pct, 100 ].min
                  %>
                  <div class="h-full <%= cpu_color %> transition-all" style="width: <%= cpu_bar %>%"></div>
                </div>
              </div>
            <% end %>

            <div class="flex items-center justify-between text-[11px] text-outline">
              <span>
                <%= server.app_records.size %> apps
                <% if cont_count %><span class="text-outline-variant"> · <%= cont_count %> containers</span><% end %>
              </span>
              <span class="font-mono">:<%= server.port %></span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-surface-container-low rounded-lg border border-outline-variant/15">
      <span class="material-symbols-outlined text-[40px] text-outline-variant mb-2">dns</span>
      <h3 class="mt-3 text-sm font-medium text-on-surface-variant"><%= t("dashboard.servers.no_servers") %></h3>
      <% if @can_manage %>
        <p class="mt-1 text-xs text-outline">Connect your first Dokku server to get started.</p>
        <div class="mt-4">
          <button data-action="click->slide-panel#open" class="inline-flex items-center px-3 py-1.5 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer"><%= t("dashboard.servers.add_server") %></button>
        </div>
      <% else %>
        <p class="mt-1 text-xs text-outline">No platform servers available yet — check back soon.</p>
      <% end %>
    </div>
  <% end %>

  <% if @can_manage %>
    <%= render layout: "dashboard/shared/slide_panel", locals: { title: t("dashboard.servers.add_server"), subtitle: "Connect a Dokku server via SSH" } do %>
      <%= render "form", server: @server %>
    <% end %>
  <% end %>
</div>
