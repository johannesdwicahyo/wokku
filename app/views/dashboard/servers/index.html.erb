<div data-controller="slide-panel">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-headline text-on-surface"><%= t("dashboard.servers.title") %></h1>
      <p class="mt-0.5 text-sm text-outline">Manage your Dokku servers</p>
    </div>
    <button data-action="click->slide-panel#open" class="inline-flex items-center px-3 py-1.5 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">
      <span class="material-symbols-outlined text-[18px] mr-1.5">add</span>
      <%= t("dashboard.servers.add_server") %>
    </button>
  </div>

  <% if @servers.any? %>
    <div class="bg-surface-container-low rounded-lg border border-outline-variant/15 overflow-hidden">
      <table class="min-w-full">
        <thead>
          <tr class="border-b border-outline-variant/15 bg-surface-container-highest">
            <th class="px-4 py-2.5 text-left text-xs font-medium text-outline uppercase tracking-wider">Name</th>
            <th class="px-4 py-2.5 text-left text-xs font-medium text-outline uppercase tracking-wider">Host</th>
            <th class="px-4 py-2.5 text-left text-xs font-medium text-outline uppercase tracking-wider">Status</th>
            <th class="px-4 py-2.5 text-left text-xs font-medium text-outline uppercase tracking-wider">Apps</th>
            <th class="px-4 py-2.5"></th>
          </tr>
        </thead>
        <tbody>
          <% @servers.each do |server| %>
            <tr class="border-b border-outline-variant/15 last:border-b-0 hover:bg-surface-container-highest transition">
              <td class="px-4 py-3">
                <%= link_to server.name, dashboard_server_path(server), class: "text-sm font-semibold text-on-surface font-mono hover:text-primary transition cursor-pointer" %>
              </td>
              <td class="px-4 py-3 text-sm text-on-surface-variant font-mono"><%= server.host %>:<%= server.port %></td>
              <td class="px-4 py-3">
                <% case server.status %>
                <% when "connected" %>
                  <span class="inline-flex items-center space-x-1 text-xs text-primary">
                    <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
                    <span><%= t("dashboard.servers.connected") %></span>
                  </span>
                <% when "unreachable" %>
                  <span class="inline-flex items-center space-x-1 text-xs text-error">
                    <span class="w-1.5 h-1.5 rounded-full bg-error"></span>
                    <span><%= t("dashboard.servers.unreachable") %></span>
                  </span>
                <% when "auth_failed" %>
                  <span class="inline-flex items-center space-x-1 text-xs text-orange-800">
                    <span class="w-1.5 h-1.5 rounded-full bg-orange-800"></span>
                    <span><%= t("dashboard.servers.auth_failed") %></span>
                  </span>
                <% when "syncing" %>
                  <span class="inline-flex items-center space-x-1 text-xs text-yellow-500">
                    <span class="w-1.5 h-1.5 rounded-full bg-yellow-500 animate-pulse"></span>
                    <span><%= t("dashboard.servers.syncing") %></span>
                  </span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm text-on-surface-variant font-mono"><%= server.app_records.size %></td>
              <td class="px-4 py-3 text-right">
                <%= link_to "View", dashboard_server_path(server), class: "text-xs text-outline hover:text-primary transition cursor-pointer" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-16 bg-surface-container-low rounded-lg border border-outline-variant/15">
      <span class="material-symbols-outlined text-[40px] text-outline-variant mb-2">dns</span>
      <h3 class="mt-3 text-sm font-medium text-on-surface-variant"><%= t("dashboard.servers.no_servers") %></h3>
      <p class="mt-1 text-xs text-outline">Connect your first Dokku server to get started.</p>
      <div class="mt-4">
        <button data-action="click->slide-panel#open" class="inline-flex items-center px-3 py-1.5 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer"><%= t("dashboard.servers.add_server") %></button>
      </div>
    </div>
  <% end %>

  <%= render layout: "dashboard/shared/slide_panel", locals: { title: t("dashboard.servers.add_server"), subtitle: "Connect a Dokku server via SSH" } do %>
    <%= render "form", server: @server %>
  <% end %>
</div>
