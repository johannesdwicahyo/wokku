<div class="mb-4">
  <div class="flex items-center space-x-2 text-sm">
    <%= link_to t("dashboard.servers.title"), dashboard_servers_path, class: "text-outline hover:text-primary transition cursor-pointer" %>
    <span class="material-symbols-outlined text-[16px] text-outline-variant">chevron_right</span>
    <span class="text-on-surface-variant font-mono"><%= @server.name %></span>
  </div>
</div>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center space-x-3">
    <h1 class="text-xl font-headline text-on-surface"><%= @server.name %></h1>
    <% case @server.status %>
    <% when "connected" %>
      <span class="inline-flex items-center space-x-1 text-xs text-primary bg-primary/10 px-2 py-0.5 rounded-md border border-primary/20">
        <span class="w-1.5 h-1.5 rounded-full bg-primary"></span>
        <span><%= t("dashboard.servers.connected") %></span>
      </span>
    <% when "unreachable" %>
      <span class="inline-flex items-center space-x-1 text-xs text-error bg-error-container/20 px-2 py-0.5 rounded-md border border-error/20">
        <span class="w-1.5 h-1.5 rounded-full bg-error"></span>
        <span><%= t("dashboard.servers.unreachable") %></span>
      </span>
    <% when "auth_failed" %>
      <span class="inline-flex items-center space-x-1 text-xs text-orange-800 bg-orange-100 px-2 py-0.5 rounded-md border border-orange-800/20">
        <span class="w-1.5 h-1.5 rounded-full bg-orange-800"></span>
        <span><%= t("dashboard.servers.auth_failed") %></span>
      </span>
    <% when "syncing" %>
      <span class="inline-flex items-center space-x-1 text-xs text-yellow-500 bg-yellow-500/10 px-2 py-0.5 rounded-md border border-yellow-500/20">
        <span class="w-1.5 h-1.5 rounded-full bg-yellow-500 animate-pulse"></span>
        <span><%= t("dashboard.servers.syncing") %></span>
      </span>
    <% end %>
  </div>
  <div class="flex items-center space-x-3">
    <%= link_to dashboard_server_terminal_path(@server), class: "inline-flex items-center px-3 py-1.5 bg-surface-container-low border border-outline-variant/15 text-on-surface-variant text-sm font-medium rounded-md hover:bg-surface-container-highest hover:text-on-surface transition" do %>
      <span class="material-symbols-outlined text-[18px] mr-1.5">terminal</span>
      Terminal
    <% end %>
    <%= link_to edit_dashboard_server_backup_destination_path(@server), class: "inline-flex items-center px-3 py-1.5 bg-surface-container-low border border-outline-variant/15 text-on-surface-variant text-sm font-medium rounded-md hover:bg-surface-container-highest hover:text-on-surface transition" do %>
      <span class="material-symbols-outlined text-[18px] mr-1.5">backup</span>
      Backups
    <% end %>
    <%= button_to "Sync Now", sync_dashboard_server_path(@server), method: :post, class: "inline-flex items-center px-3 py-1.5 text-sm font-medium text-on-surface-variant bg-surface-container-low border border-outline-variant/15 rounded-md hover:bg-surface-container-highest hover:text-on-surface transition cursor-pointer" %>
    <%= button_to "Delete", dashboard_server_path(@server),
          method: :delete,
          form: {
            data: {
              controller: "confirm-delete",
              confirm_delete_name_value: @server.name,
              confirm_delete_impact_value: "This will remove #{@server.name} from Wokku and all its apps, databases, and backups will lose their connection. The Dokku server itself will NOT be deleted — you must remove it manually if you want to.",
              confirm_delete_resource_value: "server"
            }
          },
          class: "text-sm text-error/70 hover:text-error font-medium transition cursor-pointer bg-transparent border-0" %>
  </div>
</div>

<%# Recovery card — shown when server can't connect %>
<% if @server.auth_failed? || @server.unreachable? %>
  <div class="mb-6 bg-error-container/10 border border-error/30 rounded-md p-5">
    <div class="flex items-start gap-4">
      <div class="w-10 h-10 rounded-full bg-error/15 flex items-center justify-center flex-shrink-0">
        <span class="material-symbols-outlined text-error">error</span>
      </div>
      <div class="flex-1">
        <h3 class="text-sm font-bold text-on-surface mb-1">
          <% if @server.auth_failed? %>
            SSH authentication failed
          <% else %>
            Server unreachable
          <% end %>
        </h3>
        <p class="text-xs text-on-surface-variant mb-3">
          <% if @server.auth_failed? %>
            Wokku couldn't authenticate to <code class="font-mono text-primary"><%= @server.host %></code> with the SSH key on file.
            This usually means the public key isn't in the server's <code class="font-mono">~/.ssh/authorized_keys</code>, or the SSH user is wrong.
          <% else %>
            Wokku couldn't connect to <code class="font-mono text-primary"><%= @server.host %>:<%= @server.port %></code>.
            Check that the server is online, the hostname is correct, and port <%= @server.port %> accepts SSH connections from Wokku's server.
          <% end %>
        </p>
        <div class="bg-surface-container-lowest rounded p-3 mb-3">
          <p class="text-[10px] text-outline uppercase tracking-wider font-bold mb-2">Troubleshooting checklist</p>
          <ul class="text-xs text-on-surface-variant space-y-1.5">
            <% if @server.auth_failed? %>
              <li class="flex items-start gap-2"><span class="text-outline">1.</span>Verify the SSH user is correct (currently: <code class="font-mono text-primary"><%= @server.ssh_user || "dokku" %></code>)</li>
              <li class="flex items-start gap-2"><span class="text-outline">2.</span>Check that Wokku's public SSH key is in <code class="font-mono">~/.ssh/authorized_keys</code> on the server</li>
              <li class="flex items-start gap-2"><span class="text-outline">3.</span>Try SSH-ing manually from your machine: <code class="font-mono text-primary">ssh <%= @server.ssh_user || "dokku" %>@<%= @server.host %></code></li>
              <li class="flex items-start gap-2"><span class="text-outline">4.</span>If you updated the server's authorized_keys, click Retry Sync below</li>
            <% else %>
              <li class="flex items-start gap-2"><span class="text-outline">1.</span>Ping the server from your machine: <code class="font-mono text-primary">ping <%= @server.host %></code></li>
              <li class="flex items-start gap-2"><span class="text-outline">2.</span>Check SSH port is open: <code class="font-mono text-primary">nc -zv <%= @server.host %> <%= @server.port %></code></li>
              <li class="flex items-start gap-2"><span class="text-outline">3.</span>Verify firewall allows SSH from Wokku's IP</li>
              <li class="flex items-start gap-2"><span class="text-outline">4.</span>Confirm the server is powered on and responsive</li>
            <% end %>
          </ul>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <%= button_to sync_dashboard_server_path(@server), method: :post, class: "inline-flex items-center gap-1 px-3 py-1.5 text-xs font-bold text-surface bg-primary rounded-md hover:bg-primary/80 transition cursor-pointer" do %>
            <span class="material-symbols-outlined text-[14px]">refresh</span>
            Retry Sync
          <% end %>
          <%= link_to edit_dashboard_server_path(@server), class: "inline-flex items-center gap-1 px-3 py-1.5 text-xs text-on-surface-variant border border-outline-variant/20 rounded-md hover:bg-surface-container-high/30 transition" do %>
            <span class="material-symbols-outlined text-[14px]">edit</span>
            Edit Server
          <% end %>
          <a href="/docs/getting-started/connect-server" target="_blank" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs text-on-surface-variant hover:text-primary transition">
            <span class="material-symbols-outlined text-[14px]">menu_book</span>
            View docs
          </a>
        </div>
      </div>
    </div>
  </div>
<% end %>

<div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-8">
  <div class="bg-surface-container-low rounded-lg border border-outline-variant/15 p-4">
    <p class="text-xs text-outline uppercase tracking-wider font-medium mb-1">Host</p>
    <p class="text-sm font-semibold text-on-surface font-mono"><%= @server.host %>:<%= @server.port %></p>
  </div>
  <div class="bg-surface-container-low rounded-lg border border-outline-variant/15 p-4">
    <p class="text-xs text-outline uppercase tracking-wider font-medium mb-1">SSH User</p>
    <p class="text-sm font-semibold text-on-surface font-mono"><%= @server.ssh_user %></p>
  </div>
  <div class="bg-surface-container-low rounded-lg border border-outline-variant/15 p-4">
    <p class="text-xs text-outline uppercase tracking-wider font-medium mb-1">Apps</p>
    <p class="text-sm font-semibold text-on-surface"><%= @apps.size %></p>
  </div>
</div>

<h2 class="text-sm font-semibold text-on-surface-variant uppercase tracking-wider mb-3">Apps on this server</h2>
<% if @apps.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
    <% @apps.each do |app| %>
      <%= link_to dashboard_app_path(app), class: "block bg-surface-container-low rounded-lg border border-outline-variant/15 p-4 hover:bg-surface-container hover:border-outline-variant/30 transition cursor-pointer group" do %>
        <div class="flex items-center justify-between">
          <span class="text-sm font-medium text-on-surface font-mono group-hover:text-primary transition"><%= app.name %></span>
          <% case app.status %>
          <% when "running" %>
            <span class="w-2 h-2 rounded-full bg-primary"></span>
          <% when "crashed" %>
            <span class="w-2 h-2 rounded-full bg-error"></span>
          <% when "stopped" %>
            <span class="w-2 h-2 rounded-full bg-outline"></span>
          <% when "deploying" %>
            <span class="w-2 h-2 rounded-full bg-yellow-500 animate-pulse"></span>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <p class="text-sm text-outline bg-surface-container-low rounded-lg border border-outline-variant/15 p-6 text-center">No apps deployed to this server yet.</p>
<% end %>
