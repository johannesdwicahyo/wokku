<%= render "dashboard/apps/tabs", app: @app %>

<div data-controller="config-vars slide-panel">
  <%# Config Vars List %>
  <div class="bg-surface-container-low rounded-xl overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-outline-variant/15 flex items-center justify-between">
      <div>
        <h2 class="text-base font-semibold text-on-surface font-headline">Config Vars</h2>
        <p class="text-sm text-outline mt-1">Environment variables for <span class="font-mono"><%= @app.name %></span></p>
      </div>
      <div class="flex items-center gap-2">
        <% if @env_vars.any? %>
          <button data-action="click->config-vars#toggleAll" data-config-vars-target="revealAllBtn"
                  class="inline-flex items-center px-3 py-1.5 text-xs text-on-surface-variant border border-outline-variant/15 rounded-md hover:border-primary/50 hover:text-primary transition cursor-pointer">
            <span class="material-symbols-outlined text-[16px] mr-1.5">visibility</span>
            <span data-config-vars-target="revealAllText">Reveal Values</span>
          </button>
        <% end %>
        <button data-action="click->slide-panel#open" class="inline-flex items-center px-3 py-1.5 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">
          <span class="material-symbols-outlined text-[16px] mr-1">add</span> Add Config Var
        </button>
      </div>
    </div>

    <% if @env_vars.any? %>
      <div class="divide-y divide-outline-variant/15">
        <% @env_vars.each do |var| %>
          <div class="px-6 py-3 flex items-center justify-between hover:bg-surface-container-high/30 group" data-config-vars-target="row">
            <div class="flex items-center space-x-4 flex-1 min-w-0">
              <span class="text-sm font-mono font-medium text-primary shrink-0"><%= var.key %></span>
              <span class="text-sm font-mono text-outline truncate" data-config-vars-target="maskedValue">••••••••</span>
              <span class="text-sm font-mono text-on-surface-variant truncate hidden" data-config-vars-target="realValue"><%= var.value %></span>
            </div>
            <div class="flex items-center space-x-2 shrink-0 opacity-0 group-hover:opacity-100 transition">
              <button data-action="click->config-vars#toggleOne"
                      class="p-1.5 text-outline hover:text-primary transition cursor-pointer" title="Reveal">
                <span class="material-symbols-outlined text-[16px]">visibility</span>
              </button>
              <button data-action="click->config-vars#edit"
                      data-var-id="<%= var.id %>" data-var-key="<%= var.key %>" data-var-value="<%= var.value %>"
                      class="p-1.5 text-outline hover:text-primary transition cursor-pointer" title="Edit">
                <span class="material-symbols-outlined text-[16px]">edit</span>
              </button>
              <%= link_to dashboard_app_config_path(@app, var), data: { turbo_method: :delete, turbo_confirm: "Remove #{var.key}?" }, class: "p-1.5 text-outline hover:text-error transition", title: "Delete" do %>
                <span class="material-symbols-outlined text-[16px]">delete</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center">
        <p class="text-sm text-outline">No config vars set.</p>
      </div>
    <% end %>
  </div>

  <%# Edit Modal (hidden by default) %>
  <div data-config-vars-target="editModal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/60" data-action="click->config-vars#closeEdit"></div>
    <div class="relative bg-surface-container-low border border-outline-variant/15 rounded-xl shadow-2xl w-full max-w-lg mx-4 p-6">
      <h3 class="text-base font-semibold text-on-surface font-headline mb-4">Edit Config Var</h3>
      <%= form_with(url: "", method: :patch, data: { config_vars_target: "editForm" }, class: "space-y-4") do |f| %>
        <div>
          <label class="block text-[10px] text-outline uppercase tracking-wider font-bold mb-1">Key</label>
          <input type="text" data-config-vars-target="editKey" disabled
                 class="w-full rounded-md bg-surface border-outline-variant/15 text-outline font-mono text-sm cursor-not-allowed">
        </div>
        <div>
          <label class="block text-[10px] text-outline uppercase tracking-wider font-bold mb-1">Value</label>
          <textarea name="env_var[value]" data-config-vars-target="editValue" rows="3"
                    class="w-full rounded-md bg-surface border-outline-variant/15 text-on-surface font-mono text-sm focus:ring-primary focus:border-primary"></textarea>
        </div>
        <div class="flex justify-end space-x-3">
          <button type="button" data-action="click->config-vars#closeEdit"
                  class="px-4 py-2 text-sm text-on-surface-variant hover:text-on-surface transition cursor-pointer">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">Save</button>
        </div>
      <% end %>
    </div>
  </div>

  <%= render layout: "dashboard/shared/slide_panel", locals: { title: "Add Config Var", subtitle: "New environment variable for #{@app.name}" } do %>
    <%= form_with(model: EnvVar.new, url: dashboard_app_config_index_path(@app), class: "space-y-4") do |f| %>
      <div>
        <%= f.label :key, class: "block text-[10px] text-outline uppercase tracking-wider font-bold mb-1" %>
        <%= f.text_field :key, class: "w-full rounded-md bg-surface border-outline-variant/15 text-on-surface font-mono text-sm focus:ring-primary focus:border-primary", placeholder: "SECRET_KEY", autofocus: true %>
      </div>
      <div>
        <%= f.label :value, class: "block text-[10px] text-outline uppercase tracking-wider font-bold mb-1" %>
        <%= f.text_area :value, rows: 4, class: "w-full rounded-md bg-surface border-outline-variant/15 text-on-surface font-mono text-sm focus:ring-primary focus:border-primary", placeholder: "value" %>
      </div>
      <div class="flex items-center gap-3">
        <%= f.submit "Add Config Var", class: "px-4 py-2 bg-primary text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer" %>
        <button type="button" data-action="click->slide-panel#close" class="text-sm text-outline hover:text-on-surface transition cursor-pointer">Cancel</button>
      </div>
    <% end %>
  <% end %>
</div>
