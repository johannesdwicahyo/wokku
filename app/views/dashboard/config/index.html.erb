<%= render "dashboard/apps/tabs", app: @app %>

<div data-controller="config-vars">
  <%# Config Vars List %>
  <div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-[#334155]/50 flex items-center justify-between">
      <div>
        <h2 class="text-base font-semibold text-white">Config Vars</h2>
        <p class="text-sm text-gray-500 mt-1">Environment variables for <span class="font-mono"><%= @app.name %></span></p>
      </div>
      <% if @env_vars.any? %>
        <button data-action="click->config-vars#toggleAll" data-config-vars-target="revealAllBtn"
                class="inline-flex items-center px-3 py-1.5 text-xs text-gray-400 border border-[#334155] rounded-md hover:border-green-500/50 hover:text-green-400 transition cursor-pointer">
          <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          <span data-config-vars-target="revealAllText">Reveal Values</span>
        </button>
      <% end %>
    </div>

    <% if @env_vars.any? %>
      <div class="divide-y divide-[#334155]/50">
        <% @env_vars.each do |var| %>
          <div class="px-6 py-3 flex items-center justify-between hover:bg-[#334155]/20 group" data-config-vars-target="row">
            <div class="flex items-center space-x-4 flex-1 min-w-0">
              <span class="text-sm font-mono font-medium text-green-400 shrink-0"><%= var.key %></span>
              <span class="text-sm font-mono text-gray-500 truncate" data-config-vars-target="maskedValue">••••••••</span>
              <span class="text-sm font-mono text-gray-300 truncate hidden" data-config-vars-target="realValue"><%= var.value %></span>
            </div>
            <div class="flex items-center space-x-2 shrink-0 opacity-0 group-hover:opacity-100 transition">
              <button data-action="click->config-vars#toggleOne"
                      class="p-1.5 text-gray-500 hover:text-green-400 transition cursor-pointer" title="Reveal">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              </button>
              <button data-action="click->config-vars#edit"
                      data-var-id="<%= var.id %>" data-var-key="<%= var.key %>" data-var-value="<%= var.value %>"
                      class="p-1.5 text-gray-500 hover:text-green-400 transition cursor-pointer" title="Edit">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              </button>
              <%= link_to dashboard_app_config_path(@app, var), data: { turbo_method: :delete, turbo_confirm: "Remove #{var.key}?" }, class: "p-1.5 text-gray-500 hover:text-red-400 transition", title: "Delete" do %>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-8 text-center">
        <p class="text-sm text-gray-500">No config vars set.</p>
      </div>
    <% end %>
  </div>

  <%# Edit Modal (hidden by default) %>
  <div data-config-vars-target="editModal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
    <div class="absolute inset-0 bg-black/60" data-action="click->config-vars#closeEdit"></div>
    <div class="relative bg-[#1E293B] border border-[#334155] rounded-xl shadow-2xl w-full max-w-lg mx-4 p-6">
      <h3 class="text-base font-semibold text-white mb-4">Edit Config Var</h3>
      <%= form_with(url: "", method: :patch, data: { config_vars_target: "editForm" }, class: "space-y-4") do |f| %>
        <div>
          <label class="block text-xs text-gray-400 uppercase tracking-wider mb-1">Key</label>
          <input type="text" data-config-vars-target="editKey" disabled
                 class="w-full rounded-md bg-[#0B1120] border-[#334155] text-gray-500 font-mono text-sm cursor-not-allowed">
        </div>
        <div>
          <label class="block text-xs text-gray-400 uppercase tracking-wider mb-1">Value</label>
          <textarea name="env_var[value]" data-config-vars-target="editValue" rows="3"
                    class="w-full rounded-md bg-[#0B1120] border-[#334155] text-white font-mono text-sm focus:ring-green-500 focus:border-green-500"></textarea>
        </div>
        <div class="flex justify-end space-x-3">
          <button type="button" data-action="click->config-vars#closeEdit"
                  class="px-4 py-2 text-sm text-gray-400 hover:text-white transition cursor-pointer">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer">Save</button>
        </div>
      <% end %>
    </div>
  </div>

  <%# Add Config Var %>
  <div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 p-6">
    <h3 class="text-sm font-semibold text-white mb-4">Add Config Var</h3>
    <%= form_with(model: EnvVar.new, url: dashboard_app_config_index_path(@app), class: "flex items-end space-x-3") do |f| %>
      <div class="w-1/3">
        <%= f.label :key, class: "block text-xs text-gray-400 uppercase tracking-wider mb-1" %>
        <%= f.text_field :key, class: "w-full rounded-md bg-[#0B1120] border-[#334155] text-white font-mono text-sm focus:ring-green-500 focus:border-green-500", placeholder: "SECRET_KEY" %>
      </div>
      <div class="flex-1">
        <%= f.label :value, class: "block text-xs text-gray-400 uppercase tracking-wider mb-1" %>
        <%= f.text_field :value, class: "w-full rounded-md bg-[#0B1120] border-[#334155] text-white font-mono text-sm focus:ring-green-500 focus:border-green-500", placeholder: "value" %>
      </div>
      <%= f.submit "Add", class: "px-4 py-2 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer" %>
    <% end %>
  </div>
</div>
