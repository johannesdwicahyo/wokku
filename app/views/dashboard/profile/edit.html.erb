<div class="max-w-lg">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-white">Edit Profile</h1>
  </div>

  <%= form_with(model: current_user, url: dashboard_profile_path, method: :patch, class: "bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 p-6 space-y-5") do |f| %>
    <% if current_user.errors.any? %>
      <div class="bg-red-500/10 border border-red-500/20 rounded-lg p-4">
        <ul class="list-disc list-inside text-sm text-red-400 space-y-1">
          <% current_user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :email, class: "block text-xs text-gray-400 uppercase tracking-wider mb-1" %>
      <%= f.email_field :email, class: "w-full rounded-md bg-[#0B1120] border-[#334155] text-white font-mono text-sm focus:ring-green-500 focus:border-green-500" %>
    </div>

    <div class="flex items-center space-x-3 pt-2">
      <%= f.submit "Save Changes", class: "px-4 py-2 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer" %>
      <%= link_to "Cancel", dashboard_profile_path, class: "text-sm text-gray-500 hover:text-gray-400 transition" %>
    </div>
  <% end %>
</div>
