<div class="max-w-lg">
  <div class="mb-6">
    <h1 class="text-2xl font-headline text-on-surface">Edit Profile</h1>
  </div>

  <%= form_with(model: current_user, url: dashboard_profile_path, method: :patch, class: "bg-surface-container-low rounded-xl border border-outline-variant/15 p-6 space-y-5") do |f| %>
    <% if current_user.errors.any? %>
      <div class="bg-error-container/20 border border-error/20 rounded-lg p-4">
        <ul class="list-disc list-inside text-sm text-error space-y-1">
          <% current_user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :email, class: "block text-xs text-on-surface-variant uppercase tracking-wider mb-1" %>
      <%= f.email_field :email, class: "w-full rounded-md bg-surface border-outline-variant/15 text-on-surface font-mono text-sm focus:ring-primary focus:border-primary" %>
    </div>

    <div>
      <%= f.label :currency, "Billing Currency", class: "block text-xs text-on-surface-variant uppercase tracking-wider mb-1" %>
      <% if current_user.resource_usages.active.billable.any? %>
        <div class="flex items-center gap-2">
          <span class="text-sm text-on-surface font-mono font-bold"><%= current_user.currency.upcase %></span>
          <span class="text-[10px] text-outline">(locked — active paid resources)</span>
        </div>
      <% else %>
        <%= f.select :currency, [["US Dollar (USD)", "usd"], ["Indonesian Rupiah (IDR)", "idr"]],
            {}, class: "w-full rounded-md bg-surface border-outline-variant/15 text-on-surface text-sm focus:ring-primary focus:border-primary" %>
      <% end %>
    </div>

    <div class="flex items-center space-x-3 pt-2">
      <%= f.submit "Save Changes", class: "px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer" %>
      <%= link_to "Cancel", dashboard_profile_path, class: "text-sm text-outline hover:text-on-surface-variant transition" %>
    </div>
  <% end %>
</div>
