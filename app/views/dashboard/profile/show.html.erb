<div data-controller="slide-panel">
  <div class="max-w-2xl">
    <h1 class="text-2xl font-headline text-on-surface mb-2">Profile</h1>
    <p class="text-sm text-outline mb-6">Your account details</p>

    <div class="bg-surface-container-low rounded-xl border border-outline-variant/15 p-6 mb-6">
      <div class="flex items-center space-x-4 mb-6">
        <div class="w-16 h-16 technical-gradient rounded-full flex items-center justify-center text-on-primary text-2xl font-bold">
          <%= current_user.email[0].upcase %>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-on-surface"><%= current_user.email %></h2>
          <p class="text-sm text-outline"><%= current_user.role.capitalize %></p>
        </div>
      </div>

      <dl class="space-y-3">
        <div class="flex justify-between py-2 border-b border-outline-variant/15">
          <dt class="text-sm text-outline">Email</dt>
          <dd class="text-sm text-on-surface"><%= current_user.email %></dd>
        </div>
        <div class="flex justify-between py-2 border-b border-outline-variant/15">
          <dt class="text-sm text-outline">Member since</dt>
          <dd class="text-sm text-on-surface-variant"><%= current_user.created_at.strftime("%B %d, %Y") %></dd>
        </div>
        <div class="flex justify-between py-2">
          <dt class="text-sm text-outline">Teams</dt>
          <dd class="text-sm text-on-surface"><%= current_user.teams.size %></dd>
        </div>
      </dl>
    </div>

    <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer">
      <span class="material-symbols-outlined text-[18px] mr-1.5">edit</span>
      Edit Profile
    </button>
  </div>

  <%= render layout: "dashboard/shared/slide_panel", locals: { title: "Edit Profile", subtitle: "Update your account details" } do %>
    <%= form_with(model: current_user, url: dashboard_profile_path, method: :patch, class: "space-y-4") do |f| %>
      <% if current_user.errors.any? %>
        <div class="rounded-md bg-error-container/20 border border-error/20 p-3">
          <ul class="text-xs text-error space-y-1">
            <% current_user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :email, class: "block text-xs font-medium text-on-surface-variant mb-1.5 uppercase tracking-wider" %>
        <%= f.email_field :email, class: "w-full rounded-md bg-surface border border-outline-variant/15 px-3 py-2 text-sm text-on-surface placeholder-outline-variant focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary font-mono" %>
      </div>

      <div class="flex items-center space-x-3 pt-2">
        <%= f.submit "Save", class: "flex-1 py-2 px-4 technical-gradient text-on-primary text-sm font-semibold rounded-md hover:opacity-90 transition cursor-pointer text-center" %>
        <button type="button" data-action="click->slide-panel#close" class="py-2 px-4 text-sm text-on-surface-variant hover:text-on-surface transition cursor-pointer">Cancel</button>
      </div>
    <% end %>
  <% end %>
</div>
