<div class="max-w-2xl">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Profile</h1>

  <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
    <div class="flex items-center space-x-4 mb-6">
      <div class="w-16 h-16 bg-purple-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
        <%= current_user.email[0].upcase %>
      </div>
      <div>
        <h2 class="text-lg font-semibold text-gray-900"><%= current_user.email %></h2>
        <p class="text-sm text-gray-500"><%= current_user.role.capitalize %></p>
      </div>
    </div>

    <dl class="space-y-3">
      <div class="flex justify-between py-2 border-b border-gray-100">
        <dt class="text-sm text-gray-500">Email</dt>
        <dd class="text-sm text-gray-900"><%= current_user.email %></dd>
      </div>
      <div class="flex justify-between py-2 border-b border-gray-100">
        <dt class="text-sm text-gray-500">Member since</dt>
        <dd class="text-sm text-gray-900"><%= current_user.created_at.strftime("%B %d, %Y") %></dd>
      </div>
      <div class="flex justify-between py-2">
        <dt class="text-sm text-gray-500">Teams</dt>
        <dd class="text-sm text-gray-900"><%= current_user.teams.size %></dd>
      </div>
    </dl>
  </div>

  <%= link_to "Edit Profile", edit_dashboard_profile_path, class: "inline-flex items-center px-4 py-2 bg-purple-600 text-white text-sm font-medium rounded-lg hover:bg-purple-700 transition shadow-sm" %>
</div>
