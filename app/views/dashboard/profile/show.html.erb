<div data-controller="slide-panel">
  <div class="max-w-2xl">
    <h1 class="text-2xl font-bold text-white mb-6">Profile</h1>

    <div class="bg-[#1E293B]/60 rounded-xl border border-[#334155]/50 p-6 mb-6">
      <div class="flex items-center space-x-4 mb-6">
        <div class="w-16 h-16 bg-green-500 rounded-full flex items-center justify-center text-[#0B1120] text-2xl font-bold">
          <%= current_user.email[0].upcase %>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-white"><%= current_user.email %></h2>
          <p class="text-sm text-gray-500"><%= current_user.role.capitalize %></p>
        </div>
      </div>

      <dl class="space-y-3">
        <div class="flex justify-between py-2 border-b border-[#334155]/50">
          <dt class="text-sm text-gray-500">Email</dt>
          <dd class="text-sm text-white"><%= current_user.email %></dd>
        </div>
        <div class="flex justify-between py-2 border-b border-[#334155]/50">
          <dt class="text-sm text-gray-500">Member since</dt>
          <dd class="text-sm text-gray-400"><%= current_user.created_at.strftime("%B %d, %Y") %></dd>
        </div>
        <div class="flex justify-between py-2">
          <dt class="text-sm text-gray-500">Teams</dt>
          <dd class="text-sm text-white"><%= current_user.teams.size %></dd>
        </div>
      </dl>
    </div>

    <button data-action="click->slide-panel#open" class="inline-flex items-center px-4 py-2 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer">Edit Profile</button>
  </div>

  <%= render layout: "dashboard/shared/slide_panel", locals: { title: "Edit Profile", subtitle: "Update your account details" } do %>
    <%= form_with(model: current_user, url: dashboard_profile_path, method: :patch, class: "space-y-4") do |f| %>
      <% if current_user.errors.any? %>
        <div class="rounded-md bg-red-500/10 border border-red-500/20 p-3">
          <ul class="text-xs text-red-400 space-y-1">
            <% current_user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :email, class: "block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider" %>
        <%= f.email_field :email, class: "w-full rounded-md bg-[#0B1120] border border-[#334155] px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-1 focus:ring-green-500 focus:border-green-500 font-mono" %>
      </div>

      <div class="flex items-center space-x-3 pt-2">
        <%= f.submit "Save", class: "flex-1 py-2 px-4 bg-green-500 text-[#0B1120] text-sm font-semibold rounded-md hover:bg-green-400 transition cursor-pointer text-center" %>
        <button type="button" data-action="click->slide-panel#close" class="py-2 px-4 text-sm text-gray-400 hover:text-white transition cursor-pointer">Cancel</button>
      </div>
    <% end %>
  <% end %>
</div>
