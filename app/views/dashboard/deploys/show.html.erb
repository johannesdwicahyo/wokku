<% content_for(:title, "Deploy — #{@app.name}") %>

<div class="space-y-4">
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-3">
      <%= link_to dashboard_app_path(@app), class: "text-sm text-outline hover:text-on-surface-variant transition" do %>
        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
      <% end %>
      <h1 class="text-lg font-semibold text-on-surface font-headline"><%= @app.name %></h1>
      <span class="text-outline-variant">&middot;</span>
      <span class="text-sm text-on-surface-variant">Deploy #<%= @deploy.id %></span>
      <% if @deploy.description.present? %>
        <span class="text-xs text-outline-variant">(<%= @deploy.description %>)</span>
      <% end %>
    </div>
    <div data-deploy-target="statusBadge">
      <% case @deploy.status %>
      <% when "pending" %>
        <span class="inline-flex items-center space-x-1.5 text-xs text-on-surface-variant"><span class="w-1.5 h-1.5 rounded-full bg-outline animate-pulse"></span><span>Pending</span></span>
      <% when "building" %>
        <span class="inline-flex items-center space-x-1.5 text-xs text-tertiary"><span class="w-1.5 h-1.5 rounded-full bg-tertiary animate-pulse"></span><span>Building</span></span>
      <% when "succeeded" %>
        <span class="inline-flex items-center space-x-1.5 text-xs text-primary"><span class="w-1.5 h-1.5 rounded-full bg-primary"></span><span>Succeeded</span></span>
      <% when "failed" %>
        <span class="inline-flex items-center space-x-1.5 text-xs text-error"><span class="w-1.5 h-1.5 rounded-full bg-error"></span><span>Failed</span></span>
      <% when "timed_out" %>
        <span class="inline-flex items-center space-x-1.5 text-xs text-error"><span class="w-1.5 h-1.5 rounded-full bg-error"></span><span>Timed Out</span></span>
      <% end %>
    </div>
  </div>

  <div class="rounded-xl border border-surface-container-low bg-surface overflow-hidden"
       data-controller="deploy"
       data-deploy-deploy-id-value="<%= @deploy.id %>">
    <div class="flex items-center justify-between px-4 py-2.5 border-b border-surface-container-low">
      <div class="flex items-center space-x-2">
        <div class="flex space-x-1.5">
          <div class="w-2.5 h-2.5 rounded-full bg-surface-container-high"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-surface-container-high"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-surface-container-high"></div>
        </div>
        <span class="text-[10px] text-outline-variant font-mono">deploy log</span>
      </div>
      <% if @deploy.finished_at && @deploy.started_at %>
        <span class="text-[10px] text-outline-variant font-mono">
          Duration: <%= (@deploy.finished_at - @deploy.started_at).round(1) %>s
        </span>
      <% end %>
    </div>
    <div data-deploy-target="output"
         class="p-4 font-mono text-xs text-on-surface-variant whitespace-pre-wrap overflow-y-auto h-[calc(100vh-250px)] leading-relaxed"><%= @deploy.log %></div>
  </div>
</div>
