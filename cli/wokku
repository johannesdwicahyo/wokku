#!/usr/bin/env ruby
# Wokku CLI — manage your Wokku apps from the terminal
# Install: curl -sL https://wokku.cloud/cli/install.sh | bash
# Or:      cp cli/wokku /usr/local/bin/wokku && chmod +x /usr/local/bin/wokku

require "json"
require "net/http"
require "uri"
require "io/console"
require "fileutils"

VERSION = "1.3.1"
CONFIG_DIR = File.expand_path("~/.wokku")
CONFIG_FILE = File.join(CONFIG_DIR, "config.json")

# === Config ===
def load_config
  return {} unless File.exist?(CONFIG_FILE)
  JSON.parse(File.read(CONFIG_FILE))
rescue
  {}
end

def save_config(config)
  FileUtils.mkdir_p(CONFIG_DIR)
  File.write(CONFIG_FILE, JSON.pretty_generate(config))
  File.chmod(0600, CONFIG_FILE)
end

def api_url
  load_config["api_url"] || ENV["WOKKU_API_URL"] || "https://wokku.cloud/api/v1"
end

def api_token
  load_config["token"] || ENV["WOKKU_API_TOKEN"]
end

# === API Client ===
def api(method, path, body = nil)
  token = api_token
  abort "Not logged in. Run: wokku auth:login" unless token

  uri = URI("#{api_url}#{path}")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = uri.scheme == "https"
  http.open_timeout = 10
  http.read_timeout = 30

  req = case method
  when :get then Net::HTTP::Get.new(uri)
  when :post then Net::HTTP::Post.new(uri)
  when :put then Net::HTTP::Put.new(uri)
  when :patch then Net::HTTP::Patch.new(uri)
  when :delete then Net::HTTP::Delete.new(uri)
  end

  req["Authorization"] = "Bearer #{token}"
  req["Content-Type"] = "application/json"
  req["User-Agent"] = "WokkuCLI/#{VERSION}"
  req.body = body.to_json if body

  resp = http.request(req)
  data = JSON.parse(resp.body) rescue resp.body

  unless resp.is_a?(Net::HTTPSuccess)
    error = data.is_a?(Hash) ? (data["error"] || data["errors"]&.join(", ") || resp.code) : resp.code
    abort "Error: #{error}"
  end

  data
end

# === Formatting ===
def table(rows, headers: nil)
  return if rows.empty?
  cols = (headers || rows.first.keys).map(&:to_s)
  widths = cols.map { |c| c.length }
  rows.each { |r| cols.each_with_index { |c, i| widths[i] = [ widths[i], r[c].to_s.length ].max } }

  fmt = widths.map { |w| "%-#{w}s" }.join("  ")
  puts fmt % cols.map(&:upcase)
  puts widths.map { |w| "-" * w }.join("  ")
  rows.each { |r| puts fmt % cols.map { |c| r[c] } }
end

def puts_json(data)
  puts JSON.pretty_generate(data)
end

# === Commands ===
COMMANDS = {}

def register(name, desc, &block)
  COMMANDS[name] = { desc: desc, handler: block }
end

# --- Auth ---
register "auth:login", "Authenticate with Wokku via browser (OAuth device flow)" do
  print "Wokku API URL [https://wokku.cloud/api/v1]: "
  url = $stdin.gets.strip
  url = "https://wokku.cloud/api/v1" if url.empty?

  # Step 1: request a device + user code
  start_uri = URI("#{url}/auth/device/code")
  http = Net::HTTP.new(start_uri.host, start_uri.port)
  http.use_ssl = start_uri.scheme == "https"
  req = Net::HTTP::Post.new(start_uri)
  req["User-Agent"] = "WokkuCLI/#{VERSION}"
  resp = http.request(req)
  data = JSON.parse(resp.body) rescue {}
  abort "Failed to start device flow: #{data['error'] || resp.code}" unless resp.is_a?(Net::HTTPSuccess)

  device_code = data["device_code"]
  user_code = data["user_code"]
  verify_url = data["verification_uri_complete"] || data["verification_uri"]
  interval = (data["interval"] || 5).to_i
  expires_in = (data["expires_in"] || 600).to_i

  puts ""
  puts "  Open in your browser: #{verify_url}"
  puts "  Code:                 #{user_code}"
  puts ""
  puts "Waiting for authorization..."

  # Try to open browser (best-effort)
  opener = case RUBY_PLATFORM
           when /darwin/ then "open"
           when /linux/  then "xdg-open"
           when /mingw|mswin/ then "start"
           end
  system(opener, verify_url, [:out, :err] => "/dev/null") if opener

  # Step 2: poll for token
  poll_uri = URI("#{url}/auth/device/token")
  poll_http = Net::HTTP.new(poll_uri.host, poll_uri.port)
  poll_http.use_ssl = poll_uri.scheme == "https"
  deadline = Time.now + expires_in

  loop do
    if Time.now > deadline
      abort "Authorization timed out. Run wokku auth:login to try again."
    end
    sleep interval

    poll_req = Net::HTTP::Post.new(poll_uri)
    poll_req["Content-Type"] = "application/json"
    poll_req["User-Agent"] = "WokkuCLI/#{VERSION}"
    poll_req.body = { device_code: device_code }.to_json
    poll_resp = poll_http.request(poll_req)
    poll_data = JSON.parse(poll_resp.body) rescue {}

    case poll_resp.code.to_i
    when 200
      email = poll_data.dig("user", "email")
      save_config({ "api_url" => url, "token" => poll_data["token"], "email" => email })
      puts "Logged in as #{email}"
      break
    when 202
      next # authorization_pending
    when 400
      interval += 1 if poll_data["error"] == "slow_down"
    when 403
      abort "Authorization denied."
    when 410
      abort "Authorization #{poll_data['error'] || 'expired'}. Run wokku auth:login to try again."
    else
      abort "Unexpected response (#{poll_resp.code}): #{poll_data['error'] || poll_resp.body}"
    end
  end
end

register "auth:logout", "Log out" do
  if File.exist?(CONFIG_FILE)
    File.delete(CONFIG_FILE)
    puts "Logged out."
  else
    puts "Not logged in."
  end
end

register "auth:whoami", "Show current user" do
  data = api(:get, "/auth/whoami")
  puts "Email: #{data['email']}"
  puts "Role:  #{data['role']}"
end

# --- Apps ---
register "apps", "List all apps" do
  apps = api(:get, "/apps")
  table(apps.map { |a| { "name" => a["name"], "status" => a["status"], "server" => a["server_id"] } })
end

register "apps:info", "Show app details (usage: wokku apps:info APP)" do
  id = ARGV.shift || abort("Usage: wokku apps:info APP")
  puts_json api(:get, "/apps/#{id}")
end

register "servers", "List available servers" do
  rows = api(:get, "/servers").map { |s| { "id" => s["id"], "name" => s["name"], "host" => s["host"] } }
  table(rows, headers: %w[id name host])
end

register "apps:create", "Create app (usage: wokku apps:create NAME --server ID|NAME)" do
  name = ARGV.shift || abort("Usage: wokku apps:create NAME --server ID|NAME")
  server_arg = nil
  branch = "main"
  while arg = ARGV.shift
    case arg
    when "--server" then server_arg = ARGV.shift
    when "--branch" then branch = ARGV.shift
    end
  end
  abort "Missing --server ID|NAME (run: wokku servers)" unless server_arg

  server_id = if server_arg.match?(/\A\d+\z/)
    server_arg.to_i
  else
    match = api(:get, "/servers").find { |s| s["name"] == server_arg }
    abort "Server '#{server_arg}' not found. Run: wokku servers" unless match
    match["id"]
  end

  data = api(:post, "/apps", { name: name, server_id: server_id, deploy_branch: branch })
  puts "Created app: #{data['name']} (id: #{data['id']})"
end

register "apps:destroy", "Delete app (usage: wokku apps:destroy APP)" do
  id = ARGV.shift || abort("Usage: wokku apps:destroy APP")
  print "Are you sure you want to delete this app? (y/N): "
  confirm = $stdin.gets.strip
  abort "Cancelled." unless confirm.downcase == "y"
  api(:delete, "/apps/#{id}")
  puts "App deleted."
end

