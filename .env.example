DATABASE_URL=postgres://postgres:wokku@db:5432/wokku
REDIS_URL=redis://redis:6379/0
SECRET_KEY_BASE=generate-with-rails-secret
GIT_HOST=0.0.0.0
GIT_PORT=2222

# GitHub App (optional — for auto-deploy from GitHub)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_SLUG=wokku
# Note: GitHub App needs "Issues: Read & Write" permission for PR preview comments

# OAuth (at least one required — these are the only login methods)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
