#!/usr/bin/env bash
# Scan staged files or given files for hardcoded secrets
set -e

# Patterns that indicate hardcoded secrets
PATTERNS=(
  'ghp_[A-Za-z0-9]{36}'           # GitHub PAT
  'gho_[A-Za-z0-9]{36}'           # GitHub OAuth
  'github_pat_[A-Za-z0-9_]{82}'   # GitHub fine-grained PAT
  'sk-[A-Za-z0-9]{48}'            # OpenAI API key
  'sk-ant-[A-Za-z0-9-]{95}'       # Anthropic API key
  're_[A-Za-z0-9]{20,}'           # Resend API key (no _ — real keys are alphanumeric only after re_)
  'AKIA[0-9A-Z]{16}'              # AWS Access Key
  'whsec_[A-Za-z0-9]{32}'         # Stripe webhook secret
  'sk_live_[A-Za-z0-9]{24,}'      # Stripe secret key
  'xoxb-[0-9]{10,}-[A-Za-z0-9]+'  # Slack bot token
  '-----BEGIN.*PRIVATE KEY-----'   # Private keys
)

# Files to scan: either passed as args or staged files
if [ $# -gt 0 ]; then
  FILES="$@"
else
  FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null)
fi

if [ -z "$FILES" ]; then
  exit 0
fi

# Exclude known safe files
EXCLUDE_PATTERNS="\.kamal/secrets|\.env$|\.env\.local|test/|spec/|docs/content/"

FOUND=0
for pattern in "${PATTERNS[@]}"; do
  MATCHES=$(echo "$FILES" | grep -vE "$EXCLUDE_PATTERNS" | xargs grep -lEn "$pattern" 2>/dev/null || true)
  if [ -n "$MATCHES" ]; then
    if [ $FOUND -eq 0 ]; then
      echo "✗ Potential secrets detected:"
      echo ""
    fi
    FOUND=1
    echo "  Pattern: $pattern"
    echo "$MATCHES" | while read -r file; do
      echo "    → $file"
      grep -nE "$pattern" "$file" 2>/dev/null | head -3 | sed 's/^/      /'
    done
    echo ""
  fi
done

if [ $FOUND -eq 1 ]; then
  echo "Move secrets to .kamal/secrets or environment variables."
  echo "If this is a false positive, use: git commit --no-verify"
  exit 1
fi
