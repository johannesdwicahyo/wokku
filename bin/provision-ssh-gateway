#!/bin/bash
# Provision the SSH git gateway on the wokku.cloud host.
#
# Run this on 43.159.57.11 as root (or via `sudo bash provision-ssh-gateway`).
# It's idempotent — safe to re-run.

set -euo pipefail

if [[ $EUID -ne 0 ]]; then
  echo "must run as root (try: sudo bash $0)" >&2
  exit 1
fi

WOKKU_DIR=/etc/wokku
WOKKU_BIN=/opt/wokku/bin
CONTAINER_GLOB='wokku-web-*'

echo "[1/5] Creating git user + directories"
if ! id git >/dev/null 2>&1; then
  useradd --system --create-home --shell /bin/bash --home-dir /var/lib/wokku-git git
fi
mkdir -p "$WOKKU_DIR" "$WOKKU_BIN" /var/lib/wokku-git /var/log/wokku
chown git:git /var/lib/wokku-git /var/log/wokku
chmod 755 "$WOKKU_BIN"
# /etc/wokku must be writable by the web container (UID 1000 = rails) so
# Git::AuthorizedKeysWriter + Git::KnownHostsWriter can update their
# files directly. sshd reads as root, so permissions on the contents
# don't matter much.
chown 1000:1000 "$WOKKU_DIR"
chmod 755 "$WOKKU_DIR"

WEB_CONTAINER=$(docker ps --filter "name=${CONTAINER_GLOB}" --format '{{.Names}}' | head -1)
if [[ -z "$WEB_CONTAINER" ]]; then
  echo "  ERR: no running web container found (docker ps --filter 'name=${CONTAINER_GLOB}')" >&2
  exit 1
fi

echo "[2/5] Installing host-side wokku-git-shell wrapper"
cat > "$WOKKU_BIN/wokku-git-shell" <<'BASH'
#!/bin/bash
# Host-side wrapper. sshd invokes this; it docker-execs into the current
# web container so the Ruby logic has Rails + DB access.
set -e
CONTAINER=$(docker ps --filter 'name=wokku-web-' --format '{{.Names}}' | head -1)
if [[ -z "$CONTAINER" ]]; then
  echo "wokku: backend unavailable" >&2
  exit 1
fi
exec docker exec -i \
  -e SSH_ORIGINAL_COMMAND="$SSH_ORIGINAL_COMMAND" \
  -e WOKKU_GIT_KEY_ID="$WOKKU_GIT_KEY_ID" \
  "$CONTAINER" bin/wokku-git-shell
BASH
chmod 755 "$WOKKU_BIN/wokku-git-shell"

echo "[3/5] sshd config fragments"

# PermitUserEnvironment must be at top level — sshd doesn't allow it
# inside a Match block. Whitelist only WOKKU_GIT_KEY_ID so other users'
# authorized_keys can't smuggle arbitrary environment variables.
cat > /etc/ssh/sshd_config.d/59-wokku-env.conf <<'CONF'
# Managed by bin/provision-ssh-gateway. Do not edit.
PermitUserEnvironment WOKKU_GIT_KEY_ID
CONF
chmod 644 /etc/ssh/sshd_config.d/59-wokku-env.conf

SSHD_FRAGMENT=/etc/ssh/sshd_config.d/60-wokku-git-gateway.conf
cat > "$SSHD_FRAGMENT" <<CONF
# Managed by bin/provision-ssh-gateway. Do not edit.
Match User git
    AuthorizedKeysFile ${WOKKU_DIR}/git-authorized-keys
    PermitTTY no
    X11Forwarding no
    AllowAgentForwarding no
    AllowTcpForwarding no
    PermitOpen none
    ForceCommand ${WOKKU_BIN}/wokku-git-shell
CONF
chmod 644 "$SSHD_FRAGMENT"
if sshd -t 2>/dev/null; then
  systemctl reload ssh || systemctl reload sshd
  echo "  sshd reloaded"
else
  echo "  ERR: sshd -t failed; NOT reloading. Fix $SSHD_FRAGMENT and retry." >&2
  exit 1
fi

echo "[4/5] Seeding authorized_keys + known_hosts from Rails"
docker exec "$WEB_CONTAINER" bin/rails wokku:gateway:write_authorized_keys || true
docker exec "$WEB_CONTAINER" bin/rails runner \
  "Server.find_each { |s| SeedKnownHostsJob.perform_later(s.id) }" || true

echo "[5/5] Installing gateway pubkey on existing Dokku servers"
docker exec "$WEB_CONTAINER" bin/rails wokku:gateway:install_on_all_servers || true

echo ""
echo "DONE. Quick checks:"
echo "  ls -la ${WOKKU_DIR}/"
echo "  sudo -u git ssh -T git@localhost       # should print the greeting"
echo ""
echo "From a laptop:"
echo "  ssh -T git@wokku.cloud                 # should print the greeting"
